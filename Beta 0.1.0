#!/bin/bash

RESET="\e[0m"

COLORS=(
"255;120;0"
"255;80;80"
"255;0;150"
"200;0;220"
"150;0;255"
"110;0;255"
)

i=0

while IFS= read -r line; do
    COLOR="\e[38;2;${COLORS[$(( i % ${#COLORS[@]} ))]}m"
    printf "%b%s%b\n" "$COLOR" "$line" "$RESET"
    ((i++))
done <<'EOF'
      _   _    ____     ____ ___  __  __ __  __    _    _   _ ____  
     | | / \  / ___|   / ___/ _ \|  \/  |  \/  |  / \  | \ | |  _ \ 
  _  | |/ _ \ \___ \  | |  | | | | |\/| | |\/| | / _ \ |  \| | | | |
 | |_| / ___ \ ___) | | |__| |_| | |  | | |  | |/ ___ \| |\  | |_| |
  \___/_/   \_\____/   \____\___/|_|  |_|_|  |_/_/   \_\_| \_|____/ 
                                                                    
EOF


echo "    Beta version 0.1.0 - Author: Jasper - License: MIT"




