#!/bin/bash

TRASH_FILES="$HOME/.local/share/Trash/files"
TRASH_INFO="$HOME/.local/share/Trash/info"
RESET="\e[0m"

COLORS=(
"255;120;0"
"255;80;80"
"255;0;150"
"200;0;220"
"150;0;255"
"110;0;255"
)

i=0

while IFS= read -r line; do
    COLOR="\e[38;2;${COLORS[$(( i % ${#COLORS[@]} ))]}m"
    printf "%b%s%b\n" "$COLOR" "$line" "$RESET"
    ((i++))
done <<'EOF'
      _   _    ____     ____ ___  __  __ __  __    _    _   _ ____  
     | | / \  / ___|   / ___/ _ \|  \/  |  \/  |  / \  | \ | |  _ \ 
  _  | |/ _ \ \___ \  | |  | | | | |\/| | |\/| | / _ \ |  \| | | | |
 | |_| / ___ \ ___) | | |__| |_| | |  | | |  | |/ ___ \| |\  | |_| |
  \___/_/   \_\____/   \____\___/|_|  |_|_|  |_/_/   \_\_| \_|____/ 
                                                                    
EOF


echo "    Beta version 0.1.1 - Author: Jasper - License: MIT"

PS3="Select option: "

select opt in "Securely empty trash" "Exit"; do
    case $REPLY in
        1)
            if [[ -z "$(ls -A "$TRASH_FILES" 2>/dev/null)" && -z "$(ls -A "$TRASH_INFO" 2>/dev/null)" ]]; then
                echo "Trash is empty."
                continue
            fi

            read -rp "Confirm deletion (y/n): " confirm
            if [[ "$confirm" != "y" ]]; then
                echo "Aborted."
                continue
            fi

            echo "Deleting files..."
            srm -v -r "${TRASH_FILES}/"*

            echo "Securely deleting trash info..."
            srm -v -r "${TRASH_INFO}/"*

            echo "Completed"
            ;;
            
        2)
            echo "Exiting."
            break
            ;;
            
        *)
            echo "Invalid option"
            ;;
    esac
done






