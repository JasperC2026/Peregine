  \____/_/    \_\_____/     |_|  \____/ \____/|______|____/ \____/_/ \_\
                                                                        
                                                                                                                                     
EOF


echo -e "${BOLD}${YELLOW}  Version 1.2 - Author: Jasper - License: MIT${RESET}"

