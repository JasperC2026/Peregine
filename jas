    echo -e "${PURPLE}"
    cat << "EOF"
                                            =                       
                                      == ==                     
..........................         ======                       
..........................        ======                        
..........................       =====                          
..........................    @@@===                            
..........................     @.:%@@                           
 .     ............            @=.-=@                   ........
        ...........           @@....%@               ...........
