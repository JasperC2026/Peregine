# -------------------
# Colors for ASCII art
# -------------------

RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"
BOLD="\e[1m"
RESET="\e[0m"

#ASCII art with color cycling
COLORS=(
"255;120;0"
"255;80;80"
"255;0;150"
"200;0;220"
"150;0;255"
"110;0;255"
)

i=0

while IFS= read -r line; do
    COLOR="\e[38;2;${COLORS[$(( i % ${#COLORS[@]} ))]}m"
    printf "%b%s%b\n" "$COLOR" "$line" "$RESET"
    ((i++))
done <<'EOF'
