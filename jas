    # Warn if not running as root (Lynis gives incomplete results without sudo)
    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}[!] Not running as root. Some checks may be skipped.${RESET}"
        echo -e "${YELLOW}    For a full audit, run: sudo jas system_audit${RESET}"
        echo
        read -rp "Continue anyway? (y/n): " cont
        [[ "$cont" != "y" ]] && return 0
    fi

    echo
    echo -e "${GREEN}[➜] Starting Lynis system audit — this may take a few minutes...${RESET}"
    echo "---------------------------------------------------------------"
    echo

    # Stream output live instead of buffering
    sudo lynis audit system
    status=$?

    echo
    echo "---------------------------------------------------------------"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Lynis finished with errors (exit code $status).${RESET}"
        return 1
    fi

    # Parse the report file for a summary
    local report="/var/log/lynis-report.dat"
    if [[ -f "$report" ]]; then
        echo -e "${CYAN}── Audit Summary ────────────────────────────────────────────${RESET}"

        local index warnings suggestions
        index=$(sudo grep   'hardening_index='  "$report" | cut -d= -f2)
        warnings=$(sudo grep -c '^warning\[\]=' "$report" 2>/dev/null || echo 0)
        suggestions=$(sudo grep -c '^suggestion\[\]=' "$report" 2>/dev/null || echo 0)

        # Colour the hardening index: <60 red, 60-79 yellow, 80+ green
        if [[ -n "$index" ]]; then
            if   (( index >= 80 )); then echo -e "  Hardening index : ${GREEN}${index}/100${RESET}"
            elif (( index >= 60 )); then echo -e "  Hardening index : ${YELLOW}${index}/100${RESET}"
            else                         echo -e "  Hardening index : ${RED}${index}/100${RESET}"
            fi
        fi

        echo -e "  Warnings        : ${RED}${warnings}${RESET}"
        echo -e "  Suggestions     : ${YELLOW}${suggestions}${RESET}"
        echo
        echo -e "  Full report     : ${CYAN}/var/log/lynis-report.dat${RESET}"
        echo -e "  Log             : ${CYAN}/var/log/lynis.log${RESET}"
        echo "---------------------------------------------------------------"
    fi

    echo -e "${GREEN}[+] System audit completed successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
