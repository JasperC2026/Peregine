setup_usbguard() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Installing USBGuard...${RESET}"
    sleep 0.5

    sudo apt update
    sudo apt install -y usbguard

    echo
    echo -e "${GREEN}[➜] Generating initial policy (VERY IMPORTANT)...${RESET}"
    echo -e "${YELLOW}[!] Make sure all trusted USB devices are plugged in!${RESET}"
    sleep 3

    sudo usbguard generate-policy > /tmp/usbguard-rules.conf

    echo
    echo -e "${GREEN}[➜] Applying policy...${RESET}"
    sudo mv /tmp/usbguard-rules.conf /etc/usbguard/rules.conf
    sudo chown root:root /etc/usbguard/rules.conf
    sudo chmod 600 /etc/usbguard/rules.conf

    echo
    echo -e "${GREEN}[➜] Enabling USBGuard service...${RESET}"
    sudo systemctl enable usbguard
    sudo systemctl start usbguard

    echo
    echo -e "${GREEN}[+] USBGuard is now active.${RESET}"
    echo -e "${YELLOW}[!] New USB devices will be BLOCKED by default.${RESET}"
    echo "---------------------------------------------------------------"
}
setup_ufw() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Installing UFW...${RESET}"
    sleep 0.5

    sudo apt update
    sudo apt install -y ufw

    echo
    echo -e "${GREEN}[➜] Setting default policies...${RESET}"
    sudo ufw default deny incoming
    sudo ufw default allow outgoing

    echo
    echo -e "${GREEN}[➜] Allowing essential services...${RESET}"

    read -p "Allow SSH (port 22)? (y/n): " allow_ssh
    if [[ "$allow_ssh" == "y" ]]; then
        sudo ufw allow 22/tcp
        echo -e "${GREEN}[+] SSH allowed${RESET}"
    fi

    sudo ufw allow from 192.168.0.0/16
    sudo ufw allow from 10.0.0.0/8

    echo
    echo -e "${GREEN}[➜] Enabling firewall...${RESET}"
    sudo ufw enable

    echo
    echo -e "${GREEN}[➜] Current status:${RESET}"
    sudo ufw status verbose

    echo
    echo -e "${GREEN}[+] UFW setup completed.${RESET}"
    echo -e "${YELLOW}[!] Incoming connections are BLOCKED by default.${RESET}"
    echo "---------------------------------------------------------------"
}
secure_empty_trash() {
    clear
    echo "---------------------------------------------------------------"

    local TRASH_FILES="$HOME/.local/share/Trash/files"
    local TRASH_INFO="$HOME/.local/share/Trash/info"

    if ! command -v srm &>/dev/null; then
        echo -e "\a"
        echo -e "${RED}[!] srm is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install secure-delete${RESET}"
        return 1
    fi

    # Count items using find to avoid glob expansion issues on empty dirs
    local file_count
    file_count=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l)

    if [[ $file_count -eq 0 ]]; then
        echo -e "${GREEN}[i] Trash is already empty.${RESET}"
        echo "---------------------------------------------------------------"
        return 0
    fi

    echo -e "${CYAN}[i] Found $file_count item(s) in Trash.${RESET}"
    echo
    read -rp "Securely delete all trash? (y/n): " confirm
    if [[ "$confirm" != "y" ]]; then
        echo -e "${YELLOW}[!] Deletion aborted.${RESET}"
        return 0
    fi

    echo
    echo -e "${GREEN}[➜] Securely deleting trash files...${RESET}"
    find "$TRASH_FILES" -mindepth 1 -exec srm -v -r {} + 2>/dev/null

    echo -e "${GREEN}[➜] Removing trash metadata...${RESET}"
    find "$TRASH_INFO" -mindepth 1 -name "*.trashinfo" -exec srm -v {} + 2>/dev/null

    # Verify
    local remaining
    remaining=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l)
    if [[ $remaining -eq 0 ]]; then
        echo -e "${GREEN}[+] Trash securely emptied.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] $remaining item(s) may not have been deleted — check manually.${RESET}"
        return 1
    fi

    echo "---------------------------------------------------------------"
}
secure_overwrite_free_space() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Securely overwriting free space...${RESET}"
    root_partition=$(df / | tail -1 | awk '{print $1}')

    if ! command -v srm &> /dev/null; then
        echo -e "\a"
        echo -e "${RED}[!] srm command not found. Please install it to use this feature.${RESET}"
        return 1
    fi

    echo
    echo -e "${GREEN}[+] Overwriting free space on $root_partition...${RESET}"
    srm -v -z -r --free "$root_partition"

    echo -e "${GREEN}[+] Free space securely overwritten.${RESET}"
    echo "---------------------------------------------------------------"
}
