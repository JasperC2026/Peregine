    paranoia_mode() {
                        clear
                        echo
                        local status=0

                        echo -e "${GREEN}[➜] Enabling Paranoia mode...${RESET}"
                        sleep 0.5

                        if sudo iptables -P OUTPUT DROP; then
                            sudo iptables -A OUTPUT -d 127.0.0.1 -j ACCEPT
                        else
                            echo -e "\a"
                            echo -e "${RED}[!] iptables failed${RESET}"
                            status=1
                        fi

                        if ! nmcli networking off; then
                            echo -e "${RED}[!] NetworkManager disable failed${RESET}"
                            status=1
                        fi

                        shred -u ~/.bash_history 2>/dev/null || true
                        history -c 2>/dev/null || true

                        find /tmp -type f -user "$USER" -exec shred -u {} \; 2>/dev/null

                        sudo modprobe -r uvcvideo 2>/dev/null || true
                        sudo modprobe -r snd_hda_intel 2>/dev/null || true

                        if [[ $status -eq 0 ]]; then
                            echo -e "${GREEN}[+] Paranoia mode enabled successfully.${RESET}"
                        else
                            echo -e "\a"
                            echo -e "${RED}[!] Paranoia mode partially failed (check output above).${RESET}"
                        fi

                        return $status
                        echo
                    }
    secure_empty_trash() {
                    clear
                    echo
                    TRASH_FILES="$HOME/.local/share/Trash/files"
                    TRASH_INFO="$HOME/.local/share/Trash/info"

                    if [[ -z "$(ls -A "$TRASH_FILES" 2>/dev/null)" && -z "$(ls -A "$TRASH_INFO" 2>/dev/null)" ]]; then
                        echo "Trash is empty."
                        return 1
                    fi

                    read -rp "Confirm deletion (y/n): " confirm
                    if [[ "$confirm" != "y" ]]; then
                        echo -e "${RED}[!] Deletion aborted.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[➜] Securely deleting trash...${RESET}"
                    sleep 0.5
                    echo "Deleting files..."
                    srm -v -r "${TRASH_FILES}/"* 2>/dev/null

                    echo -e "${GREEN}[➜] Securely deleting trash info...${RESET}"
                    sleep 0.5
                    srm -v -r "${TRASH_INFO}/"* 2>/dev/null

                    echo -e "${GREEN}[+] Deletion completed.${RESET}"
                    echo
                    }
    secure_overwrite_free_space() {
                    clear
                    echo
                    echo -e "${GREEN}[➜] Securely overwriting free space...${RESET}"
                    root_partition=$(df / | tail -1 | awk '{print $1}')

                    if ! command -v srm &> /dev/null; then
                        echo -e "${RED}[!] srm command not found. Please install it to use this feature.${RESET}"
                        return 1
                    fi

                    echo
                    echo -e "${GREEN}[+] Overwriting free space on $root_partition...${RESET}"
                    srm -v -z -r --free "$root_partition"

                    echo -e "${GREEN}[+] Free space securely overwritten.${RESET}"
                    echo
                    }
