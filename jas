generate_password() {
    echo "---------------------------------------------------------------"
    echo "OpenSSL by the OpenSSL Project https://openssl.org/"
    echo -e "${GREEN}[➜] Generating secure password...${RESET}"
    sleep 0.5
    echo

    if command -v openssl >/dev/null 2>&1; then
        password=$(openssl rand -base64 12 2>/dev/null)
        status=$?

        if [[ $status -eq 0 && -n "$password" ]]; then
            echo -e "${CYAN}$password${RESET}"
            echo -e "${GREEN}[+] Password generation completed.${RESET}"
        else
            echo -e "\a"
            echo -e "${RED}[!] Failed to generate password.${RESET}"
            return 1
        fi
    else
        echo -e "\a"
        echo -e "${RED}[!] OpenSSL is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install openssl${RESET}"
        return 1
    fi
    echo "---------------------------------------------------------------"
}
delete_file() {
    echo "---------------------------------------------------------------"
    echo -n "Enter file: "
    read -r file

    if [[ -z "$file" ]]; then
        echo -e "${YELLOW}[!] No file entered.${RESET}"
    elif [[ ! -f "$file" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] File does not exist.${RESET}"
    else
        echo -e "${GREEN}[+] Running shred for: $file${RESET}"
        shred -u -v -n 5 "$file"
        echo -e "${GREEN}[+] File securely deleted.${RESET}"
    fi
echo "---------------------------------------------------------------"
}
clean_metadata() {
    echo "---------------------------------------------------------------"
    echo "ExifTool by Phil Harvey https://exiftool.org/"
    echo -e "${GREEN}[➜] Removing metadata from image...${RESET}"
    echo

    if ! command -v exiftool >/dev/null 2>&1; then
        echo -e "\a"
        echo -e "${RED}[!] exiftool is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install libimage-exiftool-perl${RESET}"
        return 1
    fi

    read -rp "Enter image file: " file

    if [[ ! -f "$file" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] File not found.${RESET}"
        return 1
    fi

    read -rp "Output file (e.g. clean.jpg): " outfile

    exiftool -all= -overwrite_original -o "$outfile" "$file" >/dev/null 2>&1
    status=$?

    if [[ $status -eq 0 ]]; then
        echo -e "${GREEN}[+] Metadata removed → $outfile${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Failed to remove metadata.${RESET}"
        return 1
    fi
    echo "---------------------------------------------------------------"
}
