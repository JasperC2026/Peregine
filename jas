      | |  /\    / ____| |__   __/ __ \ / __ \| |    |  _ \ / __ \ \ / /
      | | /  \  | (___      | | | |  | | |  | | |    | |_) | |  | \ V / 
  _   | |/ /\ \  \___ \     | | | |  | | |  | | |    |  _ <| |  | |> <  
 | |__| / ____ \ ____) |    | | | |__| | |__| | |____| |_) | |__| / . \ 
  \____/_/    \_\_____/     |_|  \____/ \____/|______|____/ \____/_/ \_\
                                                                        
                                                                                                                                     
EOF


echo "    Alpha version 1.0 - Author: Jasper - License: MIT"

# -------------------
# Network Tools Submenu
# -------------------
network_tools() {
    while true; do
        PS3="Network Tools Menu: "
        options=("Whois" "Ping" "Trace" "DNS info" "get IP" "Back")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    # Whois lookup
                    echo -n "Enter domain (ex: example.com): "
                    read -r domain
                    whois "$domain"
                    ;;
                2)
                    echo -n "Enter item to ping: "
                    read -r itemping
                    ping "$itemping"
                    ;;
                3)
                    echo -n "Enter domain to trace: "
                    read -r domaintrace
                    traceroute "$domaintrace"
                    ;;
                4)
                    echo -n "Enter domain to get DNS info: "
                    read -r domaindns
                    dig "$domaindns"
                    ;;
                5)
                    curl ifconfig.me
                    ;;
                6)
                    return  # Back to main menu
                    ;;
                *)
                    echo "Invalid option"
                    ;;
            esac
        done
    done
}

# -------------------
# System Tools Submenu
# -------------------
system_tools() {
    while true; do
        PS3="System Tools Menu: "
        options=("Updating all apps" "See system information" "Back")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    echo "Updating all apps..."
                    # update APT
                    echo "Updating all APT packages..."
                    echo
                    sudo apt update && sudo apt upgrade -y
                    echo
                    echo "APT packages updated"
                    echo 
                    # update flatpak
                    echo "Updating all flatpak packages..."
                    echo
                    flatpak update -y
                    echo
                    echo "flatpak updated"
                    echo 
                    # update snap
                    echo "Updating all snap packages..."
                    echo
                    sudo snap refresh
                    echo
                    upgradable=$(snap list --upgradable)
                    if [ -z "$upgradable" ]; then
                    echo "No upgradable Snap packages found."
                    else
                    echo "Upgradable Snap packages:"
                    echo "$upgradable" 
                    echo "Updating upgradable Snap packages..."
                    sudo snap refresh --all
                    echo 
                    echo "All upgradable Snap packages have been updated."
                    echo
                    fi
            ;;
                2)
                    fastfetch
                    ;;
                3)
                    return
                    ;;
                *)
                    echo "Invalid option"
                    ;;
            esac
        done
    done
}

# -------------------
# Privacy/Security Tools Submenu
# -------------------
privacy_tools() {
    while true; do
        PS3="Privacy/Security Menu: "
        options=("Secure empty trash" "Securely overwrite free space" "Check for rootkits" "Removing file" "Generate secure password" "Remove temporary files" "Back")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                     # Check if trash is empty
                    if [[ -z "$(ls -A "$TRASH_FILES" 2>/dev/null)" && -z "$(ls -A "$TRASH_INFO" 2>/dev/null)" ]]; then
                        echo "Trash is empty."
                        continue
                    fi

                    # Confirm deletion
                    read -rp "Confirm deletion (y/n): " confirm
                    if [[ "$confirm" != "y" ]]; then
                        echo "Aborted."
                        continue
                    fi

                    # Securely delete files
                    echo "Deleting files..."
                    srm -v -r "${TRASH_FILES}/"*

                    echo "Securely deleting trash info..."
                    srm -v -r "${TRASH_INFO}/"*

                    # Completed status
                    echo "Completed"
                    ;;
            
                2)
                    echo "Securely overwriting free space..."
                    # Get the root partition
                    root_partition=$(df / | tail -1 | awk '{print $1}')
                    
                    # Check if srm is installed
                    if ! command -v srm &> /dev/null; then
                        echo "srm command not found. Please install it to use this feature."
                        continue
                    fi
                    
                    # Securely overwrite free space
                    echo "Overwriting free space on $root_partition..."
                    srm -v -z -r --free "$root_partition"
                    
                    echo "Free space securely overwritten."
                    ;;
                3)
                    echo "Checking for rootkits with chkrootkit..."
                    chkrootkit 
                    ;;
                4)
                    echo -n "Enter file: "
                    read -r file

                    if [[ -z "$file" ]]; then
                    echo "No file entered."
                    elif [[ ! -f "$file" ]]; then
                    echo "File does not exist."
                    else
                    echo "Running shred for: $file"
                    shred -u -v -n 5 "$file"
                    fi
                    ;; 
                5)
                    openssl rand -base64 12
                    ;;    
                6)
                    echo "Removing temporary files..."
                    rm -rf /tmp/*
                    echo "Temporary files removed."
                    ;;    
                7)
                    return
                    ;;
                *)
                    echo "Invalid option"
                    ;;
            esac
        done
    done
}

