setup_clamav() {
    echo
    echo -e "${GREEN}[➜] Installing ClamAV...${RESET}"
    sleep 0.5

    sudo apt update
    sudo apt install -y clamav clamav-daemon

    echo
    echo -e "${GREEN}[➜] Stopping services before update...${RESET}"
    sudo systemctl stop clamav-freshclam

    echo
    echo -e "${GREEN}[➜] Updating virus database...${RESET}"
    sudo freshclam

    echo
    echo -e "${GREEN}[➜] Enabling automatic updates...${RESET}"
    sudo systemctl enable clamav-freshclam
    sudo systemctl start clamav-freshclam

    echo
    echo -e "${GREEN}[➜] Enabling ClamAV daemon (real-time scanning)...${RESET}"
    sudo systemctl enable clamav-daemon
    sudo systemctl start clamav-daemon

    echo
    echo -e "${GREEN}[➜] Fixing permissions...${RESET}"
    sudo chown -R clamav:clamav /var/lib/clamav

    echo
    echo -e "${GREEN}[➜] Testing installation...${RESET}"
    clamscan --version

    echo
    echo -e "${GREEN}[+] ClamAV setup completed successfully.${RESET}"
    echo -e "${YELLOW}[!] Quick scan example: clamscan -r ~/Downloads${RESET}"
}
setup_usbguard() {
    echo
    echo -e "${GREEN}[➜] Installing USBGuard...${RESET}"
    sleep 0.5

    sudo apt update
    sudo apt install -y usbguard

    echo
    echo -e "${GREEN}[➜] Generating initial policy (VERY IMPORTANT)...${RESET}"
    echo -e "${YELLOW}[!] Make sure all trusted USB devices are plugged in!${RESET}"
    sleep 3

    sudo usbguard generate-policy > /tmp/usbguard-rules.conf

    echo
    echo -e "${GREEN}[➜] Applying policy...${RESET}"
    sudo mv /tmp/usbguard-rules.conf /etc/usbguard/rules.conf
    sudo chown root:root /etc/usbguard/rules.conf
    sudo chmod 600 /etc/usbguard/rules.conf

    echo
    echo -e "${GREEN}[➜] Enabling USBGuard service...${RESET}"
    sudo systemctl enable usbguard
    sudo systemctl start usbguard

    echo
    echo -e "${GREEN}[+] USBGuard is now active.${RESET}"
    echo -e "${YELLOW}[!] New USB devices will be BLOCKED by default.${RESET}"
}
setup_ufw() {
    echo
    echo -e "${GREEN}[➜] Installing UFW...${RESET}"
    sleep 0.5

    sudo apt update
    sudo apt install -y ufw

    echo
    echo -e "${GREEN}[➜] Setting default policies...${RESET}"
    sudo ufw default deny incoming
    sudo ufw default allow outgoing

    echo
    echo -e "${GREEN}[➜] Allowing essential services...${RESET}"

    read -p "Allow SSH (port 22)? (y/n): " allow_ssh
    if [[ "$allow_ssh" == "y" ]]; then
        sudo ufw allow 22/tcp
        echo -e "${GREEN}[+] SSH allowed${RESET}"
    fi

    sudo ufw allow from 192.168.0.0/16
    sudo ufw allow from 10.0.0.0/8

    echo
    echo -e "${GREEN}[➜] Enabling firewall...${RESET}"
    sudo ufw enable

    echo
    echo -e "${GREEN}[➜] Current status:${RESET}"
    sudo ufw status verbose

    echo
    echo -e "${GREEN}[+] UFW setup completed.${RESET}"
    echo -e "${YELLOW}[!] Incoming connections are BLOCKED by default.${RESET}"
}
# Security
confirm_paranoia() {
    echo
    echo -e "\a"
    echo -e "${RED}[!] WARNING: Paranoia mode is extremely invasive and may break networking, audio, and system functionality.${RESET}"
    echo -e "\a"
    echo -e "${RED}[!] Use only in controlled environments (VM recommended).${RESET}"
    echo
    echo "Type EXACTLY: ENABLE PARANOIA MODE"
    read -r input

    if [[ "$input" != "ENABLE PARANOIA MODE" ]]; then
        echo -e "${RED}[!] Confirmation failed. Aborting.${RESET}"
        return 1
    fi

    return 0
    echo
}

paranoia_mode() {
    clear
    echo
    local status=0

    echo -e "${GREEN}[➜] Enabling Paranoia mode...${RESET}"
    sleep 0.5

    if sudo iptables -P OUTPUT DROP; then
        sudo iptables -A OUTPUT -d 127.0.0.1 -j ACCEPT
    else
        echo -e "\a"
        echo -e "${RED}[!] iptables failed${RESET}"
        status=1
    fi

    if ! nmcli networking off; then
        echo -e "${RED}[!] NetworkManager disable failed${RESET}"
        status=1
    fi

    shred -u ~/.bash_history 2>/dev/null || true
    history -c 2>/dev/null || true

    find /tmp -type f -user "$USER" -exec shred -u {} \; 2>/dev/null

    sudo modprobe -r uvcvideo 2>/dev/null || true
    sudo modprobe -r snd_hda_intel 2>/dev/null || true

    if [[ $status -eq 0 ]]; then
        echo -e "${GREEN}[+] Paranoia mode enabled successfully.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Paranoia mode partially failed (check output above).${RESET}"
    fi

    return $status
    echo
}

secure_empty_trash() {
    clear
    echo
    TRASH_FILES="$HOME/.local/share/Trash/files"
    TRASH_INFO="$HOME/.local/share/Trash/info"

    if [[ -z "$(ls -A "$TRASH_FILES" 2>/dev/null)" && -z "$(ls -A "$TRASH_INFO" 2>/dev/null)" ]]; then
        echo "Trash is empty."
        return 1
    fi

    read -rp "Confirm deletion (y/n): " confirm
    if [[ "$confirm" != "y" ]]; then
        echo -e "${RED}[!] Deletion aborted.${RESET}"
        return 1
    fi

    echo -e "${GREEN}[➜] Securely deleting trash...${RESET}"
    sleep 0.5
    echo "Deleting files..."
    srm -v -r "${TRASH_FILES}/"* 2>/dev/null

    echo -e "${GREEN}[➜] Securely deleting trash info...${RESET}"
    sleep 0.5
    srm -v -r "${TRASH_INFO}/"* 2>/dev/null

    echo -e "${GREEN}[+] Deletion completed.${RESET}"
    echo
}

secure_overwrite_free_space() {
    clear
    echo
    echo -e "${GREEN}[➜] Securely overwriting free space...${RESET}"
    root_partition=$(df / | tail -1 | awk '{print $1}')

    if ! command -v srm &> /dev/null; then
        echo -e "\a"
        echo -e "${RED}[!] srm command not found. Please install it to use this feature.${RESET}"
        return 1
    fi

    echo
    echo -e "${GREEN}[+] Overwriting free space on $root_partition...${RESET}"
    srm -v -z -r --free "$root_partition"

    echo -e "${GREEN}[+] Free space securely overwritten.${RESET}"
    echo
}

