i=0

run_with_tor() {
    if [[ "$USE_TOR" == "y" ]]; then
        torsocks "$@"
    else
        "$@"
    fi
}
whois_lookup() {
    echo "---------------------------------------------------------------"
    echo -n "Enter domain (ex: example.com): "
    read -r domain

    if [[ -z "$domain" ]]; then
        echo -e "${YELLOW}[!] Error: Domain cannot be empty.${RESET}"
        return 1
    fi

    echo -e "${PURPLE}"
    read -p "Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    echo -e "${GREEN}[➜] Performing Whois lookup for $domain...${RESET}"
    sleep 0.5

    output=$(run_with_tor whois "$domain" 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Whois lookup failed (network/command error).${RESET}"
        return 1
    fi

    if echo "$output" | grep -qiE "no match|not found|no data found|status: free"; then
        echo -e "\a"
        echo -e "${RED}[!] Domain not found or no WHOIS data available.${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Whois lookup completed successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
ping() {
    echo "---------------------------------------------------------------"
    echo -n "Enter item to ping: "
    read -r itemping

    if [[ -z "$itemping" ]]; then
        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
        return 1
    fi

    output=$(command ping -c 6 "$itemping" 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Ping failed (host unreachable or network issue).${RESET}"
        return 1
    fi

    if echo "$output" | grep -q "100% packet loss"; then
        echo -e "\a"
        echo -e "${RED}[!] Ping failed (100% packet loss).${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Ping completed successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
traceroute() {
    echo "---------------------------------------------------------------"
    echo -n "Enter domain to trace: "
    read -r domaintrace

    if [[ -z "$domaintrace" ]]; then
        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
        return 1
    fi

    echo -e "${YELLOW}[!] Traceroute is unreliable over Tor. Running normally.${RESET}"
    sleep 0.5

    output=$(command traceroute "$domaintrace" 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Traceroute failed (network/DNS issue).${RESET}"
        return 1
    fi

    if echo "$output" | grep -qE "^\s*[0-9]+\s+\*\s+\*\s+\*"; then
        echo -e "\a"
        echo -e "${RED}[!] Traceroute failed or blocked (no responses).${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Traceroute completed successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
dns_info() {
    echo "---------------------------------------------------------------"
    echo -n "Enter domain to get DNS info: "
    read -r domaindns

    if [[ -z "$domaindns" ]]; then
        echo -e "${YELLOW}[!] Error: Domain cannot be empty.${RESET}"
        return 1
    fi

    echo -e "${PURPLE}"
    read -p "Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    echo -e "${GREEN}[➜] Getting DNS info for $domaindns...${RESET}"
    sleep 0.5

    output=$(run_with_tor dig "$domaindns" 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] DNS lookup failed (network/DNS issue).${RESET}"
        return 1
    fi

    if echo "$output" | grep -q "status: NXDOMAIN"; then
        echo -e "${YELLOW}[!] Domain does not exist (NXDOMAIN).${RESET}"
        return 1
    fi

    if ! echo "$output" | grep -q "ANSWER SECTION"; then
        echo -e "${YELLOW}[!] No DNS records found.${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] DNS info retrieved successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
get_ip() {
    echo -e "${PURPLE}----------------------------------------------------------------"
    read -p "Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    echo -e "${GREEN}[➜] Fetching public IP...${RESET}"
    sleep 0.5

    output=$(run_with_tor curl -s --max-time 5 ifconfig.me 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Failed to fetch public IP (network issue).${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Public IP fetched successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
ip_osint() {
    echo "---------------------------------------------------------------"
    echo "IPinfo https://ipinfo.io/"
    read -p "Enter IP or domain: " target

    if [[ -z "$target" ]]; then
        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
        return 1
    fi

    echo -e "${PURPLE}"
    read -p "Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    echo -e "${GREEN}[➜] Fetching OSINT for $target...${RESET}"
    sleep 0.5

    data=$(run_with_tor curl -s --max-time 5 "https://ipinfo.io/$target" 2>&1)
    status=$?

    if [[ $status -ne 0 || -z "$data" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Failed to fetch OSINT data.${RESET}"
        return 1
    fi

    if ! echo "$data" | jq . >/dev/null 2>&1; then
        echo -e "\a"
        echo -e "${RED}[!] Invalid response (not JSON or API error).${RESET}"
        return 1
    fi

    if echo "$data" | jq -e '.bogon' >/dev/null 2>&1; then
        echo -e "${YELLOW}[!] Invalid or private IP address.${RESET}"
        return 1
    fi

    echo "IP:       $(echo "$data" | jq -r '.ip // "N/A"')"
    echo "City:     $(echo "$data" | jq -r '.city // "N/A"')"
    echo "Region:   $(echo "$data" | jq -r '.region // "N/A"')"
    echo "Country:  $(echo "$data" | jq -r '.country // "N/A"')"
    echo "ISP:      $(echo "$data" | jq -r '.org // "N/A"')"
    echo "Timezone: $(echo "$data" | jq -r '.timezone // "N/A"')"

    echo -e "${GREEN}[+] IP OSINT lookup completed successfully.${RESET}"
    return 0
    echo "---------------------------------------------------------------"
}
maigret_search() {
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Maigret Username OSINT${RESET}"
    echo

    if ! command -v maigret &>/dev/null; then
        echo -e "\a"
        echo -e "${RED}[!] Maigret not installed.${RESET}"
        echo -e "${YELLOW}[➜] Install with: pipx install maigret${RESET}"
        return
    fi

    read -p "Enter username to search: " username

    echo -e "${PURPLE}"
    read -p "Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    output_file="maigret_${username}_$(date +%s).json"

    echo -e "${GREEN}[➜] Searching for username: ${username}${RESET}"
    echo -e "${YELLOW}[!] Note: Requests go to external sites.${RESET}"
    echo

    run_with_tor maigret "$username" --json "$output_file" --top-sites 50 --timeout 5

    echo
    echo -e "${GREEN}[+] Scan completed.${RESET}"
    echo -e "${GREEN}[➜] Results saved to: ${output_file}${RESET}"
    echo "---------------------------------------------------------------"
}
tor_connect() {
    clear
    echo -e "${PURPLE}----------------------------------------------------------------${RESET}"
    cat << "EOF"
                                            =                       
                                      == ==                     
..........................         ======                       
..........................        ======                        
..........................       =====                          
..........................    @@@===                            
..........................     @.:%@@                           
 .     ............            @=.-=@                   ........
        ...........           @@....%@               ...........
        ...........         @@:...:=..+@@           ............
        ...........      @@-....-.=.::...#@        .............
        ...........    @@....:+....=.+.....%@     ..............
        ...........   @#...*........+.+.....=@    ...........   
        ...........   @...-....:..=..:@......@@   .........     
        ...........  %%..-...*.....-.=@.......@   .........     
        ...........  @#.:..::....::.:=@.......@   .........     
        ...........   @..-.*...::.*.%+@......@@   .........     
        ...........   @%..:%...+..-.#+@.....=@    .........     
        ...........    @@..-%..+..=.=#.....%@     .........     
        ...........      @@-++-.+.%#@=..:@@       .........     
        ..........          @@@@@@@@#@@@          .........     

EOF
    echo -e "${RESET}"
    echo -e "${PURPLE}[➜] Initializing Tor connection...${RESET}"
    
    if ! command -v tor &>/dev/null; then
        echo -e "\a"
        echo -e "${RED}[!] Tor is not installed.${RESET}"
        echo -e "${YELLOW}[➜] Install with: sudo apt install tor torsocks${RESET}"
        return
    fi

    echo -e "${PURPLE}[➜] Starting Tor service...${RESET}"
    sudo systemctl start tor

    if systemctl is-active --quiet tor; then
        echo -e "${PURPLE}[+] Tor is running.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Failed to start Tor.${RESET}"
        return
    fi

    echo
    echo -e "${PURPLE}[➜] Checking Tor IP...${RESET}"
    torsocks curl -s https://check.torproject.org/api/ip | grep -o '"IP":"[^"]*' | cut -d'"' -f4
    echo
    echo -e "${PURPLE}[+] Traffic is now routed through Tor (torsocks).${RESET}"

    echo
    read -p "Install tor browser? (y/n): " install_tor_browser
    if [[ "$install_tor_browser" == "y" ]]; then
        echo -e "${PURPLE}[➜] Installing Tor Browser...${RESET}"
        sudo apt install torbrowser-launcher
        echo -e "${PURPLE}[+] Tor Browser installed successfully.${RESET}"
    fi
    echo "---------------------------------------------------------------"
}
update_apps() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Starting update process...${RESET}"
    sleep 0.5

    overall_status=0

    echo "Updating all APT packages..."
    echo

    if sudo apt update && sudo apt upgrade -y; then
        echo
        echo -e "${GREEN}[+] APT packages updated${RESET}"
    else
        echo
        echo -e "\a"
        echo -e "${RED}[!] APT update failed${RESET}"
        overall_status=1
    fi
    echo
    echo "Updating all flatpak packages..."
    echo

    if command -v flatpak >/dev/null 2>&1; then
        if flatpak update -y; then
            echo
            echo -e "${GREEN}[+] Flatpak updated${RESET}"
        else
            echo
            echo -e "\a"
            echo -e "${RED}[!] Flatpak update failed${RESET}"
            overall_status=1
        fi
    else
        echo -e "${YELLOW}[!] Flatpak not installed, skipping.${RESET}"
    fi
    echo
    echo "Updating all snap packages..."
    echo

    if command -v snap >/dev/null 2>&1; then
        if sudo snap refresh; then
            echo
            echo -e "${GREEN}[+] Snap packages updated${RESET}"
        else
            echo
            echo -e "\a"
            echo -e "${RED}[!] Snap update failed${RESET}"
            overall_status=1
        fi
    else
        echo -e "${YELLOW}[!] Snap not installed, skipping.${RESET}"
    fi
    echo
    if [[ $overall_status -eq 0 ]]; then
        echo -e "${GREEN}[+] All updates completed successfully.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Some updates failed. Check output above.${RESET}"
    fi
    echo "---------------------------------------------------------------"
}
systeminfo() {
    clear
    echo "---------------------------------------------------------------"
    echo "Fastfetch https://github.com/fastfetch-cli/fastfetch"
    echo -e "${GREEN}[➜] Gathering system information...${RESET}"
    sleep 0.5

    if command -v fastfetch >/dev/null 2>&1; then
