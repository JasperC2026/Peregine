# -------------------
# Help Menu
# -------------------
show_help() {
clear
cat << "EOF"
JAS Toolbox - Command Line Interface
===================================

Usage:
  jas <command> [options]

Description:
  Multi-purpose toolbox for networking, system management,
  privacy, and security operations.

Commands:

  NETWORK:
    whois_lookup / whois     Perform WHOIS lookup on a domain
    ping                     Send ICMP requests to a host
    traceroute / trace       Trace route to a target
    dns_info / dns           Retrieve DNS records
    get_ip / ip              Show public IP address
    ip_osint / osint         Gather IP intelligence data
    inspect_cert             Inspect SSL/TLS certificate of a domain
    tor_connect              Connect to a server through Tor
    maigret_search               Search for username across data breaches

  SYSTEM:
    update_apps              Update system packages (APT/Flatpak/Snap)
    systeminfo / sys-info    Display system information
    paranoia_mode            Extreme lockdown mode (WARNING)
    useful_tools             Install useful tools
    setup_clamav             Install and set up ClamAV antivirus
    setup_usbguard           Install and set up USBGuard
    setup_ufw                Install and set up UFW firewall

  PRIVACY & SECURITY:
    secure_empty_trash / set     Securely empty trash
    secure_overwrite_free_space / SOFC
                                 Overwrite free disk space
    system_audit / audit         Run system audit (Lynis)
    bleachbit                    Clean system junk
    rootkit_hunt / audit         Scan for rootkits
    remove_temp_files / rm-temp  Clear /tmp directory
    generate_password / psswd    Generate secure password
    delete_file / del            Securely delete a file
    clean_metadata               Remove metadata from files

  MISC:
    matrix / -m              Matrix-style terminal effect
    hacked                   Hollywood-style terminal effect
    hacking                  Fake hacking simulation

  ENCRYPTING:
    encrypt_file_aes256      Encrypt a file with AES-256
    decrypt_file_aes256      Decrypt a file with AES-256
    encrypt_text_aes256      Encrypt text with AES-256
    decrypt_text_aes256      Decrypt text with AES-256
    encrypt_file_aes128      Encrypt a file with AES-128
    decrypt_file_aes128      Decrypt a file with AES-128
    encrypt_text_aes128      Encrypt text with AES-128
    decrypt_text_aes128      Decrypt text with AES-128
    encrypt_text_vigenere    Encrypt text with Vigenere cipher
    decrypt_text_vigenere    Decrypt text with Vigenere cipher
    encrypt_text_ceasar      Encrypt text with Caesar cipher
    decrypt_text_ceasar      Decrypt text with Caesar cipher
    encrypt_text_base64      Encode text with Base64
    decrypt_text_base64      Decode text with Base64
    rot13_cipher             Encrypt/Decrypt text with ROT13

  OPEN SUB-MENUS:
    network_tools            Open network tools menu
    system_tools             Open system tools menu
    privacy_tools            Open privacy/security tools menu
    encryptions_tools        Open encrypting tools menu
    misc_tools               Open miscellaneous tools menu

  OTHER:
    license / -l             Show license information
    clone_source / -c        Clone project repository
    help / -h / --help       Show this help message

Notes:
  - Some commands require sudo privileges.
  - External tools may be required (whois, dig, lynis, etc.).
  - Destructive actions (e.g., overwrite, shred) are irreversible.
  - paranoia_mode can disrupt networking and system behavior.

EOF
}

# -------------------
# Command Dispatcher
# -------------------
if [[ -n "$1" ]]; then
    case "$1" in
        # NETWORK
        whois_lookup|whois) whois_lookup ;;
        ping) ping ;;
        traceroute|trace) traceroute ;;
        dns_info|dns) dns_info ;;
        get_ip|ip) get_ip ;;
        ip_osint|osint) ip_osint ;;
        inspect_cert) inspect_cert ;;
        tor_connect) tor_connect ;;
        maigret_search) maigret_search ;;
        # SYSTEM
        update_apps) update_apps ;;
        systeminfo|sys-info) systeminfo ;;
        paranoia_mode)
            if confirm_paranoia; then
                paranoia_mode
            else
                exit 1
            fi
            ;;
        useful_tools) useful_tools ;;
        setup_clamav) setup_clamav ;;
        setup_usbguard) setup_usbguard ;;
        setup_ufw) setup_ufw ;;
        # PRIVACY & SECURITY
        secure_empty_trash|SET) secure_empty_trash ;;
        secure_overwrite_free_space|SOFC) secure_overwrite_free_space ;;
        system_audit|audit) system_audit ;;
        bleachbit) bleachbit ;;
        rootkit_hunt|rootkit) rootkit_hunt ;;
        remove_temp_files|rm-temp) remove_temp_files ;;
        generate_password|psswd) generate_password ;;
        delete_file|del) delete_file ;;
        clean_metadata) clean_metadata ;;
        # ENCRYPTING
        encrypt_file_aes256) encrypt_file_aes256 ;;
        decrypt_file_aes256) decrypt_file_aes256 ;;
        encrypt_text_aes256) encrypt_text_aes256 ;;
        decrypt_text_aes256) decrypt_text_aes256 ;;
        encrypt_file_aes128) encrypt_file_aes128 ;;
        decrypt_file_aes128) decrypt_file_aes128 ;;
        encrypt_text_aes128) encrypt_text_aes128 ;;
        decrypt_text_aes128) decrypt_text_aes128 ;;
        encrypt_text_vigenere) encrypt_text_vigenere ;;
        decrypt_text_vigenere) decrypt_text_vigenere ;;
        encrypt_text_ceasar) encrypt_text_ceasar ;;
        decrypt_text_ceasar) decrypt_text_ceasar ;;
        encrypt_text_base64) encrypt_text_base64 ;;
        decrypt_text_base64) decrypt_text_base64 ;;
        rot13_cipher) rot13_cipher ;;
        # MISC
        matrix|-m) matrix ;;
        hacked) hacked ;;
        hacking) hacking ;;
        # OTHER
        license|-l) license ;;
        clone_source|clone) clone_source ;;
        help|-h|--help) show_help ;;
        version|-v) version ;;
        # MENUS
        misc_tools) misc_tools ;;
        system_tools) system_tools ;;
        privacy_tools) privacy_tools ;;
        network_tools) network_tools ;;
        encryptions_tools) encryptions_tools ;;
        *)
            echo -e "\a"
            echo -e "${RED}[!] Unknown command: $1${RESET}"
            echo "Use 'jas help' to see available commands."
            exit 1
            ;;
    esac
    exit 0
fi

