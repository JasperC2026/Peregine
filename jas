echo -e "${YELLOW}[!] Note: Some of these tools can be dangerous if used improperly. Make sure you understand what each tool does before using it. Always use these tools responsibly and ethically.${RESET}"
privacy_tools() {
    while true; do
        PS3="Privacy/Security Menu: "
        options=("Securely wipe trash" "Securely overwrite free space" "Peform system audit" "Peform system cleanup" "Check for rootkits" "Remove temporary files" "Generate secure password" "Delete file"  "Exit")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    # Securely wipe trash
                    echo

                    # Check if trash is empty
                    TRASH_FILES="$HOME/.local/share/Trash/files"
                    if [[ -z "$(ls -A "$TRASH_FILES" 2>/dev/null)" && -z "$(ls -A "$TRASH_INFO" 2>/dev/null)" ]]; then
                        echo "Trash is empty."
                        continue
                    fi

                    # Confirm deletion
                    read -rp "Confirm deletion (y/n): " confirm
                    if [[ "$confirm" != "y" ]]; then
                        echo -e "${RED}[!] Deletion aborted.${RESET}"
                        continue
                    fi

                    # Securely delete files
                    TRASH_INFO="$HOME/.local/share/Trash/info"
                    echo -e "${GREEN}[➜] Securely deleting trash...${RESET}"
                    sleep 0.5
                    echo "Deleting files..."
                    srm -v -r "${TRASH_FILES}/"*

                    echo -e "${GREEN}[➜] Securely deleting trash info...${RESET}"
                    sleep 0.5
                    srm -v -r "${TRASH_INFO}/"*


                    # Completed status
                    echo -e "${GREEN}[+] Deletion completed.${RESET}"
                    ;;
                2)
                    # Securely overwrite free space
                    echo
                    echo -e "${GREEN}[➜] Securely overwriting free space...${RESET}"
                    # Get the root partition
                    root_partition=$(df / | tail -1 | awk '{print $1}')
                    
                    # Check if srm is installed
                    if ! command -v srm &> /dev/null; then
                        echo -e "${RED}[!] srm command not found. Please install it to use this feature.${RESET}"
                        continue
                    fi
                    
                    # Securely overwrite free space
                    echo
                    echo -e "${GREEN}[+] Overwriting free space on $root_partition...${RESET}"
                    srm -v -z -r --free "$root_partition"
                    
                    echo -e "${GREEN}[+] Free space securely overwritten.${RESET}"
                    ;;
                3)  
                    # Perform system audit with Lynis
                    echo
                    echo "Lynis by CISOfy https://cisofy.com/lynis/"
                    sleep 0.5

                    echo
                    echo -e "${GREEN}[➜] Performing system audit with Lynis...${RESET}"
                    sleep 0.5
                    echo

                    if command -v lynis >/dev/null 2>&1; then
                        output=$(sudo lynis audit system 2>&1)
                        status=$?

                        echo "$output"

                        if [[ $status -eq 0 ]]; then
                            echo
                            echo -e "${GREEN}[+] System audit completed successfully.${RESET}"
                        else
                            echo
                            echo -e "${RED}[!] Lynis audit finished with errors (check output above).${RESET}"
                            return 1
                        fi
                    else
                        echo -e "${RED}[!] Lynis is not installed.${RESET}"
                        echo -e "${YELLOW}[i] Install with: sudo apt install lynis${RESET}"
                        return 1
                    fi
                    ;;
                4)
                    # Perform system cleanup with BleachBit
                    echo
                    echo "BleachBit by BleachBit Team https://www.bleachbit.org/"
                    echo -e "${GREEN}[➜] Running BleachBit...${RESET}"
                    sleep 0.5

                    if command -v bleachbit >/dev/null 2>&1; then
                        output=$(sudo bleachbit 2>&1)
                        status=$?

                        echo "$output"

                        if [[ $status -eq 0 ]]; then
                            echo -e "${GREEN}[+] BleachBit cleanup completed successfully.${RESET}"
                        else
                            echo -e "${RED}[!] BleachBit finished with errors.${RESET}"
                            return 1
                        fi
                    else
                        echo -e "${RED}[!] BleachBit is not installed.${RESET}"
                        echo -e "${YELLOW}[i] Install with: sudo apt install bleachbit${RESET}"
                        return 1
                    fi
                    ;;
                5)
                    # Check for rootkits with chkrootkit
                    echo
                    echo "chkrootkit by chkrootkit Team https://chkrootkit.org/"
                    echo -e "${GREEN}[➜] Checking for rootkits with chkrootkit...${RESET}"
                    sleep 0.5

                    if command -v chkrootkit >/dev/null 2>&1; then
                        output=$(sudo chkrootkit 2>&1)
                        status=$?

                        echo "$output"

                        # chkrootkit usually returns 0 even if issues are found,
                        # so we also scan output for warnings
                        if echo "$output" | grep -qiE "INFECTED|WARNING|suspicious"; then
                            echo -e "${RED}[!] Potential threats detected! Review output above.${RESET}"
                            return 1
                        fi

                        if [[ $status -eq 0 ]]; then
                            echo -e "${GREEN}[+] Rootkit check completed (no obvious threats).${RESET}"
                        else
                            echo -e "${RED}[!] chkrootkit finished with errors.${RESET}"
                            return 1
                        fi
                    else
                        echo -e "${RED}[!] chkrootkit is not installed.${RESET}"
                        echo -e "${YELLOW}[i] Install with: sudo apt install chkrootkit${RESET}"
                        return 1
                    fi
                    ;;
                6)
                    # Remove temporary files
                    echo
                    echo -e "${GREEN}[➜] Removing temporary files...${RESET}"
                    sleep 0.5

                    # safer: only remove user-owned temp files
                    if rm -rf /tmp/* 2>/dev/null; then
                        echo -e "${GREEN}[+] Temporary files removed.${RESET}"
                    else
                        echo -e "${RED}[!] Failed to remove some temporary files (permissions or in-use files).${RESET}"
                        return 1
                    fi
                    ;;
                7)  
                    # Generate secure password
                    echo
                    echo -e "${GREEN}[➜] Generating secure password...${RESET}"
                    sleep 0.5
                    echo

                    if command -v openssl >/dev/null 2>&1; then
                        password=$(openssl rand -base64 12 2>/dev/null)
                        status=$?

                        if [[ $status -eq 0 && -n "$password" ]]; then
                            echo -e "${CYAN}$password${RESET}"
                            echo -e "${GREEN}[+] Password generation completed.${RESET}"
                        else
                            echo -e "${RED}[!] Failed to generate password.${RESET}"
                            return 1
                        fi
                    else
                        echo -e "${RED}[!] OpenSSL is not installed.${RESET}"
                        echo -e "${YELLOW}[i] Install with: sudo apt install openssl${RESET}"
                        return 1
                    fi
                    ;;

                8)    
                    # Delete file with shred
                    echo
                    echo -n "Enter file: "
                    read -r file

                    if [[ -z "$file" ]]; then
                    echo -e "${RED}[!] No file entered.${RESET}"
                    elif [[ ! -f "$file" ]]; then
                    echo -e "${RED}[!] File does not exist.${RESET}"
                    else
                    echo -e "${GREEN}[+] Running shred for: $file${RESET}"
                    shred -u -v -n 5 "$file" 
                    echo -e "${GREEN}[+] File securely deleted.${RESET}"
                    fi
                    ;; 
                
                9)
                    # Exit
                    exit 0
                    ;;
                q)
                    # Exit
                    exit 0
                    ;;
                *)
                    # Handle invalid input
                    echo -e "${RED}[✖] Invalid option.${RESET}" 
                    ;;
            esac
        done
    done
}
