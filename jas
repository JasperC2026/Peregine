if [[ -n "$1" ]]; then
    case "$1" in

        # NETWORK
        whois_lookup|whois) whois_lookup ;;
        ping) ping ;;
        traceroute|trace) traceroute ;;
        dns_info|dns) dns_info ;;
        get_ip|ip) get_ip ;;
        ip_osint|osint) ip_osint ;;
        inspect_cert) inspect_cert ;;
        tor_connect) tor_connect ;;
        maigret_search) maigret_search ;;

        # SYSTEM
        update_apps) update_apps ;;
        systeminfo|sys-info) systeminfo ;;
        paranoia_mode)
            if confirm_paranoia; then
                paranoia_mode
            else
                exit 1
            fi
            ;;
        useful_tools) useful_tools ;;
        setup_clamav) setup_clamav ;;
        setup_usbguard) setup_usbguard ;;
        setup_ufw) setup_ufw ;;

        # PRIVACY & SECURITY
        secure_empty_trash|SET) secure_empty_trash ;;
        secure_overwrite_free_space|SOFC) secure_overwrite_free_space ;;
        system_audit|audit) system_audit ;;
        bleachbit) bleachbit ;;
        rootkit_hunt|rootkit) rootkit_hunt ;;
        remove_temp_files|rm-temp) remove_temp_files ;;
        generate_password|psswd) generate_password ;;
        delete_file|del) delete_file ;;
        clean_metadata) clean_metadata ;;

        # ENCRYPTING
        generate_aes256_key) generate_aes256_key ;;
        generate_aes128_key) generate_aes128_key ;;
        encrypt_file_aes256) encrypt_file_aes256 ;;
        decrypt_file_aes256) decrypt_file_aes256 ;;
        encrypt_text_aes256) encrypt_text_aes256 ;;
        decrypt_text_aes256) decrypt_text_aes256 ;;
        encrypt_file_aes128) encrypt_file_aes128 ;;
        decrypt_file_aes128) decrypt_file_aes128 ;;
        encrypt_text_aes128) encrypt_text_aes128 ;;
        decrypt_text_aes128) decrypt_text_aes128 ;;
        encrypt_text_vigenere) encrypt_text_vigenere ;;
        decrypt_text_vigenere) decrypt_text_vigenere ;;
        encrypt_text_ceasar) encrypt_text_ceasar ;;
        decrypt_text_ceasar) decrypt_text_ceasar ;;
        encrypt_text_base64) encrypt_text_base64 ;;
        decrypt_text_base64) decrypt_text_base64 ;;
        rot13_cipher) rot13_cipher ;;

        # MISC
        matrix|-m) matrix ;;
        hacked) hacked ;;
        hacking) hacking ;;
        read_nerd_news) read_nerd_news ;;
        # OTHER
        license|-l) license ;;
        clone_source|clone) clone_source ;;
        help|-h|--help) show_help ;;
        version|-v) version ;;
        # MENUS
        misc_tools) misc_tools ;;
        system_tools) system_tools ;;
        privacy_tools) privacy_tools ;;
        network_tools) network_tools ;;
        encryptions_tools) encryptions_tools ;;

        # INFO SYSTEM
        info)
            if [[ -z "$2" ]]; then
                echo "Usage: jas info <command>"
            else
                show_command_info "$2"
            fi
            ;;

        *)
            echo -e "\a"
            echo -e "${RED}[!] Unknown command: $1${RESET}"
            echo "Use 'jas help' to see available commands."
            exit 1
            ;;
    esac

    exit 0
fi

