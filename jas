# -------------------
# Help Menu
# -------------------
show_help() {
cat << "EOF"
JAS Toolbox - Command Line Interface
===================================

Usage:
  jas <command> [options]

Description:
  Multi-purpose toolbox for networking, system management,
  privacy, and security operations.

Commands:

  NETWORK:
    whois_lookup / whois     Perform WHOIS lookup on a domain
    ping                     Send ICMP requests to a host
    traceroute / trace       Trace route to a target
    dns_info / dns           Retrieve DNS records
    get_ip / ip              Show public IP address
    ip_osint / osint         Gather IP intelligence data

  SYSTEM:
    update_apps              Update system packages (APT/Flatpak/Snap)
    systeminfo / sys-info    Display system information
    paranoia_mode            Extreme lockdown mode (WARNING)

  PRIVACY & SECURITY:
    secure_empty_trash / set     Securely empty trash
    secure_overwrite_free_space / SOFC
                                 Overwrite free disk space
    system_audit / audit         Run system audit (Lynis)
    bleachbit                    Clean system junk
    rootkit_hunt / audit         Scan for rootkits
    remove_temp_files / rm-temp  Clear /tmp directory
    generate_password /psswd     Generate secure password
    delete_file / del           Securely delete a file

  MISC:
    matrix / -m              Matrix-style terminal effect
    hacked                   Hollywood-style terminal effect
    hacking                  Fake hacking simulation

  OTHER:
    license / -l             Show license information
    clone_source / -c   Clone project repository
    help / -h / --h      Show this help message

Notes:
  - Some commands require sudo privileges.
  - External tools may be required (whois, dig, lynis, etc.).
  - Destructive actions (e.g., overwrite, shred) are irreversible.
  - paranoia_mode can disrupt networking and system behavior.

EOF
}

# -------------------
# Command Dispatcher
# -------------------
if [[ -n "$1" ]]; then
    case "$1" in
        whois_lookup|whois) whois_lookup ;;
        ping) ping ;;
        traceroute|trace) traceroute ;;
        dns_info|dns) dns_info ;;
        get_ip|ip) get_ip ;;
        ip_osint|osint) ip_osint ;;
        update_apps) update_apps ;;
        systeminfo|sys-info) systeminfo ;;
        paranoia_mode)
            if confirm_paranoia; then
                paranoia_mode
            else
                exit 1
            fi
            ;;
        secure_empty_trash|SET) secure_empty_trash ;;
        secure_overwrite_free_space|SOFC) secure_overwrite_free_space ;;
        system_audit|audit) system_audit ;;
        bleachbit) bleachbit ;;
        rootkit_hunt|rootkit) rootkit_hunt ;;
        remove_temp_files|rm-temp) remove_temp_files ;;
        generate_password|psswd) generate_password ;;
        delete_file|del) delete_file ;;
        matrix|-m) matrix ;;
        hacked) hacked ;;
        hacking) hacking ;;
        license|-l) license ;;
        clone_source|clone) clone_source ;;
        help|-h|--help) show_help ;;
        version|-v) version ;;
        *)
            echo -e "${RED}[!] Unknown command: $1${RESET}"
            echo "Use 'jas help' to see available commands."
            exit 1
            ;;
    esac
    exit 0
fi


