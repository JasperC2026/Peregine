read_nerd_news () {
    echo "-------------------------------------------------------------------"
    WIRED_RSS="https://www.wired.com/feed/rss"
    ARS_RSS="https://feeds.arstechnica.com/arstechnica/index"

    echo ""
    echo "########################################"
    echo "#        RSS FEED READER               #"
    echo "########################################"
    echo " Fetching latest headlines..."

    fetch_feed "WIRED" "$WIRED_RSS" 5
    fetch_feed "ARS TECHNICA" "$ARS_RSS" 5

    echo "========================================"
    echo " Done."
    echo "========================================"
}
fetch_feed() {
    local source="$1"
    local url="$2"
    local limit="${3:-5}"

    echo ""
    echo "========================================"
    echo " $source"
    echo "========================================"

    curl -s "$url" | xmllint --xpath "//item" - 2>/dev/null | \
    grep -oP '(?<=<title>).*?(?=</title>)|(?<=<link>).*?(?=</link>)|(?<=<pubDate>).*?(?=</pubDate>)' | \
    awk -v limit="$limit" '
        NR % 3 == 1 { title=$0 }
        NR % 3 == 2 { link=$0 }
        NR % 3 == 0 {
            count++
            if (count <= limit) {
                print count". " title
                print "   " $0
                print "   " link
                print ""
            }
        }
    '
}
