update_apps() {
    clear
    echo
    echo -e "${GREEN}[➜] Starting update process...${RESET}"
    sleep 0.5

    overall_status=0

    echo "Updating all APT packages..."
    echo

    if sudo apt update && sudo apt upgrade -y; then
        echo
        echo -e "${GREEN}[+] APT packages updated${RESET}"
    else
        echo
        echo -e "\a"
        echo -e "${RED}[!] APT update failed${RESET}"
        overall_status=1
    fi
    echo
    echo "Updating all flatpak packages..."
    echo

    if command -v flatpak >/dev/null 2>&1; then
        if flatpak update -y; then
            echo
            echo -e "${GREEN}[+] Flatpak updated${RESET}"
        else
            echo
            echo -e "\a"
            echo -e "${RED}[!] Flatpak update failed${RESET}"
            overall_status=1
        fi
    else
        echo -e "${YELLOW}[!] Flatpak not installed, skipping.${RESET}"
    fi
    echo
    echo "Updating all snap packages..."
    echo

    if command -v snap >/dev/null 2>&1; then
        if sudo snap refresh; then
            echo
            echo -e "${GREEN}[+] Snap packages updated${RESET}"
        else
            echo
            echo -e "\a"
            echo -e "${RED}[!] Snap update failed${RESET}"
            overall_status=1
        fi
    else
        echo -e "${YELLOW}[!] Snap not installed, skipping.${RESET}"
    fi
    echo
    if [[ $overall_status -eq 0 ]]; then
        echo -e "${GREEN}[+] All updates completed successfully.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Some updates failed. Check output above.${RESET}"
    fi
    echo
}
