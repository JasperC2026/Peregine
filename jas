i=0
rainbow() {
  local colors=("\e[31m" "\e[33m" "\e[32m" "\e[36m" "\e[34m" "\e[35m")
  local i=0

  while IFS= read -r line; do
    printf "%b%s\e[0m\n" "${colors[$((i % 6))]}" "$line"
    ((i++))
  done
}
