tor_connect() {
    clear
    echo "----------------------------------------------------------------"
    echo -e "${PURPLE}[➜] Initializing Tor connection...${RESET}"
    
    if ! command -v tor &>/dev/null; then
        echo -e "\a"
        echo -e "${RED}[!] Tor is not installed.${RESET}"
        echo -e "${YELLOW}[➜] Install with: sudo apt install tor torsocks${RESET}"
        return
    fi

    echo -e "${PURPLE}[➜] Starting Tor service...${RESET}"
    sudo systemctl start tor

    if systemctl is-active --quiet tor; then
        echo -e "${PURPLE}[+] Tor is running.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Failed to start Tor.${RESET}"
        return
    fi

    echo
    echo -e "${PURPLE}[➜] Checking Tor IP...${RESET}"
    torsocks curl -s https://check.torproject.org/api/ip | grep -o '"IP":"[^"]*' | cut -d'"' -f4
    echo
    echo -e "${PURPLE}[+] Traffic is now routed through Tor (torsocks).${RESET}"

    echo
    read -p "Install tor browser? (y/n): " install_tor_browser
    if [[ "$install_tor_browser" == "y" ]]; then
        echo -e "${PURPLE}[➜] Installing Tor Browser...${RESET}"
        sudo apt install torbrowser-launcher
        echo -e "${PURPLE}[+] Tor Browser installed successfully.${RESET}"
    fi
    echo "---------------------------------------------------------------"
}
update_apps() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Starting update process...${RESET}"
    echo "---------------------------------------------------------------"

    local overall_status=0
    local start_time=$SECONDS

    _update_section() {
        local label="$1"; shift
        local section_start=$SECONDS
        echo
        echo -e "${CYAN}── $label ─────────────────────────────────────────────${RESET}"
        "$@"
        local status=$?
        local elapsed=$(( SECONDS - section_start ))
        if [[ $status -eq 0 ]]; then
            echo -e "${GREEN}[+] $label completed (${elapsed}s).${RESET}"
        else
            echo -e "\a"
            echo -e "${RED}[!] $label failed (${elapsed}s).${RESET}"
            overall_status=1
        fi
        return $status
    }

    # APT
    _update_section "APT" bash -c 'sudo apt update && sudo apt upgrade -y'

    # Flatpak
    if command -v flatpak >/dev/null 2>&1; then
        _update_section "Flatpak" flatpak update -y
    else
        echo -e "${YELLOW}[i] Flatpak not installed — skipping.${RESET}"
    fi

    # Snap
    if command -v snap >/dev/null 2>&1; then
        _update_section "Snap" sudo snap refresh
    else
        echo -e "${YELLOW}[i] Snap not installed — skipping.${RESET}"
    fi

    # pip (user packages)
    if command -v pip3 >/dev/null 2>&1; then
        _update_section "pip3 (user)" bash -c \
            'pip3 list --outdated --format=freeze 2>/dev/null \
             | cut -d= -f1 \
             | xargs -r pip3 install --upgrade --quiet'
    fi

    local total_elapsed=$(( SECONDS - start_time ))
    echo
    echo "---------------------------------------------------------------"
    if [[ $overall_status -eq 0 ]]; then
        echo -e "${GREEN}[+] All updates completed successfully (${total_elapsed}s total).${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Some updates failed — check output above (${total_elapsed}s total).${RESET}"
    fi
    echo "---------------------------------------------------------------"
}
