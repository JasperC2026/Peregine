#!/bin/bash

# Jas - A simple command line toolbox for networking, system managing and privacy/security. Version 1.0.

# -------------------
# Updater
# -------------------

update_jas() {
    echo "[+] Checking for updates..."

    TMP=$(mktemp)

    if curl -fsSL https://raw.githubusercontent.com/DarkShadowUser/Jas-toolbox/main/jas -o "$TMP"; then
        sudo install -m 755 "$TMP" /usr/local/bin/jas
        rm "$TMP"
        echo "[✓] Jas Toolbox updated!"
    else
        echo "[!] Update failed."
        rm -f "$TMP"
    fi
}

# -------------------
# Help function
# -------------------

if [[ "$1" == "help" ]]; then
    echo "Jas Toolbox commands:"
    echo "  jas        - launch toolbox menu"
    echo "  jas update - update Jas Toolbox"
    echo "  jas help   - show this help"
    exit
fi

# -------------------
# Run dependency check
# -------------------
check_dependencies

# -------------------
# Dependency check and installation
# -------------------

check_dependencies() {

    deps=(
        whois
        curl
        dig
        fastfetch
        srm
        chkrootkit
        openssl
        traceroute
    )

    missing=()

    for cmd in "${deps[@]}"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done

    if [ ${#missing[@]} -ne 0 ]; then
        echo "[!] Missing dependencies: ${missing[*]}"
        echo "[+] Installing them..."

        sudo apt update
        sudo apt install -y whois curl dnsutils fastfetch secure-delete chkrootkit traceroute openssl
    fi
}

# -------------------
# Variables for commands.
# -------------------

TRASH_FILES="$HOME/.local/share/Trash/files"
TRASH_INFO="$HOME/.local/share/Trash/info"
RESET="\e[0m"

# -------------------
# Colors for ASCII art
# -------------------

COLORS=(
"255;120;0"
"255;80;80"
"255;0;150"
"200;0;220"
"150;0;255"
"110;0;255"
)

i=0

while IFS= read -r line; do
    COLOR="\e[38;2;${COLORS[$(( i % ${#COLORS[@]} ))]}m"
    printf "%b%s%b\n" "$COLOR" "$line" "$RESET"
    ((i++))
done <<'EOF'
