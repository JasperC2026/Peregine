# -------------------
# Network Tools Submenu
# -------------------
echo
network_tools() {
    while true; do
        PS3="Network Tools Menu: "
        options=("Whois" "Ping" "Trace" "DNS info" "get IP" "IP osint" "Back")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    # Whois lookup
                    echo
                    echo -n "Enter domain (ex: example.com): "
                    read -r domain 

                    if [[ -z "$domain" ]]; then
                        echo -e "${YELLOW}[!] Error: Domain cannot be empty.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[➜] Performing Whois lookup for $domain...${RESET}"
                    sleep 0.5

                    # Run whois and capture output
                    output=$(whois "$domain" 2>&1)
                    status=$?

                    echo -e "${CYAN}$output${RESET}"

                    # Check result
                    if [[ $status -ne 0 ]]; then
                        echo -e "${RED}[!] Whois lookup failed (network/command error).${RESET}"
                        return 1
                    fi

                    # Detect "not found" cases (common patterns)
                    if echo "$output" | grep -qiE "no match|not found|no data found|status: free"; then
                        echo -e "${RED}[!] Domain not found or no WHOIS data available.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[+] Whois lookup completed successfully.${RESET}"
                    ;;
                2)
                    # Ping
                    echo
                    echo -n "Enter item to ping: "
                    read -r itemping 

                    if [[ -z "$itemping" ]]; then
                        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[➜] Pinging $itemping...${RESET}"
                    sleep 0.5

                    # Run ping and capture output
                    output=$(ping -c 6 "$itemping" 2>&1)
                    status=$?

                    echo -e "${CYAN}$output${RESET}"

                    # Check if ping command failed
                    if [[ $status -ne 0 ]]; then
                        echo -e "${RED}[!] Ping failed (host unreachable or network issue).${RESET}"
                        return 1
                    fi

                    # Detect packet loss (100% loss = fail)
                    if echo "$output" | grep -q "100% packet loss"; then
                        echo -e "${RED}[!] Ping failed (100% packet loss).${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[+] Ping completed successfully.${RESET}"
                    ;;
                3)
                    # Traceroute
                    echo
                    echo -n "Enter domain to trace: "
                    read -r domaintrace 

                    if [[ -z "$domaintrace" ]]; then
                        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[➜] Tracing route to $domaintrace...${RESET}"
                    sleep 0.5

                    # Run traceroute and capture output
                    output=$(traceroute "$domaintrace" 2>&1)
                    status=$?

                    echo -e "${CYAN}$output${RESET}"

                    # Check if traceroute command failed
                    if [[ $status -ne 0 ]]; then
                        echo -e "${RED}[!] Traceroute failed (network/DNS issue).${RESET}"
                        return 1
                    fi

                    # Detect unreachable route (common pattern: only * * *)
                    if echo "$output" | grep -qE "^\s*[0-9]+\s+\*\s+\*\s+\*"; then
                        echo -e "${RED}[!] Traceroute failed or blocked (no responses).${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[+] Traceroute completed successfully.${RESET}"
                    ;;
                4)
                    # DNS info
                    echo
                    echo -n "Enter domain to get DNS info: "
                    read -r domaindns 

                    if [[ -z "$domaindns" ]]; then
                        echo -e "${YELLOW}[!] Error: Domain cannot be empty.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[➜] Getting DNS info for $domaindns...${RESET}"
                    sleep 0.5

                    # Run dig and capture output
                    output=$(dig "$domaindns" 2>&1)
                    status=$?

                    echo -e "${CYAN}$output${RESET}"

                    # Check command failure
                    if [[ $status -ne 0 ]]; then
                        echo -e "${RED}[!] DNS lookup failed (network/DNS issue).${RESET}"
                        return 1
                    fi

                    # Detect no valid answer
                    if echo "$output" | grep -q "status: NXDOMAIN"; then
                        echo -e "${RED}[!] Domain does not exist (NXDOMAIN).${RESET}"
                        return 1
                    fi

                    # Detect empty answer section
                    if ! echo "$output" | grep -q "ANSWER SECTION"; then
                        echo -e "${RED}[!] No DNS records found.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[+] DNS info retrieved successfully.${RESET}"
                    ;;
                5)
                    # Get public IP
                    echo
                    echo -e "${GREEN}[➜] Fetching public IP...${RESET}"
                    sleep 0.5

                    # Fetch IP
                    output=$(curl -s --max-time 5 ifconfig.me 2>&1)
                    status=$?

                    echo -e "${CYAN}$output${RESET}"

                    # Check failure
                    if [[ $status -ne 0 ]]; then
                        echo -e "${RED}[!] Failed to fetch public IP (network issue).${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[+] Public IP fetched successfully.${RESET}"
                    ;;
                6)
                # IP OSINT
                echo
                ip_osint() {
                    read -p "Enter IP or domain: " target
                    
                    if [[ -z "$target" ]]; then
                        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
                        return 1
                    fi

                    echo -e "${GREEN}[➜] Fetching OSINT for $target...${RESET}"
                    sleep 0.5

                    # Fetch data
                    data=$(curl -s --max-time 5 "https://ipinfo.io/$target" 2>&1)
                    status=$?

                    # Check curl failure
                    if [[ $status -ne 0 || -z "$data" ]]; then
                        echo -e "${RED}[!] Failed to fetch OSINT data.${RESET}"
                        return 1
                    fi

                    # Validate JSON (jq check)
                    if ! echo "$data" | jq . >/dev/null 2>&1; then
                        echo -e "${RED}[!] Invalid response (not JSON or API error).${RESET}"
                        return 1
                    fi

                    # Check if API returned error
                    if echo "$data" | jq -e '.bogon' >/dev/null 2>&1; then
                        echo -e "${RED}[!] Invalid or private IP address.${RESET}"
                        return 1
                    fi

                    # Output data
                    echo "IP:       $(echo "$data" | jq -r '.ip // "N/A"')"
                    echo "City:     $(echo "$data" | jq -r '.city // "N/A"')"
                    echo "Region:   $(echo "$data" | jq -r '.region // "N/A"')"
                    echo "Country:  $(echo "$data" | jq -r '.country // "N/A"')"
                    echo "ISP:      $(echo "$data" | jq -r '.org // "N/A"')"
                    echo "Timezone: $(echo "$data" | jq -r '.timezone // "N/A"')"

                    return 0
                }

                ip_osint

                # Final status message
                if [[ $? -eq 0 ]]; then
                    echo -e "${GREEN}[+] IP OSINT lookup completed successfully.${RESET}"
                else
                    echo -e "${RED}[!] IP OSINT lookup failed.${RESET}"
                fi
                ;;
                7)
                    # Exit
                    exit 0
                    ;;
                q)
                    # Exit
                    exit 0
                    ;;
                *)
                    # Handle invalid input
                    echo -e "${RED} [✖] Invalid option${RESET}" 
                    ;;
            esac
        done
    done
}

# -------------------
# System Tools Submenu
# -------------------
echo
system_tools() {
    while true; do
        PS3="System Tools Menu: "
        options=("Updating all apps" "See system information" "Paranoia mode" "Exit")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    # Update all apps
                    echo
                    echo -e "${GREEN}[➜] Starting update process...${RESET}"
                    sleep 0.5

                    overall_status=0

                    update_APT () {
                        echo "Updating all APT packages..."
                        echo

                        if sudo apt update && sudo apt upgrade -y; then
                            echo
                            echo -e "${GREEN}[+] APT packages updated${RESET}"
                        else
                            echo
                            echo -e "${RED}[!] APT update failed${RESET}"
                            overall_status=1
                        fi
                        echo
                    }

                    update_flatpak () {
                        echo "Updating all flatpak packages..."
                        echo

                        if command -v flatpak >/dev/null 2>&1; then
                            if flatpak update -y; then
                                echo
                                echo -e "${GREEN}[+] Flatpak updated${RESET}"
                            else
                                echo
                                echo -e "${RED}[!] Flatpak update failed${RESET}"
                                overall_status=1
                            fi
                        else
                            echo -e "${YELLOW}[!] Flatpak not installed, skipping.${RESET}"
                        fi
                        echo
                    }

                    update_snap () {
                        echo "Updating all snap packages..."
                        echo

                        if command -v snap >/dev/null 2>&1; then
                            if sudo snap refresh; then
                                echo
                                echo -e "${GREEN}[+] Snap packages updated${RESET}"
                            else
                                echo
                                echo -e "${RED}[!] Snap update failed${RESET}"
                                overall_status=1
                            fi
                        else
                            echo -e "${YELLOW}[!] Snap not installed, skipping.${RESET}"
                        fi
                        echo
                    }

                    update_APT
                    update_flatpak
                    update_snap

                    # Final status
                    if [[ $overall_status -eq 0 ]]; then
                        echo -e "${GREEN}[+] All updates completed successfully.${RESET}"
                    else
                        echo -e "${RED}[!] Some updates failed. Check output above.${RESET}"
                    fi
                    ;;
                2)
                    # Display system information
                    echo
                    echo "Fastfetch https://github.com/fastfetch-cli/fastfetch"
                    echo -e "${GREEN}[➜] Gathering system information...${RESET}"
                    sleep 0.5

                    if command -v fastfetch >/dev/null 2>&1; then
                        if fastfetch; then
                            echo
                            echo -e "${GREEN}[+] System information displayed.${RESET}"
                        else
                            echo
                            echo -e "${RED}[!] Fastfetch failed to run.${RESET}"
                            return 1
                        fi
                    else
                        echo -e "${YELLOW}[!] fastfetch not installed. Falling back to basic system info...${RESET}"
                        echo

                        uname -a
                        echo
                        lsb_release -a 2>/dev/null
                        echo
                        uptime

                        echo
                        echo -e "${GREEN}[+] Basic system information displayed.${RESET}"
                    fi
                    ;;
                3)   
                   # Paranoia mode
                    echo

                    confirm_paranoia() {
                        echo -e "${RED}[!] WARNING: Paranoia mode is extremely invasive and may break networking, audio, and system functionality.${RESET}"
                        echo -e "${RED}[!] Use only in controlled environments (VM recommended).${RESET}"
                        echo
                        echo "Type EXACTLY: ENABLE PARANOIA MODE"
                        read -r input

                        if [[ "$input" != "ENABLE PARANOIA MODE" ]]; then
                            echo -e "${RED}[!] Confirmation failed. Aborting.${RESET}"
                            return 1
                        fi
                    }

                    paranoia_mode() {
                        local status=0

                        echo -e "${GREEN}[➜] Enabling Paranoia mode...${RESET}"
                        sleep 0.5

                        # Firewall lockdown
                        if sudo iptables -P OUTPUT DROP; then
                            sudo iptables -A OUTPUT -d 127.0.0.1 -j ACCEPT
                        else
                            echo -e "${RED}[!] iptables failed${RESET}"
                            status=1
                        fi

                        # Network manager off
                        if ! nmcli networking off; then
                            echo -e "${RED}[!] NetworkManager disable failed${RESET}"
                            status=1
                        fi

                        # History cleanup (safe version)
                        shred -u ~/.bash_history 2>/dev/null || true
                        history -c 2>/dev/null || true

                        # /tmp cleanup (safer: only user files, not system-wide force shred)
                        find /tmp -type f -user "$USER" -exec shred -u {} \; 2>/dev/null

                        # Module unload (optional hardware lockdown)
                        sudo modprobe -r uvcvideo 2>/dev/null || true
                        sudo modprobe -r snd_hda_intel 2>/dev/null || true

                        if [[ $status -eq 0 ]]; then
                            echo -e "${GREEN}[+] Paranoia mode enabled successfully.${RESET}"
                        else
                            echo -e "${RED}[!] Paranoia mode partially failed (check output above).${RESET}"
                        fi

                        return $status
                    }

                    if confirm_paranoia; then
                        paranoia_mode
                    else
                        exit 1
                    fi
                    ;;
                4)
                    # Exit
                    exit 0
                    ;;
                q)
                    # Exit
                    exit 0
                    ;;
                *)
                    # Error handling for invalid input
                    echo -e "${RED}[✖] Invalid option${RESET}" # Handle invalid input and prompt user again
                    ;;
            esac
        done
    done
}

