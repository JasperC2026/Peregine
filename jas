        echo -e "${RED}[!] OpenSSL is not installed.${RESET}"
        return 1
    fi

    read -rp "Enter encrypted text: " text

    echo -e "${CYAN}"
    printf "%s" "$text" | openssl enc -aes-128-cbc -d -pbkdf2 -iter 100000 -a
    status=$?
    echo -e "${RESET}"
    if [[ $status -eq 0 ]]; then
        echo -e "${GREEN}[+] Text decrypted.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Decryption failed.${RESET}"
        return 1
    fi
    echo "---------------------------------------------------------------"
}
decrypt_text_ceasar() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Caesar Decipher${RESET}"

    read -rp "Enter text: " text
    read -rp "Enter shift (e.g. 3): " shift

    shift=$(( -shift ))

    echo -e "${CYAN}"
    result=$(printf "%s" "$text" | awk -v shift="$shift" '
    BEGIN {
        alphabet="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
        len=length(alphabet)

        for (i=1;i<=len;i++) {
            c=substr(alphabet,i,1)
            new=substr(alphabet,((i-1+shift)%len+len)%len+1,1)
            map[c]=new
        }
    }
    {
        for (i=1;i<=length($0);i++) {
            c=substr($0,i,1)
            printf "%s", (c in map)?map[c]:c
        }
    }')

    echo -e "${RESET}"
    echo -e "${GREEN}[+] Result: $result${RESET}"
    echo "---------------------------------------------------------------"
}
decrypt_text_vigenere() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${GREEN}[➜] Vigenère Decipher${RESET}"
    echo

    read -rp "Enter text: " text
    read -rp "Enter key: " key

    echo -e "${CYAN}"
    result=$(awk -v text="$text" -v key="$key" '
    function ord(c) { return index("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c) }
    function chr(n) { return substr("ABCDEFGHIJKLMNOPQRSTUVWXYZ", n, 1) }

    BEGIN {
        key = toupper(key)
        text = toupper(text)
        keylen = length(key)
        j = 1

        for (i = 1; i <= length(text); i++) {
            c = substr(text, i, 1)

            if (c ~ /[A-Z]/) {
                shift = ord(substr(key, j, 1)) - 1

                new = (ord(c) - shift - 1)
                new = (new % 26 + 26) % 26 + 1

                printf "%s", chr(new)
                j = (j % keylen) + 1
            } else {
                printf "%s", c
            }
        }
    }')

    echo -e "${RESET}"
    echo -e "${GREEN}[+] Result: $result${RESET}"
    echo "---------------------------------------------------------------"
}
