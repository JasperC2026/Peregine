}
whois_lookup() {
    clear
    echo "---------------------------------------------------------------"
    echo -e "${BOLD}"
    echo -n "Enter domain (ex: example.com): "
    echo -e "${RESET}"
    read -r domain

    if [[ -z "$domain" ]]; then
        echo -e "${YELLOW}[!] Error: Domain cannot be empty.${RESET}"
        return 1
    fi

    # Strip protocol/path if user pastes a full URL (e.g. https://example.com/page)
    domain=$(echo "$domain" | sed -E 's|^https?://||; s|/.*||')

    # Validate domain format: labels of 1-63 chars, TLD of 2-63 chars
    if ! echo "$domain" | grep -qE '^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}$'; then
        echo -e "${RED}[!] Invalid domain format: '$domain'${RESET}"
        echo -e "${YELLOW}    Expected format: example.com or sub.example.co.uk${RESET}"
        return 1
    fi

    echo -e "${PURPLE}"
    read -p "Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    echo -e "${GREEN}[➜] Performing Whois lookup for $domain...${RESET}"
    sleep 0.5

    output=$(run_with_tor whois "$domain" 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Whois lookup failed (network/command error).${RESET}"
        return 1
    fi

    if echo "$output" | grep -qiE "no match|not found|no data found|status: free"; then
        echo -e "\a"
        echo -e "${RED}[!] Domain not found or no WHOIS data available.${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Whois lookup completed successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
ping() {
    clear
    echo "---------------------------------------------------------------"
    echo -n "Enter item to ping (domain or IP): "
    read -r itemping

    if [[ -z "$itemping" ]]; then
        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
        return 1
    fi

    # Strip protocol/path if user pastes a URL
    itemping=$(echo "$itemping" | sed -E 's|^https?://||; s|/.*||')

    # Validate: IPv4, IPv6, or domain
    local ipv4='^([0-9]{1,3}\.){3}[0-9]{1,3}$'
    local ipv6='^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$'
    local domain='^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}$'

    if ! echo "$itemping" | grep -qE "${ipv4}|${ipv6}|${domain}"; then
        echo -e "${RED}[!] Invalid target: '$itemping'${RESET}"
        echo -e "${YELLOW}    Expected: a domain (example.com), IPv4 (1.2.3.4), or IPv6 (::1)${RESET}"
        return 1
    fi

    # Extra check: each IPv4 octet must be 0-255
    if echo "$itemping" | grep -qE "$ipv4"; then
        IFS='.' read -r o1 o2 o3 o4 <<< "$itemping"
        if (( o1 > 255 || o2 > 255 || o3 > 255 || o4 > 255 )); then
            echo -e "${RED}[!] Invalid IPv4 address: '$itemping' (octet out of range).${RESET}"
            return 1
        fi
    fi

    output=$(command ping -c 6 "$itemping" 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Ping failed (host unreachable or network issue).${RESET}"
        return 1
    fi

    if echo "$output" | grep -q "100% packet loss"; then
        echo -e "\a"
        echo -e "${RED}[!] Ping failed (100% packet loss).${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Ping completed successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
traceroute() {
    clear
    echo "---------------------------------------------------------------"
    echo -n "Enter domain or IP to trace: "
    read -r domaintrace

    if [[ -z "$domaintrace" ]]; then
        echo -e "${YELLOW}[!] Error: Target cannot be empty.${RESET}"
        return 1
    fi

    # Strip protocol/path if user pastes a URL
    domaintrace=$(echo "$domaintrace" | sed -E 's|^https?://||; s|/.*||')

    # Validate: IPv4, IPv6, or domain
    local ipv4='^([0-9]{1,3}\.){3}[0-9]{1,3}$'
    local ipv6='^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$'
    local domain='^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}$'

    if ! echo "$domaintrace" | grep -qE "${ipv4}|${ipv6}|${domain}"; then
        echo -e "${RED}[!] Invalid target: '$domaintrace'${RESET}"
        echo -e "${YELLOW}    Expected: a domain (example.com), IPv4 (1.2.3.4), or IPv6 (::1)${RESET}"
        return 1
    fi

    # Extra check: each IPv4 octet must be 0-255
    if echo "$domaintrace" | grep -qE "$ipv4"; then
        IFS='.' read -r o1 o2 o3 o4 <<< "$domaintrace"
        if (( o1 > 255 || o2 > 255 || o3 > 255 || o4 > 255 )); then
            echo -e "${RED}[!] Invalid IPv4 address: '$domaintrace' (octet out of range).${RESET}"
            return 1
        fi
    fi

    echo -e "${YELLOW}[!] Traceroute is unreliable over Tor. Running normally.${RESET}"
    sleep 0.5

    output=$(command traceroute "$domaintrace" 2>&1)
    status=$?

    echo -e "${CYAN}$output${RESET}"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Traceroute failed (network/DNS issue).${RESET}"
        return 1
    fi

    if echo "$output" | grep -qE "^\s*[0-9]+\s+\*\s+\*\s+\*"; then
        echo -e "\a"
        echo -e "${RED}[!] Traceroute failed or blocked (no responses).${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Traceroute completed successfully.${RESET}"
    echo "---------------------------------------------------------------"
}
