# Jas - A simple command line toolbox for networking, system managing and privacy/security. Version 1.6

# -------------------
# Colors for ASCII art and use in output messages
# -------------------

RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"
PURPLE="\e[35m"
ORANGE="\e[38;5;208m"
BOLD="\e[1m"
RESET="\e[0m"
COLORS=(
"0;0;180" 
"0;0;255" 
"0;102;255"
"0;153;255" 
"0;204;255" 
)
i=0
rainbow() {
  local colors=("\e[31m" "\e[33m" "\e[32m" "\e[36m" "\e[34m" "\e[35m")
  local i=0

  while IFS= read -r line; do
    printf "%b%s\e[0m\n" "${colors[$((i % 6))]}" "$line"
    ((i++))
  done
}

