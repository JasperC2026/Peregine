# -------------------
# Network Tools Submenu
# -------------------
network_tools() {
    while true; do
        PS3="Network Tools Menu: "
        options=("Whois" "Ping" "Trace" "DNS info" "get IP" "IP osint" "Back")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    # Whois lookup
                    echo -n "Enter domain (ex: example.com): "
                    read -r domain # read domain input from user
                    echo -e "${GREEN}[+] Performing Whois lookup for $domain...${RESET}"
                    sleep 0.5
                    whois "$domain" # Perform whois lookup and display results
                    ;;
                2)
                    echo -n "Enter item to ping: "
                    read -r itemping # read ping target input from user
                    echo -e "${GREEN}[+] Pinging $itemping...${RESET}"
                    sleep 0.5
                    ping "$itemping" # Perform ping and display results
                    ;;
                3)
                    echo -n "Enter domain to trace: "
                    read -r domaintrace # read trace target input from user
                    echo -e "${GREEN}[+] Tracing route to $domaintrace...${RESET}"
                    sleep 0.5
                    traceroute "$domaintrace" # Perform traceroute and display results
                    ;;
                4)
                    echo -n "Enter domain to get DNS info: "
                    read -r domaindns # read DNS target input from user
                    echo -e "${GREEN}[+] Getting DNS info for $domaindns...${RESET}"
                    sleep 0.5
                    dig "$domaindns" # Perform DNS lookup and display results
                    ;;
                5)
                    echo -e "${GREEN}[+] Fetching public IP...${RESET}"
                    sleep 0.5
                    curl ifconfig.me # Fetch and display public IP address
                    ;;
                6)
                    ip_osint() {
                    read -p "Enter IP or domain: " target # read target input from user
                    
                    echo -e "${GREEN}[+] Fetching OSINT for $target...${RESET}"
                    sleep 0.5

                    data=$(curl -s ipinfo.io/$target)

                    echo "IP:       $(echo $data | jq -r '.ip')"
                    echo "City:     $(echo $data | jq -r '.city')"
                    echo "Region:   $(echo $data | jq -r '.region')"
                    echo "Country:  $(echo $data | jq -r '.country')"
                    echo "ISP:      $(echo $data | jq -r '.org')"
                    echo "Timezone: $(echo $data | jq -r '.timezone')"
                }
                    ip_osint # Perform IP OSINT lookup and display results
                    ;;
                7)
                    echo -e "${GREEN}[+] Returning to main menu...${RESET}" 
                    return  
                    ;;
                *)
                    echo -e "${RED} [!] Invalid option${RESET}   " # Handle invalid input and prompt user again
                    ;;
            esac
        done
    done
}

# -------------------
# System Tools Submenu
# -------------------
system_tools() {
    while true; do
        PS3="System Tools Menu: "
        options=("Updating all apps" "See system information" "Paranoia mode" "Back")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    echo -e "${GREEN}[+] Starting update process...${RESET}"
                    sleep 0.5
                    echo "Updating all apps..."
                    # update APT
                    echo "Updating all APT packages..."
                    echo
                    sudo apt update && sudo apt upgrade -y # Update APT packages and display results
                    echo
                    echo -e "${GREEN}[+] APT packages updated${RESET}"
                    echo 
                    # update flatpak
                    echo "Updating all flatpak packages..."
                    echo
                    flatpak update -y # Update flatpak packages and display results 
                    echo
                    echo -e "${GREEN}[+] flatpak updated${RESET}"
                    echo 
                    # update snap
                    echo "Updating all snap packages..."
                    echo
                    sudo snap refresh # Update snap packages and display results
                    echo
                    upgradable=$(snap list --upgradable)
                    if [ -z "$upgradable" ]; then
                    echo -e "${RED}[!] No upgradable Snap packages found.${RESET}"
                    else
                    echo "Upgradable Snap packages:"
                    echo "$upgradable" 
                    echo "Updating upgradable Snap packages..."
                    sudo snap refresh --all # Update all snap packages, including upgradable ones
                    echo 
                    echo -e "${GREEN}[+] All upgradable Snap packages have been updated.${RESET}"
                    echo
                    fi
            ;;
                2)
                    echo -e "${GREEN}[+] Gathering system information...${RESET}"
                    sleep 0.5
                    fastfetch # Display system information using fastfetch
                    ;;
                3)   
                    confirm_paranoia() {
                    echo -e "[!] WARNING: PARANOIA MODE IS EXTREMELY INVASIVE"
                    echo "Type EXACTLY: ENABLE PARANOIA MODE"
                    read -r input

                    if [[ "$input" != "ENABLE PARANOIA MODE" ]]; then
                    echo -e "${RED}[!] Confirmation failed. Aborting.${RESET}"
                    exit 1
                    fi
                    }

                    confirm_paranoia

                    echo -e "${GREEN}[+] Enabling Paranoia mode...${RESET}"
                    sleep 0.5

                    sudo iptables -P OUTPUT DROP # Drop all outgoing traffic by default
                    sudo iptables -A OUTPUT -d 127.0.0.1 -j ACCEPT # Allow localhost
                    nmcli networking off # Disable NetworkManager

                    shred -u ~/.bash_history 2>/dev/null # Securely delete bash history
                    history -c # Clear current session history
                    sudo find /tmp -type f -exec shred -u {} \; 2>/dev/null # Securely delete temporary files

                    sudo modprobe -r uvcvideo 2>/dev/null # Disable webcam
                    sudo modprobe -r snd_hda_intel 2>/dev/null # Disable microphone

                    echo -e "${GREEN}[+] Paranoia mode enabled.${RESET}"
                    ;;
                4)
                    echo -e "${GREEN}[+] Returning to main menu...${RESET}"
                    return
                    ;;
                *)
                    echo -e "${RED} [!] Invalid option${RESET}   " # Handle invalid input and prompt user again
                    ;;
            esac
        done
    done
}

# -------------------
# Privacy/Security Tools Submenu
# -------------------

privacy_tools() {
    while true; do
        PS3="Privacy/Security Menu: "
        options=("Securely wipe trash" "Securely overwrite free space" "Peform system audit" "Peform system cleanup" "Check for rootkits" "Remove temporary files" "Generate secure password" "Delete file"  "Exit")
        select opt in "${options[@]}"; do
            case $REPLY in
                1)
                    TRASH_FILES="$HOME/.local/share/Trash/files"
                    TRASH_INFO="$HOME/.local/share/Trash/info"

                     # Check if trash is empty
                    if [[ -z "$(ls -A "$TRASH_FILES" 2>/dev/null)" && -z "$(ls -A "$TRASH_INFO" 2>/dev/null)" ]]; then
                        echo "Trash is empty."
                        continue
                    fi

                    # Confirm deletion
                    read -rp "Confirm deletion (y/n): " confirm
                    if [[ "$confirm" != "y" ]]; then
                        echo -e "${RED}[!] Deletion aborted.${RESET}"
                        continue
                    fi

                    # Securely delete files
                    echo -e "${GREEN}[+] Securely deleting trash...${RESET}"
                    sleep 0.5
                    echo "Deleting files..."
                    srm -v -r "${TRASH_FILES}/"*

                    echo -e "${GREEN}[+] Securely deleting trash info...${RESET}"
                    sleep 0.5
                    srm -v -r "${TRASH_INFO}/"*

                    # Completed status
                    echo -e "${GREEN}[+] Deletion completed.${RESET}"
                    ;;
            
                2)
                    echo -e "${GREEN}[+] Securely overwriting free space...${RESET}"
                    # Get the root partition
                    root_partition=$(df / | tail -1 | awk '{print $1}')
                    
                    # Check if srm is installed
                    if ! command -v srm &> /dev/null; then
                        echo -e "${RED}[!] srm command not found. Please install it to use this feature.${RESET}"
                        continue
                    fi
                    
                    # Securely overwrite free space
                    echo -e "${GREEN}[+] Overwriting free space on $root_partition...${RESET}"
                    srm -v -z -r --free "$root_partition"
                    
                    echo -e "${GREEN}[+] Free space securely overwritten.${RESET}"
                    ;;
                3)
                    echo -e "${GREEN}[+] Performing system audit with Lynis...${RESET}"
                    sleep 0.5
                    echo
                    sudo lynis audit system # Perform system audit with Lynis and display results
                    echo
                    echo -e "${GREEN}[+] System audit completed.${RESET}"
                    ;;    
                4)
                    echo -e "${GREEN}[+] Running BleachBit...${RESET}"
                    sleep 0.5
                    sudo bleachbit # Run BleachBit with root privileges and display results
                    echo -e "${GREEN}[+] BleachBit cleanup completed.${RESET}"
                    ;;
                5)
                    echo -e "${GREEN}[+] Checking for rootkits with chkrootkit...${RESET}"
                    chkrootkit # Check for rootkits with chkrootkit and display results
                    echo -e "${GREEN}[+] Rootkit check completed.${RESET}"
                    ;;  
                6)
                    echo -e "${GREEN}[+] Removing temporary files...${RESET}"
                    rm -rf /tmp/* # Remove all files in /tmp directory
                    echo -e "${GREEN}[+] Temporary files removed.${RESET}"
                    ;;  
                7)
                    echo -e "${GREEN}[+] Generating secure password...${RESET}"
                    sleep 0.5
                    echo 
                    openssl rand -base64 12 # Generate and display a secure random password
                    echo -e "${GREEN}[+] Password generation completed.${RESET}"
                    ;;  

                8)    
                    echo -n "Enter file: "
                    read -r file

                    if [[ -z "$file" ]]; then
                    echo -e "${RED}[!] No file entered.${RESET}"
                    elif [[ ! -f "$file" ]]; then
                    echo -e "${RED}[!] File does not exist.${RESET}"
                    else
                    echo -e "${GREEN}[+] Running shred for: $file${RESET}"
                    shred -u -v -n 5 "$file" # Securely delete the specified file with 5 passes and display results
                    echo -e "${GREEN}[+] File securely deleted.${RESET}"
                    fi
                    ;; 
                
                9)
                    echo -e "${GREEN}[+] Returning to main menu...${RESET}"
                    return
                    ;;
                *)
                    echo -e "${RED}[!] Invalid option.${RESET}" # Handle invalid input and prompt user again
                    ;;
            esac
        done
    done
}

