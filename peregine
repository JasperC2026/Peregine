subdomain_enum() {
    echo "───────────────────────────────────────────────────────────────"
    echo "Subdomain Enumeration — DNS brute-force + crt.sh + zone transfer"
    echo -e "${YELLOW}[i] Uses: dig, curl, jq — optional: subfinder${RESET}"
    echo -e "${YELLOW}[i] Only use on authorized systems, and respect privacy policies.${RESET}"
    echo -e "${YELLOW}[i] Gathering OSINT data can be illegal in certain cases, use wisely.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
 
    # ── Input ────────────────────────────────────────────────────────
    echo -n "Enter target domain (e.g. example.com): "
    read -r domain
 
    if [[ -z "$domain" ]]; then
        echo -e "${YELLOW}[!] Error: Domain cannot be empty.${RESET}"
        return 1
    fi
 
    domain=$(echo "$domain" | sed -E 's|^https?://||; s|/.*||' | tr '[:upper:]' '[:lower:]')
 
    if ! echo "$domain" | grep -qE '^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}$'; then
        echo -e "${RED}[!] Invalid domain format: '$domain'${RESET}"
        echo -e "${YELLOW}    Expected: example.com or sub.example.co.uk${RESET}"
        return 1
    fi
 
    # ── Tor ──────────────────────────────────────────────────────────
    echo -e "${PURPLE}"
    read -p "[TOR]Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"
 
    # ── Output file ──────────────────────────────────────────────────
    local outfile="subdomain_enum_${domain}_$(date +%Y%m%d_%H%M%S).txt"
    local found=()
 
    _sub_add() {
        # Add a subdomain to the found list (dedup)
        local sub="$1"
        if [[ -n "$sub" ]] && ! printf '%s\n' "${found[@]}" | grep -qx "$sub"; then
            found+=("$sub")
        fi
    }
 
    # ── Method 1: crt.sh certificate transparency (passive) ──────────
    echo
    echo -e "${CYAN}── [1/3] crt.sh Certificate Transparency ────────────────────${RESET}"
 
    if ! command -v curl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
        echo -e "${YELLOW}[!] curl or jq not found — skipping crt.sh.${RESET}"
    else
        echo -e "${GREEN}[➜] Querying crt.sh for $domain...${RESET}"
        local crt_data
        crt_data=$(run_with_tor curl -sf --max-time 15 \
            "https://crt.sh/?q=%25.$domain&output=json" 2>&1)
        local crt_status=$?
 
        if [[ $crt_status -ne 0 || -z "$crt_data" ]]; then
            echo -e "${YELLOW}[!] crt.sh query failed or timed out.${RESET}"
        elif ! echo "$crt_data" | jq empty 2>/dev/null; then
            echo -e "${YELLOW}[!] crt.sh returned invalid JSON.${RESET}"
        else
            local crt_count=0
            while IFS= read -r sub; do
                # crt.sh can return wildcard entries like *.example.com — strip the wildcard
                sub="${sub#\*.}"
                # Only keep subdomains that actually belong to the target
                if echo "$sub" | grep -qE "\.${domain}$|^${domain}$"; then
                    _sub_add "$sub"
                    echo -e "  ${GREEN}[+]${RESET} $sub"
                    (( crt_count++ ))
                fi
            done < <(echo "$crt_data" | jq -r '.[].name_value' 2>/dev/null | sort -u)
            echo -e "${GREEN}[+] crt.sh found $crt_count subdomains.${RESET}"
        fi
    fi
 
    # ── Method 2: Zone transfer attempt ──────────────────────────────
    echo
    echo -e "${CYAN}── [2/3] DNS Zone Transfer (AXFR) ──────────────────────────${RESET}"
 
    if ! command -v dig >/dev/null 2>&1; then
        echo -e "${YELLOW}[!] dig not found — skipping zone transfer.${RESET}"
    else
        # Resolve nameservers for the domain first
        local ns_list
        ns_list=$(dig +short NS "$domain" 2>/dev/null | sed 's/\.$//')
 
        if [[ -z "$ns_list" ]]; then
            echo -e "${YELLOW}[!] No nameservers found for $domain — skipping.${RESET}"
        else
            local axfr_success=0
            while IFS= read -r ns; do
                [[ -z "$ns" ]] && continue
                echo -e "${GREEN}[➜] Trying AXFR on $ns...${RESET}"
                local axfr_data
                axfr_data=$(dig AXFR "$domain" "@$ns" 2>/dev/null)
                if echo "$axfr_data" | grep -qv "Transfer failed\|communications error\|connection timed out"; then
                    local axfr_count=0
                    while IFS= read -r sub; do
                        sub="${sub%.}"     # strip trailing dot
                        if echo "$sub" | grep -qE "\.${domain}$|^${domain}$"; then
                            _sub_add "$sub"
                            echo -e "  ${GREEN}[+]${RESET} $sub"
                            (( axfr_count++ ))
                        fi
                    done < <(echo "$axfr_data" | awk '/^[^;]/ {print $1}' | sort -u)
                    if [[ $axfr_count -gt 0 ]]; then
                        echo -e "${GREEN}[+] Zone transfer succeeded on $ns — $axfr_count records.${RESET}"
                        axfr_success=1
                    fi
                fi
            done <<< "$ns_list"
            if [[ $axfr_success -eq 0 ]]; then
                echo -e "${YELLOW}[i] Zone transfer not allowed (expected for most public domains).${RESET}"
            fi
        fi
    fi
 
    # ── Method 3: DNS brute-force with built-in wordlist ─────────────
    echo
    echo -e "${CYAN}── [3/3] DNS Brute-Force ────────────────────────────────────${RESET}"
 
    if ! command -v dig >/dev/null 2>&1; then
        echo -e "${YELLOW}[!] dig not found — skipping brute-force.${RESET}"
    else
        # Built-in wordlist — common subdomains, no external file needed
        local wordlist=(
            www mail ftp smtp pop pop3 imap webmail
            remote vpn api dev staging test beta
            admin portal dashboard login auth sso oauth
            blog shop store cdn static assets img images media
            docs help support forum community wiki
            ns ns1 ns2 dns dns1 dns2
            mx mx1 mx2 smtp1 smtp2
            db database mysql postgres redis mongo
            git gitlab github ci jenkins
            cloud s3 bucket backup
            app mobile api2 v1 v2 status
            intranet internal corp office
            proxy gateway fw firewall
            monitor metrics grafana kibana
            old legacy dev2 uat qa preprod prod
        )
 
        echo -e "${GREEN}[➜] Testing ${#wordlist[@]} subdomains against $domain...${RESET}"
        local brute_count=0
 
        for word in "${wordlist[@]}"; do
            local fqdn="${word}.${domain}"
            # A-record lookup; suppress errors, only output on hit
            local result
            result=$(dig +short A "$fqdn" 2>/dev/null | head -1)
            if [[ -n "$result" ]]; then
                _sub_add "$fqdn"
                echo -e "  ${GREEN}[+]${RESET} ${fqdn} ${CYAN}→ ${result}${RESET}"
                (( brute_count++ ))
            fi
        done
        echo -e "${GREEN}[+] Brute-force found $brute_count subdomains.${RESET}"
    fi
     # ── Resolve IPs for all found subdomains ─────────────────────────
    echo
    echo -e "${CYAN}── Resolving IPs ────────────────────────────────────────────${RESET}"
 
    declare -A sub_ips
    for sub in "${found[@]}"; do
        local ip
        ip=$(dig +short A "$sub" 2>/dev/null | grep -E '^[0-9]+\.' | head -1)
        sub_ips["$sub"]="${ip:-unresolved}"
    done
 
    # ── Summary ──────────────────────────────────────────────────────
    echo
    echo -e "${CYAN}── Summary ──────────────────────────────────────────────────${RESET}"
 
    if [[ ${#found[@]} -eq 0 ]]; then
        echo -e "${YELLOW}[i] No subdomains found.${RESET}"
    else
        printf "  ${BOLD}%-45s %s${RESET}\n" "Subdomain" "IP"
        echo "  ──────────────────────────────────────────────────────"
        for sub in $(printf '%s\n' "${found[@]}" | sort); do
            printf "  ${CYAN}%-45s${RESET} %s\n" "$sub" "${sub_ips[$sub]}"
        done
        echo
        echo -e "${GREEN}[+] Total unique subdomains found: ${#found[@]}${RESET}"
    fi
 
    # ── Save to file ──────────────────────────────────────────────────
    {
        echo "# Subdomain enumeration — $domain"
        echo "# Date: $(date)"
        echo "# Total: ${#found[@]}"
        echo
        printf "%-45s %s\n" "Subdomain" "IP"
        printf "%-45s %s\n" "---------" "--"
        for sub in $(printf '%s\n' "${found[@]}" | sort); do
            printf "%-45s %s\n" "$sub" "${sub_ips[$sub]}"
        done
    } > "$outfile"
 
    echo -e "${GREEN}[➜] Results saved to: ${outfile}${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
local_server() {
    echo "{DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v python3 >/dev/null 2>&1; then  # Check if python is installed 
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install python3"
        exit 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"
    echo 

    echo "{DIVIDER}"
    echo -e "${RED}[!]${RESET} Note: This will expose the contents of the current directory to anyone who can access the specified port on your machine. Make sure you understand the security implications before proceeding."
    echo "This will start a local HTTP server using Python's built-in http.server module. You can access it by navigating to http://localhost:PORT in your web browser, where PORT is the port number you specify."
    echo "Make sure to stop the server when you're done by pressing Ctrl+C in the terminal."
    echo "{DIVIDER}"

    echo -n "Are you sure you want to start a local server? (y/n): "
    read -r confirm # Read user input to confirm starting the local server

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo -n "Enter port number (default 8000): "
        read -r port # Read user input for the port number to use for the local server

        python3 -m http.server "$port" # Start a local HTTP server on the specified port
        status=$? # Capture the exit status of the python command to check for errors
    else
        echo -e "${YELLOW}[i]${RESET} Local server setup cancelled."
        return 1
    fi

    if [[ $status -ne 0 ]]; then # Check if the python command executed successfully
        echo -e "${RED}[!]${RESET} Failed to start local server: $output"
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Local server started successfully on port $port"
    fi

    echo "[->] Command executed" 
    echo "{DIVIDER}"
}
whois_lookup() {
    echo "{DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v whois >/dev/null 2>&1; then  # Check if whois is installed 
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install whois"
        exit 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"
    echo 

    echo -n "Enter domain: "
    read -r domain # Read user input for the domain to look up

    if [[ -z "$domain" ]]; then # Check if the user entered a domain
        echo -e "${RED}[!]${RESET} No domain entered. Exiting."
        return 1
    fi

    if ! echo "$domain" | grep -qE '^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}$'; then # Validate the domain format using a regex
        echo -e "${RED}[!] Invalid domain format: '$domain'${RESET}"
        return 1
    fi

    echo -e "${PURPLE}"
    read -p "[TOR] Route through Tor? (y/n): " USE_TOR # Ask the user if they want to route through Tor
    echo -e "${RESET}"

    if [[ "$USE_TOR" =~ ^[Yy]$ ]]; then
        if ! command -v torsocks >/dev/null 2>&1; then # Check if torsocks is installed
            echo -e "${RED}[!]${RESET} Torsocks is not installed. Please install it to use Tor routing."
            echo "Install with: sudo apt install torsocks"
            exit 1
        fi

        echo -e "${GREEN}[+]${RESET} Routing through Tor..."
        output=$(torsocks whois $domain  2>&1) # Use torsocks to route the whois command through Tor
        status=$? # Capture the exit status of the whois command to check for errors
    else 
        output=$(whois $domain 2>&1) # Perform a standard whois lookup without Tor
        status=$? # Capture the exit status of the whois command to check for errors
    fi

    if echo "$output" | grep -qiE "no match|not found|no data found|status: free"; then
        echo -e "\a"
        echo -e "${RED}[!]${RESET} Domain not found or no WHOIS data available."
        return 1
    fi

    if [[ $status -ne 0 ]]; then # Check if the whois command executed successfully
        echo -e "${RED}[!]${RESET} Whois lookup failed: $output"
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Whois lookup successful"
        echo -e "${CYAN}WHOIS Information for $domain:${RESET}"
        echo -e "${CYAN}$output${RESET}"
    fi
    echo "[->] Command executed"
    echo "{DIVIDER}"
}
