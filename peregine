            echo "  Explainer of the BSL (Business Source License)"
            ;;
        unlicense_explained)
            echo -e "${CYAN}unlicense_explained${RESET}"
            echo "  Explainer of the Unlicense (public domain dedication)"
            ;;
        cc_explained)
            echo -e "${CYAN}cc_explained${RESET}"
            echo "  Explainer of the Creative Commons licenses."
            ;;
        license|l)
            echo -e "${CYAN}license / l${RESET}"
