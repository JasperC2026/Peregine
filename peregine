rot13_cipher() {
    echo "───────────────────────────────────────────────────────────────"
    echo -e "${GREEN}[➜] ROT13 Cipher${RESET}"

    echo -e "${CYAN}"
    read -rp "Enter text: " text
    result=$(printf "%s" "$text" | tr 'A-Za-z' 'N-ZA-Mn-za-m')
    echo -e "${RESET}"

    echo -e "${GREEN}[+] Result:${RESET} $result"
    echo "───────────────────────────────────────────────────────────────"
}
decrypt_text_base64() {
    echo "───────────────────────────────────────────────────────────────"
    echo -e "${GREEN}[➜] Base64 Decode${RESET}"

    echo -e "${CYAN}"
    read -rp "Enter Base64 text: " text
    result=$(printf "%s" "$text" | base64 -d 2>/dev/null)
    echo -e "${RESET}"

    if [[ $? -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Invalid Base64 input.${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Result:${RESET} $result"
    echo "───────────────────────────────────────────────────────────────"
}
decrypt_text_aes256() {
    echo "───────────────────────────────────────────────────────────────"
    echo "OpenSSL by the OpenSSL Project https://openssl.org/"
    echo -e "${GREEN}[➜] Decrypting text (AES-256-CBC)...${RESET}"
    echo

    if ! command -v openssl >/dev/null 2>&1; then
        echo -e "\a"
        echo -e "${RED}[!] OpenSSL is not installed.${RESET}"
        return 1
    fi

    read -rp "Enter encrypted text: " text
    echo -e "${CYAN}"
    printf "%s" "$text" | openssl enc -aes-256-cbc -d -pbkdf2 -iter 100000 -a
    status=$?
    echo -e "${RESET}"

    if [[ $status -eq 0 ]]; then
        echo -e "${GREEN}[+] Text decrypted.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Decryption failed.${RESET}"
        return 1
    fi
    echo "───────────────────────────────────────────────────────────────"
}
