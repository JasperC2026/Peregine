        "$(printf "${CSEP}  ─────────────────────────────────────────────────${RESET}")"
        "$(printf "  ${CLABEL}${BOLD}  %-26s${RESET} ${CSEP}%s${RESET}" "File — Encrypt" "Decrypt")"
        "$(printf "${CSEP}  ─────────────────────────────────────────────────${RESET}")"
