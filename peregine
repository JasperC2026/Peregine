        encrypt_text_vigenere|decrypt_text_vigenere)
            echo -e "${CYAN}Vigenère cipher${RESET}"
            echo "  Polyalphabetic substitution cipher using a keyword."
            echo "  Input is converted to uppercase before processing."
            echo -e "  ${YELLOW}[!] Not cryptographically secure — educational use only.${RESET}"
            ;;
        encrypt_text_base64|decrypt_text_base64)
            echo -e "${CYAN}Base64 encode / decode${RESET}"
            echo "  Encode or decode text using Base64."
            echo -e "  ${YELLOW}[!] Not encryption — Base64 is encoding only, not secure.${RESET}"
            ;;
        rot13_cipher|rot13)
            echo -e "${CYAN}ROT13${RESET}"
            echo "  Apply ROT13 substitution to text. Running it twice restores the original."
            echo -e "  ${YELLOW}[!] Not cryptographically secure — educational use only.${RESET}"
            ;;

        # ── Misc ─────────────────────────────────────────────────────────────
        license|l)
            echo -e "${CYAN}license / l${RESET}"
            echo "  Display the full GPL-3.0 license text and a plain-English summary."
            ;;
        clone_source|c)
            echo -e "${CYAN}clone_source / c${RESET}"
            echo "  Clone the Peregine source code from Codeberg."
            echo -e "  ${GREEN}Requires:${RESET} git  (sudo apt install git)"
            ;;
        version|v|V)
            echo -e "${CYAN}version / v / V${RESET}"
            echo "  Show the current Peregine version, type, release date, and test date."
            ;;
        help)
            echo -e "${CYAN}help [command]${RESET}"
            echo "  With no arguments: show all available commands."
            echo "  With a command name: show details and dependencies for that command."
            echo -e "  Example: ${GREEN}peregine help whois${RESET}"
            ;;

        *)
            echo -e "${RED}[!] No help entry for '$1'.${RESET}"
            echo -e "    Run ${CYAN}peregine help${RESET} to list all commands."
            echo -e "${DIVIDER}"
            return 1
            ;;
    esac

    echo -e "${DIVIDER}"
}
