        echo -e "${RED}[!]${RESET} Required dependency not installed"
        echo "Install with: sudo apt install openssl"
        return 1
    fi

    status_dependencies

    echo
    echo -e "$forward Decrypting text (AES-256-CBC)..."

    echo
    read -rp "Enter encrypted text: " text

    echo
    animation_begin
    printf "%s" "$text" | openssl enc -aes-256-cbc -d -pbkdf2 -iter 100000 -a
    animation_end
    status=$?

    if [[ $status -ne 0 ]]; then
        echo -e "${RED}[!]${RESET} Decryption failed."
        return 1
    else 
        echo
        echo -e "${GREEN}[+]${RESET} Text decrypted."
    fi

    command_executed
}

