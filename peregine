    echo -e "${DIVIDER}"

    if ! command -v openssl &> /dev/null; then # Check if openssl is installed
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install openssl"
        return 1
    fi

    status_dependencies

   read -rp "Password length (default: 16, max: 128): " length

    length=${length:-16}

    if ! [[ "$length" =~ ^[0-9]+$ ]] || (( length < 8 || length > 128 )); then
        echo -e "${RED}[!]${RESET} Invalid length '$length' — must be a number between 8 and 128."
        return 1
    fi

    echo
    echo -e "${output_color}── Passwords ────────────────────────────────────────────────${RESET}"

    local pass_alnum
    pass_alnum=$(openssl rand -base64 96 | tr -dc 'A-Za-z0-9' | head -c "$length")
    echo -e "  Alphanumeric : ${output_color}${pass_alnum}${RESET}"

    local pass_full
    pass_full=$(openssl rand -base64 96 | tr -dc 'A-Za-z0-9!@#$%^&*()-_=+[]{}|;:,.<>?' | head -c "$length")
    echo -e "  With symbols : ${output_color}${pass_full}${RESET}"

    local pass_hex
    pass_hex=$(openssl rand -hex 64 | head -c "$length")
    echo -e "  Hex          : ${output_color}${pass_hex}${RESET}"

    echo
    local entropy_alnum entropy_full
    entropy_alnum=$(awk "BEGIN { printf \"%d\", $length * 5.954 }")
    entropy_full=$(awk  "BEGIN { printf \"%d\", $length * 6.554 }")
    echo -e "${output_color}[i] Estimated entropy — alphanumeric: ~${entropy_alnum} bits  |  with symbols: ~${entropy_full} bits${RESET}"

    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
secure_delete() {
    echo -e "${DIVIDER}"

    if ! command -v shred &> /dev/null; then # Check if shred is installed
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install shred"
        return 1
    fi

    status_dependencies

    echo
    warning_destructive_actions
    echo

    echo -n "Enter file or directory to securely delete: "
    read -r target

    if [[ ! -e "$target" ]]; then
        echo -e "${RED}[!]${RESET} Target does not exist: '$target'"
        return 1
    fi

    if [[ -d "$target" ]]; then
        echo -e "${YELLOW}[!] '$target' is a directory.${RESET}"
        read -rp "Securely delete entire directory and contents? (y/n): " confirm
        [[ "$confirm" != "y" ]] && return 0

        echo -e "${GREEN}[➜] Shredding all files in '$target'...${RESET}"
        find "$target" -type f -exec shred -u -v -n 5 {} \;
        rm -rf "$target"

        if [[ ! -e "$target" ]]; then
            echo -e "${GREEN}[+]${RESET} Directory securely deleted."
        else
            echo -e "${RED}[!]${RESET} Directory may not have been fully removed."
            return 1
        fi

    elif [[ -f "$target" ]]; then
        read -rp "Securely delete '$target'? (y/n): " confirm
        [[ "$confirm" != "y" ]] && return 0

        echo -e "${GREEN}[➜]${RESET} Shredding '$target'..."
        shred -u -v -n 5 "$target"

        if [[ ! -e "$target" ]]; then
            echo -e "${GREEN}[+]${RESET} File securely deleted."
        else
            echo -e "${RED}[!]${RESET} File may still exist — check manually."
            return 1
        fi
    else
        echo -e "${RED}[!]${RESET} Target is not a regular file or directory (symlink, device, etc.)."
        return 1
    fi

    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}

clean_metadata() {
    echo -e "${DIVIDER}"

    if ! command -v exiftool &> /dev/null; then # Check if exiftool is installed
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install exiftool"
        return 1
    fi

    status_dependencies

    read -rp "Enter input file: " file

    if [[ ! -f "$file" ]]; then
        echo -e "${RED}[!]${RESET} File not found: '$file'"
        return 1
    fi

    local mimetype
        mimetype=$(file --mime-type -b "$file")
        case "$mimetype" in
            image/*|video/*|audio/*|application/pdf)
                ;;
            *)
                echo -e "${RED}[!]${RESET} Unsupported file type: $mimetype"
                echo -e "${YELLOW}[i] exiftool supports images, video, audio, and PDF${RESET}"
                return 1
                ;;
        esac
    local meta_count
        meta_count=$(exiftool "$file" 2>/dev/null | grep -v "^File\|^Directory\|^MIME\|^ExifTool" | wc -l)
        echo -e "${CYAN}[i] Found $meta_count metadata fields in '$file'.${RESET}"
        echo

        read -rp "Output file (leave blank to overwrite original): " outfile

        if [[ -z "$outfile" ]]; then
            echo -e "[!] This will overwrite the original file."
            read -rp "Confirm? (y/n): " confirm
            [[ "$confirm" != "y" ]] && return 0

            exiftool -all= -overwrite_original "$file" >/dev/null 2>&1
            status=$?
            outfile="$file"
        else
            exiftool -all= -overwrite_original -o "$outfile" "$file" >/dev/null 2>&1
            status=$?
        fi

        if [[ $status -ne 0 ]]; then
            echo -e "${RED}[!]${RESET} Failed to remove metadata"
            return 1
        fi

    local remaining
    remaining=$(exiftool "$outfile" 2>/dev/null | grep -v "^File\|^Directory\|^MIME\|^ExifTool" | wc -l)
    echo -e "${GREEN}[+]${RESET} Metadata removed → $outfile"
    echo -e "${output_color}[i] Remaining metadata fields: $remaining (filesystem/format fields only).${RESET}"


    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
