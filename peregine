encrypt_file_twofish() {
    echo "───────────────────────────────────────────────────────────────"
    echo -e "${GREEN}[➜] Encrypting file (Twofish)...${RESET}"
    echo

    if ! command -v gpg >/dev/null 2>&1; then
        echo -e "${RED}[!] GPG is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install gnupg${RESET}"
