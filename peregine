    echo -e "${DIVIDER}"
}
rootkit_hunt() {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v chkrootkit  &> /dev/null; then # Check if chkrootkit is installed
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install chkrootkit"
        exit 1
