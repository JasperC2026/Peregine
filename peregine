generate_key () {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v openssl >/dev/null 2>&1; then  # Check if openssl is installed 
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install openssl"
        return 1
    fi

    status_dependencies

    echo -e "${BOLD}Select key size:${RESET}"
    echo "  1) 128-bit  (16 bytes  — AES-128)"
    echo "  2) 192-bit  (24 bytes  — AES-192)"
    echo "  3) 256-bit  (32 bytes  — AES-256)"
    echo "  4) 512-bit  (64 bytes  — ChaCha20 / general use)"
    echo
    read -rp "Choice [1-4]: " choice

    case "$choice" in
        1) bits=128;  bytes=16  ;;
        2) bits=192;  bytes=24  ;;
        3) bits=256;  bytes=32  ;;
        4) bits=512;  bytes=64  ;;
        *)
            echo -e "\a"
            echo -e "${RED}[!] Invalid choice. Enter 1, 2, 3, or 4.${RESET}"
            return 1
            ;;
    esac
    
    echo 
    echo -e "${GREEN}[+]${RESET} Generating $bits-bit key ($bytes bytes)..."

    key=$(openssl rand -hex "$bytes" 2>/dev/null) # Generate a random key of the specified size using openssl
    status=$? # Capture the exit status of the openssl command to check for errors

    if [[ $status -ne 0 ]]; then # Check if the openssl command executed successfully
        echo -e "${RED}[!]${RESET} Key generation failed."
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Key generated successfully:"
        echo -e "${output_color}$key${RESET}"
    fi

    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
encrypt_file_aes256() {
    echo -e "${DIVIDER}"

    echo "[->] Checking dependencies"

    if ! command -v openssl >/dev/null 2>&1; then
        echo -e "${RED}[!]${RESET} Required dependency not installed"
        echo "Install with: sudo apt install openssl"
        return 1
    fi

    status_dependencies

    echo -e "${GREEN}[➜]${RESET} Encrypting file (AES-256-CBC)..."
    echo

    read -rp "Enter file to encrypt: " file

    if [[ ! -f "$file" ]]; then
        echo -e "\a"
        echo -e "${RED}[!]${RESET} File not found."
        return 1
    fi

    read -rp "Output file (e.g. file.enc): " outfile

    openssl enc -aes-256-cbc -pbkdf2 -iter 100000 -salt -in "$file" -out "$outfile"
    status=$?

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!]${RESET} Encryption failed."
        return 1
    fi

    echo -e "${GREEN}[+]${RESET} File encrypted → $outfile"
