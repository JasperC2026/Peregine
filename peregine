clean_system() {
    echo "───────────────────────────────────────────────────────────────"
    echo "BleachBit by Andrew Ziem https://www.bleachbit.org/"
    echo -e "${GREEN}[➜] Clean browser caches, logs, temp files, and other artifacts${RESET}"
    echo -e "${YELLOW}[i] Only use on your own system. Some actions are irreversible.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    if ! command -v bleachbit >/dev/null 2>&1; then
        echo -e "\a${RED}[!] BleachBit is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install bleachbit${RESET}"
        return 1
    fi

    echo -e "${BOLD}Clean target:${RESET}"
    echo "  1) Preview only         (no changes — shows what would be removed)"
    echo "  2) System temp & logs   (apt cache, /tmp, system logs)"
    echo "  3) Browser artifacts    (Firefox cache, history, cookies)"
    echo "  4) Bash history"
    echo "  5) All of the above     (preview first, then confirm)"
    echo
    read -rp "Choice [1-5]: " choice

    local t_sys="apt.autoclean apt.autoremove system.cache system.localizations system.rotated_logs system.tmp"
    local t_browser="firefox.cache firefox.cookies firefox.dom firefox.forms firefox.history firefox.session_restore"
    local t_bash="bash.history"

    case "$choice" in
        1)
            echo -e "${CYAN}── Preview (dry run) ────────────────────────────────────────${RESET}"
            bleachbit --preview $t_sys $t_browser $t_bash 2>/dev/null
            echo -e "${YELLOW}[i] No files were removed.${RESET}"
            ;;
        2)
            read -rp "Clean system temp files and logs? (y/n): " confirm
            [[ "$confirm" != "y" ]] && return 0
            bleachbit --clean $t_sys 2>/dev/null
            [[ $? -ne 0 ]] && { echo -e "\a${RED}[!] BleachBit reported errors.${RESET}"; return 1; }
            ;;
        3)
            read -rp "Clean Firefox browser artifacts? (y/n): " confirm
            [[ "$confirm" != "y" ]] && return 0
            bleachbit --clean $t_browser 2>/dev/null
            [[ $? -ne 0 ]] && { echo -e "\a${RED}[!] BleachBit reported errors.${RESET}"; return 1; }
            ;;
        4)
            read -rp "Clear Bash history? (y/n): " confirm
            [[ "$confirm" != "y" ]] && return 0
            bleachbit --clean $t_bash 2>/dev/null
            [[ $? -ne 0 ]] && { echo -e "\a${RED}[!] BleachBit reported errors.${RESET}"; return 1; }
            ;;
        5)
            echo -e "${CYAN}── Preview ───────────────────────────────────────────────────${RESET}"
            bleachbit --preview $t_sys $t_browser $t_bash 2>/dev/null
            echo
            read -rp "Proceed with full clean? (y/n): " confirm
            [[ "$confirm" != "y" ]] && return 0
            bleachbit --clean $t_sys $t_browser $t_bash 2>/dev/null
            [[ $? -ne 0 ]] && { echo -e "\a${RED}[!] BleachBit reported errors.${RESET}"; return 1; }
            ;;
        *)
            echo -e "\a${RED}[!] Invalid choice. Enter 1–5.${RESET}"; return 1 ;;
    esac

    echo
    echo -e "${GREEN}[+] Clean completed.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
