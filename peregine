encryption() {
    # ── Colours ───────────────────────────────────────────────────────────────
    local BOLD='\033[1m'
    local RESET='\033[0m'
    local DIM='\033[2m'
    local CLOGO='\033[38;5;255m'   # white  — logo @'s
    local CLABEL='\033[38;5;114m'  # soft green — info labels
    local CVAL='\033[38;5;250m'    # grey   — info values
    local CSEP='\033[38;5;240m'    # dim    — separators

    # ── Logo ──────────────────────────────────────────────────────────────────
    local -a LOGO=(
        "                                                          "
        "       @                                          @       "
        "        @                                        @        "
        "        @@@                                    @@@        "
        "         @@@@.                              =@@@@         "
        "           @@@@@                         .@@@@@           "
        "           @@ *@@@@=                  %@@@@  @@           "
        "            @@@@= @@@@@   @@@@@    @@@@@ %@@@@            "
        "             @@@@@@@ @@@@   @@@  @@@@ @@@@@@@             "
        "              @@@.   @@@@  @@@@@:@@@@   :@@@              "
        "                %@@@@@ @@@@@@@@@@@@ @@@@@:                "
        "                    *@@ @@=@@@@ @@ @@.                    "
        "                    @@@:@@ @@@@ @@ @@@                    "
        "                     @+@@@  @@  @@%@@                     "
        "                      @ @@@ @@ @@@ @                      "
        "                        @ @@  @@@@@                       "
        "                     .@@ @ -.=@ *@@@@                     "
        "                       @@  @  @  @@                       "
        "                          @    @                          "
        "                        @@ @- @ @@                        "
        "                         @@ @@ @*                         "
        "                            @+                            "
        "                                                          "
    )

    # ── Info block (right column) ─────────────────────────────────────────────
    local -a INFO=(
        ""
        "$(printf "${CLABEL}${BOLD}  Encryption${RESET}  ${CSEP}Command Overview${RESET}")"
