# Security
secure_shred_dir() {
    if ! command -v shred >/dev/null 2>&1; then # Check if shred is installed 
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install coreutils"
        return 1
    fi

    status_dependencies
    
    read -rp "Enter directory to shred: " target # Read user input for the directory to shred
    if [[ -z "$target" ]]; then # Check if the user entered a target
        echo -e "${RED}[!]${RESET} No target entered. Exiting."
        return 1
    fi

    target="${target/#\~/$HOME}" # Expand ~ to the user's home directory if it is used in the target path
    if [[ ! -d "$target" ]]; then # Check if the target is a valid directory
        echo -e "${RED}[!]${RESET} Target is not a valid directory: '$target'"
        return 1
    fi

    local abs_target # Get the absolute path of the target directory to ensure we are checking the correct path for safety
    abs_target=$(realpath "$target") # Get the absolute path of the target directory to ensure we are checking the correct path for safety
    if [[ "$abs_target" == "/" || "$abs_target" == "$HOME" ]]; then # Check if the target directory is the root directory or the user's home directory, which would be too dangerous to shred

        echo -e "${RED}[!] Refusing to shred '$abs_target' — too dangerous.${RESET}"
        return 1
    fi

    echo
    echo -e "  Overwrite passes:" 
    echo -e "  ${CYAN}[1]${RESET} 1 pass  — fast, good enough for most SSDs / already-encrypted"
    echo -e "  ${CYAN}[2]${RESET} 3 passes — DoD 5220.22-M (default, recommended for HDDs)"
    echo -e "  ${CYAN}[3]${RESET} 7 passes — stricter"
    echo -e "  ${CYAN}[4]${RESET} 35 passes — Gutmann (very slow)"
    echo
    read -rp "Select pass count (1-4, default: 2): " pass_choice
 
    local passes # Determine the number of passes based on the user's choice, defaulting to 3 if the input is invalid or empty
    case "$pass_choice" in
        1) passes=1  ;;
        3) passes=7  ;;
        4) passes=35 ;;
        *) passes=3  ;;
    esac
 
    local total_files
    total_files=$(find "$abs_target" -type f | wc -l) # Count the total number of files in the target directory to provide progress feedback during shredding

    echo
    echo -e "${CYAN}  Directory : $abs_target${RESET}"
    echo -e "${CYAN}  Files     : $total_files${RESET}"
    echo -e "${CYAN}  Passes    : $passes${RESET}"
    echo

    
    if [[ ! "$hide_warnings" =~ ^[false]$ ]]; then
        echo
        warning_destructive_actions
        echo 
    fi

    echo -e "${RED}[!]${RESET} This will permanently destroy $total_files file(s) in:"
    echo -e "    ${BOLD}$abs_target${RESET}"
    echo
    read -rp "Type the directory name to confirm: " confirm_name

    if [[ "$confirm_name" != "$(basename "$abs_target")" ]]; then # Check if the user correctly confirmed the directory name to prevent accidental shredding

        echo -e "${RED}[!]${RESET} Confirmation failed. Directory name did not match. Exiting."
        return 1
    fi

    local current=0
    local errors=0
 
    while IFS= read -r -d '' file; do
        (( current++ ))
        local pct=$(( current * 100 / total_files ))
        printf "\r  ${GREEN}[%3d%%]${RESET} (%d/%d) Shredding: %-60s" \
            "$pct" "$current" "$total_files" "$(basename "$file")"
 
        animation_begin
        if ! shred -u -z -n "$passes" "$file" 2>/dev/null; then
            echo
            echo -e "  ${RED}[!]${RESET} Failed to shred: $file"
            (( errors++ ))
        fi
        animation_end
    done < <(find "$abs_target" -type f -print0)

    echo -e "$forward Removing directory structure..."
    find "$abs_target" -type l -delete 2>/dev/null
    rm -rf "$abs_target"

  echo
    echo -e "${output_color}── Summary ──────────────────────────────────────────────────"
    echo -e "  Files processed : $current"
 
    if [[ $errors -gt 0 ]]; then
        echo -e "  Errors          : ${RED}$errors${RESET}"
    fi
 
    if [[ -e "$abs_target" ]]; then

        echo -e "${RED}[!]${RESET} Directory still exists — some files may not have been removed."
        echo -e "Check manually: $abs_target"
        echo "───────────────────────────────────────────────────────────────${RESET}"
        return 1
    fi
 
    echo -e "  ${GREEN}${RESET}Directory verified gone."
    echo
    echo -e "${GREEN}[+]${RESET} Secure directory shred completed."

    command_executed
}
secure_empty_trash() {
    if ! command -v shred >/dev/null 2>&1; then
        echo -e "${RED}[!]${RESET} Required dependency not installed"
        echo "Install with: sudo apt install coreutils"
        return 1
    fi

    status_dependencies

    local file_count
    file_count=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l)

    if [[ $file_count -eq 0 ]]; then
        echo -e "${GREEN}[i] Trash is already empty.${RESET}"
        return 0
    fi

    if [[ ! "$hide_warnings" =~ ^[false]$ ]]; then
        warning_destructive_actions
        echo
    fi

    echo -e "${output_color}[i] Found $file_count item(s) in Trash.${RESET}"
    echo
    read -rp "Securely delete all trash? (y/n): " confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        animation_begin
        echo -e "${GREEN}[+]${RESET} Emptying Trash securely..."

        # Shred files: 3 passes, zero out on final pass, then remove
        find "$TRASH_FILES" -type f -print0 2>/dev/null \
            | xargs -0 -r shred -z -n 3 --remove 2>/dev/null

        # Remove leftover empty directories
        find "$TRASH_FILES" -mindepth 1 -depth -type d -empty -delete 2>/dev/null

        # Shred and remove the corresponding .trashinfo metadata files
        find "$TRASH_INFO" -type f -print0 2>/dev/null \
            | xargs -0 -r shred -z -n 3 --remove 2>/dev/null
    else
        echo -e "${YELLOW}[i]${RESET} Trash emptying cancelled."
        return 1
        animation_end
    fi

    local remaining
    remaining=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l)

    if [[ $remaining -eq 0 ]]; then
        echo -e "${GREEN}[+] Trash securely emptied.${RESET}"
    else

