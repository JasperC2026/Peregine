clone_source() {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v git >/dev/null 2>&1; then
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: apt install git"
        return 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"

    git clone https://codeberg.org/JasperC/Peregine.git
    status=$?

     if [[ $? -ne 0 ]]; then
        echo -e "${RED}[!]${RESET} Failed to clone source code."
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Source code cloned successfully."
    fi

    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
