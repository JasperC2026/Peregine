decrypt_file_twofish() {
    echo "───────────────────────────────────────────────────────────────"
    echo -e "${GREEN}[➜] Decrypting file (Twofish)...${RESET}"
    echo

    if ! command -v gpg >/dev/null 2>&1; then
        echo -e "${RED}[!] GPG is not installed.${RESET}"
        return 1
    fi

    read -rp "Enter encrypted file: " file

    if [[ ! -f "$file" ]]; then
        echo -e "${RED}[!] File not found.${RESET}"
        return 1
    fi

    read -rp "Output file: " outfile

    gpg -o "$outfile" -d "$file"

    status=$?

    if [[ $status -eq 0 ]]; then
        echo -e "${GREEN}[+] File decrypted → $outfile${RESET}"
    else
        echo -e "${RED}[!] Decryption failed.${RESET}"
        return 1
    fi

    echo "───────────────────────────────────────────────────────────────"
}
encrypt_file_serpent() {
    echo "───────────────────────────────────────────────────────────────"
    echo -e "${GREEN}[➜] Encrypting file (Serpent)...${RESET}"
    echo

    if ! command -v gpg >/dev/null 2>&1; then
        echo -e "${RED}[!] GPG is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install gnupg${RESET}"
        return 1
    fi

    read -rp "Enter key size (128/192/256): " bits

    if [[ "$bits" != "128" && "$bits" != "192" && "$bits" != "256" ]]; then
        echo -e "${RED}[!] Invalid key size.${RESET}"
        return 1
    fi

    read -rp "Enter file to encrypt: " file

    if [[ ! -f "$file" ]]; then
        echo -e "${RED}[!] File not found.${RESET}"
        return 1
    fi

    read -rp "Output file: " outfile

    gpg --symmetric --cipher-algo SERPENT256 --s2k-digest-algo SHA512 --compress-algo none -o "$outfile" "$file"

    status=$?

    if [[ $status -eq 0 ]]; then
        echo -e "${GREEN}[+] File encrypted → $outfile${RESET}"
    else
        echo -e "${RED}[!] Encryption failed.${RESET}"
        return 1
    fi

    echo "───────────────────────────────────────────────────────────────"
}
