    echo -e "${GREEN}[+] Free space securely overwritten.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
system_audit() {
    echo "───────────────────────────────────────────────────────────────"
    echo "Lynis by CISOfy https://cisofy.com/lynis/"
    echo -e "${YELLOW}[i] Lynis is an external tool not affiliated with Jas-toolbox.${RESET}"
    echo -e "${YELLOW}    It audits for vulnerabilities, misconfigurations, and compliance issues.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    if ! command -v lynis >/dev/null 2>&1; then
        echo -e "\a"
        echo
        echo -e "${RED}[!] Lynis is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install lynis${RESET}"
        return 1
    fi

    # Warn if not running as root (Lynis gives incomplete results without sudo)
    if [[ $EUID -ne 0 ]]; then
        echo
        echo -e "${YELLOW}[!] Not running as root. Some checks may be skipped.${RESET}"
        echo -e "${YELLOW}    For a full audit, run: sudo jas system_audit${RESET}"
        echo
        read -rp "Continue anyway? (y/n): " cont
        [[ "$cont" != "y" ]] && return 0
    fi

    echo
    echo -e "${GREEN}[➜] Starting Lynis system audit — this may take a few minutes...${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    # Stream output live instead of buffering
    sudo lynis audit system
    status=$?

    echo
    echo "───────────────────────────────────────────────────────────────"

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Lynis finished with errors (exit code $status).${RESET}"
        return 1
    fi

    # Parse the report file for a summary
    local report="/var/log/lynis-report.dat"
    if [[ -f "$report" ]]; then
        echo -e "${CYAN}── Audit Summary ────────────────────────────────────────────${RESET}"

        local index warnings suggestions
        index=$(sudo grep   'hardening_index='  "$report" | cut -d= -f2)
        warnings=$(sudo grep -c '^warning\[\]=' "$report" 2>/dev/null || echo 0)
        suggestions=$(sudo grep -c '^suggestion\[\]=' "$report" 2>/dev/null || echo 0)

        # Colour the hardening index: <60 red, 60-79 yellow, 80+ green
        if [[ -n "$index" ]]; then
            if   (( index >= 80 )); then echo -e "  Hardening index : ${GREEN}${index}/100${RESET}"
            elif (( index >= 60 )); then echo -e "  Hardening index : ${YELLOW}${index}/100${RESET}"
            else                         echo -e "  Hardening index : ${RED}${index}/100${RESET}"
            fi
        fi

        echo -e "  Warnings        : ${RED}${warnings}${RESET}"
        echo -e "  Suggestions     : ${YELLOW}${suggestions}${RESET}"
        echo
        echo -e "  Full report     : ${CYAN}/var/log/lynis-report.dat${RESET}"
        echo -e "  Log             : ${CYAN}/var/log/lynis.log${RESET}"
        echo "───────────────────────────────────────────────────────────────"
    fi
}
rootkit_hunt() {
    echo -e "${GREEN}[+] System audit completed successfully.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo "chkrootkit by chkrootkit Team https://chkrootkit.org/"
    echo -e "${YELLOW}[i] chkrootkit is an external tool not affiliated with Jas-toolbox.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    if ! command -v chkrootkit >/dev/null 2>&1; then
        echo -e "\a"
        echo -e "${RED}[!] chkrootkit is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install chkrootkit${RESET}"
        return 1
    fi

    # chkrootkit needs root for meaningful results
    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}[!] Not running as root. Many checks will be skipped or unreliable.${RESET}"
        echo -e "${YELLOW}    For a full scan, run: sudo jas rootkit_hunt${RESET}"
        echo
        read -rp "Continue anyway? (y/n): " cont
        [[ "$cont" != "y" ]] && return 0
    fi

    echo
    echo -e "${GREEN}[➜] Scanning for rootkits — this may take a moment...${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    # Capture and stream simultaneously so output is visible live
    # and we can still parse it for the summary
    local tmpfile
    tmpfile=$(mktemp)

    sudo chkrootkit 2>&1 | tee "$tmpfile"
    status=${PIPESTATUS[0]}

    echo
    echo "───────────────────────────────────────────────────────────────"

    # Parse results from the captured output
    local infected warnings suspicious
    infected=$(grep -ciE "^INFECTED"  "$tmpfile" 2>/dev/null || echo 0)
    warnings=$(grep -ciE "^WARNING"   "$tmpfile" 2>/dev/null || echo 0)
    suspicious=$(grep -ciE "suspicious" "$tmpfile" 2>/dev/null || echo 0)

    rm -f "$tmpfile"

    echo -e "${CYAN}── Scan Summary ─────────────────────────────────────────────${RESET}"
    echo -e "  INFECTED  : $(  [[ $infected   -gt 0 ]] && echo -e "${RED}${infected}${RESET}"   || echo -e "${GREEN}${infected}${RESET}")"
    echo -e "  Warnings  : $(  [[ $warnings   -gt 0 ]] && echo -e "${RED}${warnings}${RESET}"   || echo -e "${GREEN}${warnings}${RESET}")"
    echo -e "  Suspicious: $([[ $suspicious -gt 0 ]] && echo -e "${YELLOW}${suspicious}${RESET}" || echo -e "${GREEN}${suspicious}${RESET}")"
    echo "---------------------------------------------------------------"

    if [[ $infected -gt 0 || $warnings -gt 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Potential threats detected — review the output above carefully.${RESET}"
        echo -e "${YELLOW}[i] Note: chkrootkit can produce false positives. Verify findings manually.${RESET}"
        return 1
    fi

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] chkrootkit finished with errors (exit code $status).${RESET}"
        return 1
    fi

    echo -e "${GREEN}[+] Rootkit scan completed — no obvious threats found.${RESET}"
    echo "---------------------------------------------------------------"
}
