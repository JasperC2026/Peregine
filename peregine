local_server() {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v python3 >/dev/null 2>&1; then
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install python3"
        exit 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"
    echo 

    echo -e "${DIVIDER}"   
    echo -e "${RED}[!]${RESET} Note: This will expose the contents of the current directory to anyone who can access the specified port on your machine. Make sure you understand the security implications before proceeding."
    echo "This will start a local HTTP server using Python's built-in http.server module. You can access it by navigating to http://localhost:PORT in your web browser, where PORT is the port number you specify."
    echo "Make sure to stop the server when you're done by pressing Ctrl+C in the terminal."
    echo -e "${DIVIDER}"    

    echo -n "Are you sure you want to start a local server? (y/n): "
    read -r confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo -n "Enter port number (default 8000): "
        read -r port

        python3 -m http.server "$port"
        status=$?
    else
        echo -e "${YELLOW}[i]${RESET} Local server setup cancelled."
        return 1
    fi

    if [[ $status -ne 0 ]]; then
        echo -e "${RED}[!]${RESET} Failed to start local server: $output"
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Local server started successfully on port $port"
    fi

    echo "[->] Command executed" 
    echo -e "${DIVIDER}"
}
whois_lookup() {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v whois >/dev/null 2>&1; then
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install whois"
        exit 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"
    echo 

    echo -n "Enter domain: "
    read -r domain

    if [[ -z "$domain" ]]; then
        echo -e "${RED}[!]${RESET} No domain entered. Exiting."
        return 1
    fi

    if ! echo "$domain" | grep -qE '^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}$'; then
        echo -e "${RED}[!] Invalid domain format: '$domain'${RESET}"
        return 1
    fi

    echo -e "${PURPLE}"
    read -p "[TOR] Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    if [[ "$USE_TOR" =~ ^[Yy]$ ]]; then
        if ! command -v torsocks >/dev/null 2>&1; then
            echo -e "${RED}[!]${RESET} Torsocks is not installed. Please install it to use Tor routing."
            echo "Install with: sudo apt install torsocks"
            exit 1
        fi

        echo -e "${GREEN}[+]${RESET} Routing through Tor..."
        output=$(torsocks whois $domain 2>&1)
        status=$?
    else 
        output=$(whois $domain 2>&1)
        status=$?
    fi

    if echo "$output" | grep -qiE "no match|not found|no data found|status: free"; then
        echo -e "\a"
        echo -e "${RED}[!]${RESET} Domain not found or no WHOIS data available."
        return 1
    fi

    if [[ $status -ne 0 ]]; then
        echo -e "${RED}[!]${RESET} Whois lookup failed: $output"
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Whois lookup successful"
        echo -e "${CYAN}WHOIS Information for $domain:${RESET}"
        echo -e "${CYAN}$output${RESET}"
    fi
    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
