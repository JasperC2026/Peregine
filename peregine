generate_key () {
    echo "───────────────────────────────────────────────────────────────"
    echo "OpenSSL by the OpenSSL Project https://openssl.org/"
    echo -e "${GREEN}[➜] Generate a cryptographic key${RESET}"
    echo

    if ! command -v openssl >/dev/null 2>&1; then
        echo -e "\a"
        echo -e "${RED}[!] OpenSSL is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install openssl${RESET}"
        return 1
    fi

    echo -e "${BOLD}Select key size:${RESET}"
    echo "  1) 128-bit  (16 bytes  — AES-128)"
    echo "  2) 192-bit  (24 bytes  — AES-192)"
    echo "  3) 256-bit  (32 bytes  — AES-256)"
    echo "  4) 512-bit  (64 bytes  — ChaCha20 / general use)"
    echo
    read -rp "Choice [1-4]: " choice

    case "$choice" in
        1) bits=128;  bytes=16  ;;
        2) bits=192;  bytes=24  ;;
        3) bits=256;  bytes=32  ;;
        4) bits=512;  bytes=64  ;;
        *)
            echo -e "\a"
            echo -e "${RED}[!] Invalid choice. Enter 1, 2, 3, or 4.${RESET}"
            return 1
            ;;
    esac

    echo
    echo -e "${GREEN}[➜] Generating ${bits}-bit key...${RESET}"
    sleep 0.3

    key=$(openssl rand -hex "$bytes" 2>/dev/null)
    status=$?

    if [[ $status -eq 0 && -n "$key" ]]; then
        echo -e "${CYAN}$key${RESET}"
        echo
        echo -e "${GREEN}[+] ${bits}-bit key generated successfully.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Failed to generate key.${RESET}"
        return 1
    fi
    echo "───────────────────────────────────────────────────────────────"
}
