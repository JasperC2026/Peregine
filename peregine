list_intel_report_options() {
    local target="$1"
    echo
    echo "Options: "
    echo "Traceroute:       t"
    echo "IP-osint:         i"
    echo "DNS-info:         d"
    echo "Maigret search:   m"
    echo "Phone lookup:     p"
    echo "Site history:     s"
    echo "Network explorer: n"
    echo
    echo -n "Enter choice: "
    read -r commands

    local section=""
    local tmpfile
    tmpfile=$(mktemp)

    case "$commands" in
        t) section="Traceroute Results" ;;
        i) section="IP OSINT Results" ;;
        d) section="DNS Info Results" ;;
        m) section="Maigret Search Results" ;;
        p) section="Phone Lookup Results" ;;
        s) section="Site History Results" ;;
        n) section="Network Explorer Results" ;;
        *)
            echo -e "${RED}[!]${RESET} Invalid option."
            rm -f "$tmpfile"
            return 1
            ;;
    esac

    # Run the tool, output goes to terminal AND tmpfile simultaneously
    case "$commands" in
        t) traceroute_base 2>&1 | tee "$tmpfile" ;;
        i) ip_osint_base   2>&1 | tee "$tmpfile" ;;
        d) dns_info_base   2>&1 | tee "$tmpfile" ;;
        m) maigret_search_base 2>&1 | tee "$tmpfile" ;;
        p) phone_lookup_base   2>&1 | tee "$tmpfile" ;;
        s) site_history_base  2>&1 | tee "$tmpfile" ;;
        n) network_explorer_base 2>&1 | tee "$tmpfile" ;;
    esac

    # Append clean (no ANSI codes) output to report
    if [[ -n "$target" && -f "$target.txt" ]]; then
        {
            echo ""
            echo "-------------------------------"
            echo "$section"
            echo "-------------------------------"
            sed 's/\x1b\[[0-9;]*m//g' "$tmpfile"
        } >> "$target.txt"
        echo -e "${GREEN}[+]${RESET} Results appended to $target.txt"
    fi

    rm -f "$tmpfile"
}
