    echo -e "  ${CYAN}[2]${RESET} Verify manifest  — check files against a saved manifest"
    echo
    read -rp "Select mode (1/2): " mode
 
    case "$mode" in
        1) _fic_create ;;
        2) _fic_verify ;;
        *)
