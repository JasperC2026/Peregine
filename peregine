_peregine_list_commands() { 
    echo -e "${CYAN}"
    echo -e "${DIVIDER}" 
    cat <<EOF
'########::'########:'########::'########::'######:::'####:'##::: ##:'########:
 ##.... ##: ##.....:: ##.... ##: ##.....::'##... ##::. ##:: ###:: ##: ##.....::
 ##:::: ##: ##::::::: ##:::: ##: ##::::::: ##:::..:::: ##:: ####: ##: ##:::::::
 ########:: ######::: ########:: ######::: ##::'####:: ##:: ## ## ##: ######:::
 ##.....::: ##...:: :: ##.. ##::: ##...:::: ##::: ##::: ##:: ##. ####: ##...::::
 ##:::::::: ##::::::: ##::. ##:: ##::::::: ##::: ##::: ##:: ##:. ###: ##:::::::
 ##:::::::: ########: ##:::. ##: ########:. ######:::'####: ##::. ##: ########:
..:::::::::........::..:::::..::........:::......::::....::..::::..::........::
                                                        
EOF
    echo -e "${DIVIDER}" 

    echo "All commands:"
    for cmd in "${_PEREGINE_COMMANDS[@]}"; do
        printf "  %-36s %s\n" "$cmd" "$(help "$cmd" | sed -n '2p')"
    done
    echo -e "${DIVIDER}"
}

    if [[ $# -eq 0 ]]; then
       _peregine_list_commands
    elif [[ "$1" == "help" ]]; then
       help "$2"
    elif [[ " ${_PEREGINE_COMMANDS[*]} " == *" $1 "* ]]; then
       "$1"
    else
    echo -e "${RED}[!] Unknown command: $1${RESET}"
    echo -e "    Run ${CYAN}peregine${RESET} without arguments to list all commands."   
    return 1
    fi

