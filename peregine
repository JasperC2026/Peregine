            ;;
        version|v|V)
            echo -e "${CYAN}version / v / V${RESET}"
            echo "  Show the current Peregine version, type, release date, and test date."
            ;;
        osint)
            echo -e "${CYAN}osint${RESET}"
            echo "  Show the OSINT-focused commands in the toolkit."
            ;;
        system/security)
            echo -e "${CYAN}system/security${RESET}"
            echo "  Show the system and security-focused commands in the toolkit."
            ;;
        networking)
            echo -e "${CYAN}networking${RESET}"
            echo "  Show the networking and OSINT-focused commands in the toolkit."
            ;;
        encryption)
            echo -e "${CYAN}encryption${RESET}"
            echo "  Show the encryption-focused commands in the toolkit."
            ;;
        help)
            echo -e "${CYAN}help [command]${RESET}"
            echo "  With no arguments: show all available commands."
            echo "  With a command name: show details and dependencies for that command."
            echo -e "  Example: ${GREEN}peregine help whois${RESET}"
            ;;
        check_dependencies|cd)
            echo -e "${CYAN}check_dependencies / cd ${RESET}"
            echo "  Check the dependencies of the toolkit"
            ;;  
        install_dependencies|id)
