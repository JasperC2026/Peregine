            ;;  
        config)
            echo -e "${CYAN}config${RESET}"
            echo "  Configure Peregine settings and preferences."
            ;;
        *)
            echo -e "${RED}[!] No help entry for '$1'.${RESET}"
            echo -e "    Run ${CYAN}peregine help${RESET} to list all commands."
            echo -e "${DIVIDER}"
            return 1
            ;;
    esac

    echo -e "${DIVIDER}"
}
