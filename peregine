# System Maintenance
update_apps() {
    echo -e "${DIVIDER}"
    echo -n "Name package manager (apt, pacman, snap, pipx, pip): "
    read -r package_manager

    if [[ -z "$package_manager" ]]; then
        echo -e "${RED}[!]${RESET} No package manager entered. Exiting."
        return 1
    fi

    if [[ "$package_manager" == "apt" ]]; then
        sudo apt update && sudo apt upgrade -y
    elif [[ "$package_manager" == "pacman" ]]; then
        sudo pacman -Syu --noconfirm
    elif [[ "$package_manager" == "snap" ]]; then
        sudo snap refresh
    elif [[ "$package_manager" == "pipx" ]]; then
        pipx upgrade-all
    elif [[ "$package_manager" == "pip" ]]; then
        pip list --outdated --format=freeze | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip install -U
    else
        echo -e "${RED}[!]${RESET} Unsupported package manager: '$package_manager'. Please use apt, pacman, snap, pipx, or pip."  
        return 1
    fi
    
    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
# Security
secure_shred_dir() {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v shred >/dev/null 2>&1; then # Check if shred is installed 
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install coreutils"
        exit 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"
    echo
    
    read -rp "Enter directory to shred: " target # Read user input for the directory to shred
    if [[ -z "$target" ]]; then # Check if the user entered a target
        echo -e "${RED}[!]${RESET} No target entered. Exiting."
        return 1
    fi

    target="${target/#\~/$HOME}" # Expand ~ to the user's home directory if it is used in the target path
    if [[ ! -d "$target" ]]; then # Check if the target is a valid directory
        echo -e "${RED}[!]${RESET} Target is not a valid directory: '$target'"
        return 1
    fi

    local abs_target # Get the absolute path of the target directory to ensure we are checking the correct path for safety
    abs_target=$(realpath "$target") # Get the absolute path of the target directory to ensure we are checking the correct path for safety
    if [[ "$abs_target" == "/" || "$abs_target" == "$HOME" ]]; then # Check if the target directory is the root directory or the user's home directory, which would be too dangerous to shred
        echo -e "\a"
        echo -e "${RED}[!] Refusing to shred '$abs_target' — too dangerous.${RESET}"
        return 1
    fi

    echo
    echo -e "  Overwrite passes:" 
    echo -e "  ${CYAN}[1]${RESET} 1 pass  — fast, good enough for most SSDs / already-encrypted"
    echo -e "  ${CYAN}[2]${RESET} 3 passes — DoD 5220.22-M (default, recommended for HDDs)"
    echo -e "  ${CYAN}[3]${RESET} 7 passes — stricter"
    echo -e "  ${CYAN}[4]${RESET} 35 passes — Gutmann (very slow)"
    echo
    read -rp "Select pass count (1-4, default: 2): " pass_choice
 
    local passes # Determine the number of passes based on the user's choice, defaulting to 3 if the input is invalid or empty
    case "$pass_choice" in
        1) passes=1  ;;
        3) passes=7  ;;
        4) passes=35 ;;
        *) passes=3  ;;
    esac
 
    local total_files
    total_files=$(find "$abs_target" -type f | wc -l) # Count the total number of files in the target directory to provide progress feedback during shredding

    echo
    echo -e "${CYAN}  Directory : $abs_target${RESET}"
    echo -e "${CYAN}  Files     : $total_files${RESET}"
    echo -e "${CYAN}  Passes    : $passes${RESET}"
    echo

    echo -e "${RED}[!]${RESET} This will permanently destroy $total_files file(s) in:"
    echo -e "    ${BOLD}$abs_target${RESET}"
    echo
    read -rp "Type the directory name to confirm: " confirm_name

    if [[ "$confirm_name" != "$(basename "$abs_target")" ]]; then # Check if the user correctly confirmed the directory name to prevent accidental shredding
        echo -e "\a"
        echo -e "${RED}[!]${RESET} Confirmation failed. Directory name did not match. Exiting."
        return 1
    fi

    local current=0
    local errors=0
 
    while IFS= read -r -d '' file; do
        (( current++ ))
        local pct=$(( current * 100 / total_files ))
        printf "\r  ${GREEN}[%3d%%]${RESET} (%d/%d) Shredding: %-60s" \
            "$pct" "$current" "$total_files" "$(basename "$file")"
 
        if ! shred -u -z -n "$passes" "$file" 2>/dev/null; then
            echo
            echo -e "  ${RED}[!]${RESET} Failed to shred: $file"
            (( errors++ ))
        fi
    done < <(find "$abs_target" -type f -print0)

    echo -e "${GREEN}[➜]${RESET} Removing directory structure..."
    find "$abs_target" -type l -delete 2>/dev/null
    rm -rf "$abs_target"

  echo
    echo -e "${CYAN}── Summary ──────────────────────────────────────────────────${RESET}"
    echo -e "  Files processed : $current"
 
    if [[ $errors -gt 0 ]]; then
        echo -e "  Errors          : ${RED}$errors${RESET}"
    fi
 
    if [[ -e "$abs_target" ]]; then
        echo -e "\a"
        echo -e "${RED}[!]${RESET} Directory still exists — some files may not have been removed."
        echo -e "Check manually: $abs_target"
        echo "───────────────────────────────────────────────────────────────"
        return 1
    fi
 
    echo -e "  ${GREEN}${RESET}Directory verified gone."
    echo
    echo -e "${GREEN}[+]${RESET} Secure directory shred completed."

    echo "[->] Command executed"
    echo -e "${DIVIDER}" 
}
secure_empty_trash() {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v srm >/dev/null 2>&1; then # Check if srm is installed 
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install srm"
        exit 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"
    echo

    local file_count
    file_count=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l) # Count the number of files in the trash to provide feedback

    if [[ $file_count -eq 0 ]]; then
        echo
        echo -e "${GREEN}[i] Trash is already empty.${RESET}"
        return 0
    fi

    echo -e "${CYAN}[i] Found $file_count item(s) in Trash.${RESET}"
    echo
    read -rp "Securely delete all trash? (y/n): " confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${GREEN}[+]${RESET} Emptying Trash securely..."
        find "$TRASH_FILES" -type f -print0 2>/dev/null | xargs -0 srm -z -n 3 2>/dev/null # Use srm to securely delete files in the trash with 3 passes and zero out the file after shredding
        find "$TRASH_INFO" -type f -print0 2>/dev/null | xargs -0 srm -z -n 3 2>/dev/null # Also securely delete the corresponding info files in the trash
        echo -e "${GREEN}[+]${RESET} Trash emptied securely."
    else
        echo -e "${YELLOW}[i]${RESET} Trash emptying cancelled."
        return 1
    fi

    local remaining
    remaining=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l)

    if [[ $remaining -eq 0 ]]; then
        echo -e "${GREEN}[+] Trash securely emptied.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] $remaining item(s) may not have been deleted — check manually.${RESET}"
        return 1
    fi

    echo "[->] Command executed"
    echo -e "${DIVIDER}" 
}
secure_overwrite_free_space() {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v sfill &> /dev/null; then # Check if sfill is installed
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: sudo apt install secure-delete"
        exit 1
    fi

    echo -e "${GREEN}[+]${RESET} Dependencies are installed"
    echo

    root_partition=$(df / | tail -1 | awk '{print $1}')
    echo -e "${CYAN}[i] Root partition detected: $root_partition${RESET}"

    echo -e "${RED}[!]${RESET} This will securely overwrite all free space on the root partition ($root_partition) to help prevent recovery of deleted files."
    echo -e "${RED}[!]${RESET} This process can take a long time depending on the size of the partition and the amount of free space. Make sure to close other applications and save your work before proceeding."
    
    echo -n "Proceed with secure free space overwrite? (y/n): "
    read -r confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${GREEN}[+]${RESET} Starting secure free space overwrite on $root_partition..."
        sudo sfill -v "$root_partition" # Use sfill to securely overwrite free space on the root partition with verbose output
        status=$? # Capture the exit status of the sfill command to check for errors
    else
        echo -e "${YELLOW}[i]${RESET} Secure free space overwrite cancelled."
        return 1
    fi

    if [[ $status -ne 0 ]]; then # Check if the sfill command executed successfully
        echo -e "${RED}[!]${RESET} Secure free space overwrite failed."
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Secure free space overwrite completed successfully on $root_partition."
    fi
    
    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
