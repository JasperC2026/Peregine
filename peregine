        if command -v shred >/dev/null 2>&1; then
            shred -u -- "$file"
            echo -e "${GREEN}[+]${RESET} Original securely removed (shred)."
        else
            rm -- "$file"
            echo -e "${YELLOW}[i]${RESET} shred not found, file removed normally."
        fi
    fi

    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}

