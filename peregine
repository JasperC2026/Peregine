}

encrypt_text_vigenere() {
    echo -e "$forward Vigenère Cipher"

    echo
    read -rp "Enter text: " text

    read -rp "Enter key: " key

    echo
    animation_begin
    result=$(awk -v text="$text" -v key="$key" '
    function ord(c) { return index("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c) }
    function chr(n) { return substr("ABCDEFGHIJKLMNOPQRSTUVWXYZ", n, 1) }
    BEGIN {
        key = toupper(key)
        text = toupper(text)
        keylen = length(key)
        j = 1
        for (i = 1; i <= length(text); i++) {
            c = substr(text, i, 1)
            if (c ~ /[A-Z]/) {
                shift = ord(substr(key, j, 1)) - 1
                new = (ord(c) + shift - 1) % 26 + 1
                printf "%s", chr(new)
                j = (j % keylen) + 1
            } else {
                printf "%s", c
            }
        }
    }')
    animation_end
    echo -e "${GREEN}[+]${RESET} Result: ${CYAN}$result${RESET}"

    command_executed
}

decrypt_text_vigenere() {
    echo -e "$forward Vigenère Decipher"

    echo
    read -rp "Enter text: " text
    read -rp "Enter key: " key

    echo
    animation_begin
    result=$(awk -v text="$text" -v key="$key" '
    function ord(c) { return index("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c) }
    function chr(n) { return substr("ABCDEFGHIJKLMNOPQRSTUVWXYZ", n, 1) }
    BEGIN {
        key = toupper(key)
        text = toupper(text)
        keylen = length(key)
        j = 1
        for (i = 1; i <= length(text); i++) {
            c = substr(text, i, 1)
            if (c ~ /[A-Z]/) {
                shift = ord(substr(key, j, 1)) - 1
                new = (ord(c) - shift - 1)
                new = (new % 26 + 26) % 26 + 1
                printf "%s", chr(new)
                j = (j % keylen) + 1
            } else {
                printf "%s", c
            }
        }
    }')
    animation_end
    echo -e "${GREEN}[+]${RESET} Result: ${CYAN}$result${RESET}"

    command_executed
}

rot13_cipher() {
    echo -e "$forward ROT13 Cipher"

    echo
    read -rp "Enter text: " text
    animation_begin
    result=$(printf "%s" "$text" | tr 'A-Za-z' 'N-ZA-Mn-za-m')
    animation_end

    echo
    echo -e "${GREEN}[+]${RESET} Result: ${CYAN}$result${RESET}"
    
    command_executed
}
