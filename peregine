            echo -e "${CYAN}── Journal for '$svc' (current boot) ────────────────────────${RESET}"
            journalctl -u "$svc" -b --no-pager 2>/dev/null
            [[ $? -ne 0 ]] && { echo -e "\a${RED}[!] Failed. Check the service name.${RESET}"; return 1; }
            ;;
        4)
            echo -e "${CYAN}── Journal since last boot ──────────────────────────────────${RESET}"
            journalctl -b --no-pager 2>/dev/null
            ;;
        5)
            echo -e "${CYAN}── Live journal feed (Ctrl+C to stop) ───────────────────────${RESET}"
            journalctl -f 2>/dev/null
            ;;
        *)
            echo -e "\a${RED}[!] Invalid choice. Enter 1–5.${RESET}"; return 1 ;;
    esac

    echo
