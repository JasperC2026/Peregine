view_connections() {
    echo "───────────────────────────────────────────────────────────────"
    echo "ss / netstat — active network connections viewer"
    echo -e "${YELLOW}[i] Shows listening ports and established connections.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    local tool
    if command -v ss >/dev/null 2>&1; then tool="ss"
    elif command -v netstat >/dev/null 2>&1; then tool="netstat"
    else
        echo -e "\a${RED}[!] Neither 'ss' nor 'netstat' is available.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install iproute2${RESET}"
        return 1
    fi

    echo -e "${CYAN}[i] Using: $tool${RESET}"
    echo

    echo -e "${BOLD}Show:${RESET}"
    echo "  1) All listening ports"
    echo "  2) All established connections"
    echo "  3) TCP only"
    echo "  4) UDP only"
    echo "  5) Full overview (listening + established, TCP + UDP)"
    echo
    read -rp "Choice [1-5]: " choice

    local output
    case "$choice" in
        1)
            echo -e "${CYAN}── Listening ports ──────────────────────────────────────────${RESET}"
            if [[ "$tool" == "ss" ]]; then output=$(ss -tlnup 2>/dev/null)
            else output=$(netstat -tlnup 2>/dev/null); fi ;;
        2)
            echo -e "${CYAN}── Established connections ──────────────────────────────────${RESET}"
            if [[ "$tool" == "ss" ]]; then output=$(ss -tnp state established 2>/dev/null)
            else output=$(netstat -tnp 2>/dev/null | grep ESTABLISHED); fi ;;
        3)
            echo -e "${CYAN}── TCP connections ──────────────────────────────────────────${RESET}"
            if [[ "$tool" == "ss" ]]; then output=$(ss -tnp 2>/dev/null)
            else output=$(netstat -tnp 2>/dev/null); fi ;;
        4)
            echo -e "${CYAN}── UDP connections ──────────────────────────────────────────${RESET}"
            if [[ "$tool" == "ss" ]]; then output=$(ss -unp 2>/dev/null)
            else output=$(netstat -unp 2>/dev/null); fi ;;
        5)
            echo -e "${CYAN}── Full overview ─────────────────────────────────────────────${RESET}"
            if [[ "$tool" == "ss" ]]; then output=$(ss -tunap 2>/dev/null)
            else output=$(netstat -tunap 2>/dev/null); fi ;;
        *)
            echo -e "\a${RED}[!] Invalid choice. Enter 1–5.${RESET}"; return 1 ;;
    esac

    echo -e "${CYAN}$output${RESET}"
    echo

    local listen_count
    if [[ "$tool" == "ss" ]]; then listen_count=$(ss -tlnup 2>/dev/null | grep -c LISTEN || echo 0)
    else listen_count=$(netstat -tlnup 2>/dev/null | grep -c LISTEN || echo 0); fi
    echo -e "${CYAN}[i] Total listening ports: $listen_count${RESET}"

    echo
    echo -e "${GREEN}[+] Done.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
# System Maintenance
update_apps() {
    echo "───────────────────────────────────────────────────────────────"
    echo -e "${GREEN}[➜] Starting update process...${RESET}"
    echo "───────────────────────────────────────────────────────────────"

    local overall_status=0
    local start_time=$SECONDS

    _update_section() {
        local label="$1"; shift
        local section_start=$SECONDS
        echo
        echo -e "${CYAN}── $label ─────────────────────────────────────────────${RESET}"
        "$@"
        local status=$?
        local elapsed=$(( SECONDS - section_start ))
        if [[ $status -eq 0 ]]; then
            echo -e "${GREEN}[+] $label completed (${elapsed}s).${RESET}"
        else
            echo -e "\a"
            echo -e "${RED}[!] $label failed (${elapsed}s).${RESET}"
            overall_status=1
        fi
        return $status
    }

    # APT
    _update_section "APT" bash -c 'sudo apt update && sudo apt upgrade -y'

    # Flatpak
    if command -v flatpak >/dev/null 2>&1; then
        _update_section "Flatpak" flatpak update -y
    else
        echo -e "${YELLOW}[i] Flatpak not installed — skipping.${RESET}"
    fi

    # Snap
    if command -v snap >/dev/null 2>&1; then
        _update_section "Snap" sudo snap refresh
    else
        echo -e "${YELLOW}[i] Snap not installed — skipping.${RESET}"
    fi

    # pip (user packages)
    if command -v pip3 >/dev/null 2>&1; then
        _update_section "pip3 (user)" bash -c \
            'pip3 list --outdated --format=freeze 2>/dev/null \
             | cut -d= -f1 \
             | xargs -r pip3 install --upgrade --quiet'
    fi

    local total_elapsed=$(( SECONDS - start_time ))
    echo
    echo "───────────────────────────────────────────────────────────────"
    if [[ $overall_status -eq 0 ]]; then
        echo -e "${GREEN}[+] All updates completed successfully (${total_elapsed}s total).${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Some updates failed — check output above (${total_elapsed}s total).${RESET}"
    fi
    echo "───────────────────────────────────────────────────────────────"
}
