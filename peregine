# Security
verify_installed_packages() {
    echo "───────────────────────────────────────────────────────────────"
    echo "debsums by Brendan O'Dea — https://packages.debian.org/debsums"
    echo -e "${GREEN}[➜] Verify installed package file integrity${RESET}"
    echo -e "${YELLOW}[i] Compares installed files against checksums from .deb packages.${RESET}"
    echo -e "${YELLOW}[i] Requires root for a complete check.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    if ! command -v debsums >/dev/null 2>&1; then
        echo -e "\a${RED}[!] debsums is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install debsums${RESET}"
        return 1
    fi

    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}[!] Not running as root — some files will be skipped.${RESET}"
        echo -e "${YELLOW}    For a full check, run: sudo peregrine check_debsums${RESET}"
        echo
        read -rp "Continue anyway? (y/n): " cont
        [[ "$cont" != "y" ]] && return 0
    fi

    echo -e "${BOLD}Check scope:${RESET}"
    echo "  1) All installed packages   (full system check — slow)"
    echo "  2) Changed files only       (faster — highlights tampered files)"
    echo "  3) Specific package"
    echo
    read -rp "Choice [1-3]: " choice

    local tmpfile
    tmpfile=$(mktemp)

    case "$choice" in
        1)
            echo -e "${GREEN}[➜] Checking all packages — this may take several minutes...${RESET}"
            echo "───────────────────────────────────────────────────────────────"
            debsums --all 2>&1 | tee "$tmpfile" ;;
        2)
            echo -e "${GREEN}[➜] Checking for changed files...${RESET}"
            echo "───────────────────────────────────────────────────────────────"
            debsums --changed 2>&1 | tee "$tmpfile" ;;
        3)
            read -rp "Package name: " pkg
            if [[ -z "$pkg" ]]; then
                echo -e "${YELLOW}[!] No package entered.${RESET}"; rm -f "$tmpfile"; return 1
            fi
            if ! dpkg -l "$pkg" 2>/dev/null | grep -q '^ii'; then
                echo -e "\a${RED}[!] Package '$pkg' is not installed.${RESET}"; rm -f "$tmpfile"; return 1
            fi
            echo -e "${GREEN}[➜] Checking package: $pkg...${RESET}"
            echo "───────────────────────────────────────────────────────────────"
            debsums "$pkg" 2>&1 | tee "$tmpfile" ;;
        *)
            echo -e "\a${RED}[!] Invalid choice. Enter 1–3.${RESET}"; rm -f "$tmpfile"; return 1 ;;
    esac

        echo
    echo -e "${CYAN}── Summary ──────────────────────────────────────────────────${RESET}"

    local ok changed missing failed_lines missing_lines
    ok=$(grep -c '\bOK\b'       "$tmpfile" 2>/dev/null); ok=${ok:-0}
    changed=$(grep -c 'FAILED'  "$tmpfile" 2>/dev/null); changed=${changed:-0}
    missing=$(grep -c 'MISSING' "$tmpfile" 2>/dev/null); missing=${missing:-0}
    failed_lines=$(grep 'FAILED'  "$tmpfile" 2>/dev/null)
    missing_lines=$(grep 'MISSING' "$tmpfile" 2>/dev/null)
    rm -f "$tmpfile"

    echo -e "  ${GREEN}OK      : $ok${RESET}"
    echo -e "  ${RED}Failed  : $changed${RESET}"
    echo -e "  ${RED}Missing : $missing${RESET}"
    echo

    if [[ $changed -gt 0 ]]; then
        echo -e "${CYAN}── Failed files ─────────────────────────────────────────────${RESET}"
        while IFS= read -r line; do
            echo -e "  ${RED}$line${RESET}"
        done <<< "$failed_lines"
        echo
    fi

    if [[ $missing -gt 0 ]]; then
        echo -e "${CYAN}── Missing files ────────────────────────────────────────────${RESET}"
        while IFS= read -r line; do
            echo -e "  ${YELLOW}$line${RESET}"
        done <<< "$missing_lines"
        echo
    fi

    if [[ $changed -gt 0 || $missing -gt 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Integrity issues found — $changed changed, $missing missing.${RESET}"
        echo -e "${YELLOW}[i] FAILED may indicate tampering or manual edits. Verify before acting.${RESET}"
        echo -e "${YELLOW}[i] Reinstall with: sudo apt install --reinstall <package>${RESET}"
        echo "───────────────────────────────────────────────────────────────"
        return 1
    fi

    echo -e "${GREEN}[+] All checked files match their package checksums.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
file_integrity_check() {
    echo "───────────────────────────────────────────────────────────────"
    echo "File Integrity Checker — sha256sum"
    echo -e "${YELLOW}[i] Create a hash manifest or verify files against one.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
 
    # ── Dependency check ─────────────────────────────────────────────
    if ! command -v sha256sum >/dev/null 2>&1; then
        echo -e "\a"
