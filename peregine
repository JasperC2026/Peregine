encrypt_text_ceasar() {
    echo -e "$forward Caesar Cipher"
    echo

    read -rp "Enter text: " text
    read -rp "Enter shift (e.g. 3 or -3): " shift

    echo
    animation_begin
    result=$(printf "%s" "$text" | awk -v shift="$shift" '
    BEGIN {
        alphabet="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
        len=length(alphabet)
        for (i=1;i<=len;i++) {
            c=substr(alphabet,i,1)
            new=substr(alphabet,((i-1+shift)%len+len)%len+1,1)
            map[c]=new
        }
    }
    {
        for (i=1;i<=length($0);i++) {
            c=substr($0,i,1)
            printf "%s", (c in map)?map[c]:c
        }
    }')
    animation_end
    echo -e "${GREEN}[+]${RESET} Result: ${CYAN}$result${RESET}"

    command_executed
}

decrypt_text_ceasar() {
    echo -e "$forward Caesar Decipher"

    echo
    read -rp "Enter text: " text

    read -rp "Enter shift (e.g. 3): " shift

    shift=$(( -shift ))
    echo
    animation_begin
    result=$(printf "%s" "$text" | awk -v shift="$shift" '
    BEGIN {
        alphabet="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
        len=length(alphabet)
        for (i=1;i<=len;i++) {
            c=substr(alphabet,i,1)
