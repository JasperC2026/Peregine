phone_lookup () {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v phoneinfoga >/dev/null 2>&1; then
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: bash <( curl -sSL https://raw.githubusercontent.com/sundowndev/phoneinfoga/master/support/scripts/install )"
        echo "sudo install ./phoneinfoga /usr/local/bin/phoneinfoga"
        return 1
    fi

    status_dependencies

    echo
    osint_disclaimer
    echo

    echo -n "Enter phone number (with country code, e.g. +1234567890): "
    read -r phone

    if [[ -z "$phone" ]]; then
        echo -e "${RED}[!]${RESET} No phone number entered. Exiting."
        return 1
    fi

    if ! echo "$phone" | grep -qE '^\+\d{10,15}$'; then
        echo -e "${RED}[!] Invalid phone number format: '$phone'${RESET}"
        return 1
    fi

    if [[ "$phone" == "+1234567890" ]]; then
        echo -e "${RED}[!]${RESET} Example phone number entered. Please enter a valid phone number with country code."
        return 1
    fi

    echo -e "${PURPLE}"
    read -p "Route through Tor? (y/n): " USE_TOR
    echo -e "${RESET}"

    if [[ "$USE_TOR" =~ ^[Yy]$ ]]; then
        if ! command -v torsocks >/dev/null 2>&1; then
            echo -e "${RED}[!]${RESET} Torsocks is not installed. Please install it to use Tor routing."
            echo "Install with: sudo apt install torsocks"
            return 1
        fi
        echo -e "${GREEN}[+]${RESET} Routing through Tor..."
        output=$(torsocks phoneinfoga scan -n "$phone" 2>&1)
        status=$?
    else 
        output=$(phoneinfoga scan -n "$phone" 2>&1)
        status=$?
    fi

    if [[ $status -ne 0 ]]; then
        echo -e "${RED}[!]${RESET} Phone lookup failed: $output"
        return 1
    else
        echo -e "${GREEN}[+]${RESET} Phone lookup successful for $phone"
        echo -e "${output_color}PhoneInfoga results for $phone:${RESET}"
        echo -e "${output_color}$output${RESET}"
    fi
    
    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
web_phone_lookup () {
    echo -e "${DIVIDER}"
    echo "[->] Checking dependencies"

    if ! command -v phoneinfoga >/dev/null 2>&1; then
        echo "${RED}[!]${RESET} Required dependencie not installed"
        echo "Install with: bash <( curl -sSL https://raw.githubusercontent.com/sundowndev/phoneinfoga/master/support/scripts/install )"
        echo "sudo install ./phoneinfoga /usr/local/bin/phoneinfoga"
        return 1
    fi

    status_dependencies

    echo
    osint_disclaimer
    echo

    echo -n "Enter port to host web interface on (default 8080): "
    read -r port

    if [[ -z "$port" ]]; then
        port=8080
    fi

    if ! [[ "$port" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
        echo -e "${RED}[!]${RESET} Invalid port number: '$port'. Please enter a number between 1 and 65535."
        return 1
    fi

    if lsof -i :"$port" >/dev/null 2>&1; then
        echo -e "${RED}[!]${RESET} Port $port is already in use. Please choose a different port."
        return 1
    fi

    echo -n "Confirm hosting PhoneInfoga web interface on port $port? (y/n): "
    read -r confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${GREEN}[+]${RESET} Starting PhoneInfoga web interface on port $port..."
        phoneinfoga serve -p "$port"
        status=$?
    else
        echo -e "${YELLOW}[i]${RESET} Web interface setup cancelled."
        return 1
    fi

    if [[ $status -ne 0 ]]; then
        echo -e "${RED}[!]${RESET} Failed to start web interface: $output"
        return 1
    else
        echo -e "${GREEN}[+]${RESET} PhoneInfoga web interface started successfully on port $port"
        echo -e "Access it at: ${output_color}http://localhost:$port${RESET}"
    fi

    echo "[->] Command executed"
    echo -e "${DIVIDER}"
}
