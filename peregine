generate_password() {
    echo "───────────────────────────────────────────────────────────────"
    echo "OpenSSL by the OpenSSL Project https://openssl.org/"
    echo -e "${GREEN}[➜] Secure password generator${RESET}"
    echo

    if ! command -v openssl >/dev/null 2>&1; then
        echo
        echo -e "\a"
        echo -e "${RED}[!] OpenSSL is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install openssl${RESET}"
        return 1
    fi

    read -rp "Password length (default: 16, max: 128): " length

    length=${length:-16}

    if ! [[ "$length" =~ ^[0-9]+$ ]] || (( length < 8 || length > 128 )); then
        echo
        echo -e "\a"
        echo -e "${RED}[!] Invalid length '$length' — must be a number between 8 and 128.${RESET}"
        return 1
    fi

    echo
    echo -e "${CYAN}── Passwords ────────────────────────────────────────────────${RESET}"

    local pass_alnum
    pass_alnum=$(openssl rand -base64 96 | tr -dc 'A-Za-z0-9' | head -c "$length")
    echo -e "  Alphanumeric : ${CYAN}${pass_alnum}${RESET}"

    local pass_full
    pass_full=$(openssl rand -base64 96 | tr -dc 'A-Za-z0-9!@#$%^&*()-_=+[]{}|;:,.<>?' | head -c "$length")
    echo -e "  With symbols : ${CYAN}${pass_full}${RESET}"

    local pass_hex
    pass_hex=$(openssl rand -hex 64 | head -c "$length")
    echo -e "  Hex          : ${CYAN}${pass_hex}${RESET}"

    echo
    local entropy_alnum entropy_full
    entropy_alnum=$(awk "BEGIN { printf \"%d\", $length * 5.954 }")
    entropy_full=$(awk  "BEGIN { printf \"%d\", $length * 6.554 }")
    echo -e "${CYAN}[i] Estimated entropy — alphanumeric: ~${entropy_alnum} bits  |  with symbols: ~${entropy_full} bits${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
secure_delete() {
    echo "───────────────────────────────────────────────────────────────"
    echo -n "Enter file or directory to securely delete: "
    read -r target
    echo

    if [[ -z "$target" ]]; then
        echo -e "${YELLOW}[!] No target entered.${RESET}"
        return 1
    fi

    if [[ ! -e "$target" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Target does not exist: '$target'${RESET}"
        return 1
    fi

    if [[ -d "$target" ]]; then
        echo -e "${YELLOW}[!] '$target' is a directory.${RESET}"
        read -rp "Securely delete entire directory and contents? (y/n): " confirm
        [[ "$confirm" != "y" ]] && return 0

        echo -e "${GREEN}[➜] Shredding all files in '$target'...${RESET}"
        find "$target" -type f -exec shred -u -v -n 5 {} \;
        rm -rf "$target"

        if [[ ! -e "$target" ]]; then
            echo -e "${GREEN}[+] Directory securely deleted.${RESET}"
        else
            echo -e "\a"
            echo -e "${RED}[!] Directory may not have been fully removed.${RESET}"
            return 1
        fi

    elif [[ -f "$target" ]]; then
        read -rp "Securely delete '$target'? (y/n): " confirm
        [[ "$confirm" != "y" ]] && return 0

        echo -e "${GREEN}[➜] Shredding '$target'...${RESET}"
        shred -u -v -n 5 "$target"

        if [[ ! -e "$target" ]]; then
            echo
            echo -e "${GREEN}[+] File securely deleted.${RESET}"
        else
            echo -e "\a"
            echo
            echo -e "${RED}[!] File may still exist — check manually.${RESET}"
            return 1
        fi
    else
        echo -e "\a"
        echo
        echo -e "${RED}[!] Target is not a regular file or directory (symlink, device, etc.).${RESET}"
        return 1
    fi

    echo "───────────────────────────────────────────────────────────────"
}
clean_metadata() {
    echo "───────────────────────────────────────────────────────────────"
    echo "ExifTool by Phil Harvey https://exiftool.org/"
    echo -e "${GREEN}[➜] Remove metadata from a file${RESET}"
    echo

    if ! command -v exiftool >/dev/null 2>&1; then
        echo -e "\a"
        echo -e "${RED}[!] exiftool is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install libimage-exiftool-perl${RESET}"
        return 1
    fi

    read -rp "Enter input file: " file

    if [[ ! -f "$file" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] File not found: '$file'${RESET}"
        return 1
    fi

    local mimetype
    mimetype=$(file --mime-type -b "$file")
    case "$mimetype" in
        image/*|video/*|audio/*|application/pdf)
            ;;
        *)
            echo -e "\a"
            echo -e "${RED}[!] Unsupported file type: $mimetype${RESET}"
            echo -e "${YELLOW}[i] exiftool supports images, video, audio, and PDF.${RESET}"
            return 1
            ;;
    esac

    local meta_count
    meta_count=$(exiftool "$file" 2>/dev/null | grep -v "^File\|^Directory\|^MIME\|^ExifTool" | wc -l)
    echo -e "${CYAN}[i] Found $meta_count metadata fields in '$file'.${RESET}"
    echo

    read -rp "Output file (leave blank to overwrite original): " outfile

    if [[ -z "$outfile" ]]; then
        echo -e "${YELLOW}[!] This will overwrite the original file.${RESET}"
        read -rp "Confirm? (y/n): " confirm
        [[ "$confirm" != "y" ]] && return 0

        exiftool -all= -overwrite_original "$file" >/dev/null 2>&1
        status=$?
        outfile="$file"
    else
        exiftool -all= -overwrite_original -o "$outfile" "$file" >/dev/null 2>&1
        status=$?
    fi

    if [[ $status -ne 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Failed to remove metadata.${RESET}"
        return 1
    fi

    local remaining
    remaining=$(exiftool "$outfile" 2>/dev/null | grep -v "^File\|^Directory\|^MIME\|^ExifTool" | wc -l)
    echo -e "${GREEN}[+] Metadata removed → $outfile${RESET}"
    echo -e "${CYAN}[i] Remaining metadata fields: $remaining (filesystem/format fields only).${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
strip_metadata_mat2() {
    echo "───────────────────────────────────────────────────────────────"
    echo "MAT2 by the Tails Project https://0xacab.org/jvoisin/mat2"
    echo -e "${GREEN}[➜] Strip metadata from files (PDF, Office, images, audio, video)${RESET}"
    echo -e "${YELLOW}[i] MAT2 supports a wider range of formats than exiftool.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
    echo

    if ! command -v mat2 >/dev/null 2>&1; then
        echo -e "\a${RED}[!] mat2 is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install mat2${RESET}"
        return 1
    fi

    read -rp "Enter file or directory to process: " target
    [[ -z "$target" ]] && { echo -e "${YELLOW}[!] No target entered.${RESET}"; return 1; }
    [[ ! -e "$target" ]] && { echo -e "\a${RED}[!] Not found: '$target'${RESET}"; return 1; }

    local files=()
    if [[ -f "$target" ]]; then
        files=("$target")
    elif [[ -d "$target" ]]; then
        while IFS= read -r -d '' f; do files+=("$f")
        done < <(find "$target" -type f -print0)
        echo -e "${CYAN}[i] Found ${#files[@]} file(s) in '$target'.${RESET}"
    fi

    [[ ${#files[@]} -eq 0 ]] && { echo -e "${YELLOW}[!] No files found.${RESET}"; return 1; }

    echo
    echo -e "${BOLD}Action:${RESET}"
    echo "  1) Preview only    (show metadata without modifying)"
    echo "  2) Clean files     (saves as filename.cleaned.ext)"
    echo "  3) Clean in-place  (overwrites originals — use with caution)"
    echo
    read -rp "Choice [1-3]: " choice

    local ok=0 skipped=0 errors=0

    _mat2_process() {
        local flag="$1" f="$2" result
        result=$(mat2 $flag "$f" 2>&1)
        if [[ $? -eq 0 ]]; then
            echo -e "  ${GREEN}[+]${RESET} $f"; (( ok++ ))
        elif echo "$result" | grep -qi "unsupported\|unknown"; then
            echo -e "  ${YELLOW}[~]${RESET} $f — unsupported, skipped"; (( skipped++ ))
        else
            echo -e "  ${RED}[!]${RESET} $f — $result"; (( errors++ ))
        fi
    }

    case "$choice" in
        1)
            echo -e "${CYAN}── Metadata preview ─────────────────────────────────────────${RESET}"
            for f in "${files[@]}"; do
                echo -e "${BOLD}▶ $f${RESET}"
                mat2 --show "$f" 2>/dev/null || echo -e "  ${YELLOW}[!] Unsupported or no metadata.${RESET}"
                echo
            done
            echo -e "${YELLOW}[i] No files were modified.${RESET}"
            echo "───────────────────────────────────────────────────────────────"
            return 0
            ;;
        2)
            echo -e "${GREEN}[➜] Cleaning ${#files[@]} file(s)...${RESET}"
            for f in "${files[@]}"; do _mat2_process "" "$f"; done ;;
        3)
            echo -e "${YELLOW}[!] In-place mode overwrites originals. This cannot be undone.${RESET}"
            read -rp "Confirm? (y/n): " confirm
            [[ "$confirm" != "y" ]] && return 0
            echo -e "${GREEN}[➜] Cleaning ${#files[@]} file(s) in-place...${RESET}"
            for f in "${files[@]}"; do _mat2_process "--inplace" "$f"; done ;;
        *)
            echo -e "\a${RED}[!] Invalid choice. Enter 1–3.${RESET}"; return 1 ;;
    esac

    echo
    echo -e "${CYAN}── Summary ──────────────────────────────────────────────────${RESET}"
    echo -e "  ${GREEN}Cleaned  : $ok${RESET}"
    echo -e "  ${YELLOW}Skipped  : $skipped${RESET}"
    [[ $errors -gt 0 ]] && echo -e "  ${RED}Errors   : $errors${RESET}"
    echo

    if [[ $errors -gt 0 ]]; then
        echo -e "\a${RED}[!] Some files could not be processed.${RESET}"
        echo "───────────────────────────────────────────────────────────────"
        return 1
    fi

    echo -e "${GREEN}[+] Metadata stripping complete.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
