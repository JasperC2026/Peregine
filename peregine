        "$(printf "  ${CLABEL}${BOLD}  %-26s${RESET} ${CSEP}%s${RESET}" "Text — Encrypt" "Decrypt")"
        "$(printf "${CSEP}  ─────────────────────────────────────────────────${RESET}")"
        "$(printf "  ${CLABEL}${BOLD}%-28s${RESET} ${CVAL}%s${RESET}" "encrypt_text_aes256" "decrypt_text_aes256")"
