# Internal commands
menu() {
    local options=("$@")
    local selected=0
    local key

    tput civis  # hide cursor
    trap 'tput cnorm; exit' INT TERM EXIT

    while true; do
        # draw menu
        for i in "${!options[@]}"; do
            if [ "$i" -eq "$selected" ]; then
                tput setaf 2  # green
                echo "> ${options[$i]}"
                tput sgr0
            else
                echo "  ${options[$i]}"
            fi
        done

        # read a key (handles escape sequences)
        IFS= read -rsn1 key
        if [[ $key == $'\x1b' ]]; then
            read -rsn2 key
            case "$key" in
                '[A') ((selected--)); [ "$selected" -lt 0 ] && selected=$((${#options[@]}-1)) ;;
                '[B') ((selected++)); [ "$selected" -ge "${#options[@]}" ] && selected=0 ;;
            esac
        elif [[ $key == "" ]]; then
            break  # Enter pressed
        fi

        # move cursor back up to redraw
        tput cuu "${#options[@]}"
    done

    tput cnorm
    echo "You chose: ${options[$selected]}"
}
