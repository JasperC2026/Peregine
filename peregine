}
secure_shred_dir() {
    echo "───────────────────────────────────────────────────────────────"
    echo "Secure Directory Shredder — shred (coreutils)"
    echo -e "${YELLOW}[!] This permanently destroys all files inside a directory.${RESET}"
    echo -e "${YELLOW}[!] Note: shred is most effective on traditional HDDs.${RESET}"
    echo -e "${YELLOW}    SSDs/flash storage may not honour overwrite passes fully${RESET}"
    echo -e "${YELLOW}    due to wear-levelling. Use disk encryption for SSDs.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
 
    # ── Dependency check ─────────────────────────────────────────────
    if ! command -v shred >/dev/null 2>&1; then
        echo -e "\a"
        echo -e "${RED}[!] shred not found.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install coreutils${RESET}"
        return 1
    fi
 
    # ── Target input ─────────────────────────────────────────────────
    echo
    read -rp "Enter directory to shred: " target
 
    if [[ -z "$target" ]]; then
        echo -e "${YELLOW}[!] No target entered.${RESET}"
        return 1
    fi
 
    # Expand ~ manually in case the user typed it
    target="${target/#\~/$HOME}"
 
    if [[ ! -e "$target" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Target does not exist: '$target'${RESET}"
        return 1
    fi
 
    if [[ ! -d "$target" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] '$target' is not a directory.${RESET}"
        echo -e "${YELLOW}[i] Use 'secure_delete' for single files.${RESET}"
        return 1
    fi
 
    # Refuse to shred root or home
    local abs_target
    abs_target=$(realpath "$target")
    if [[ "$abs_target" == "/" || "$abs_target" == "$HOME" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Refusing to shred '$abs_target' — too dangerous.${RESET}"
        return 1
    fi
 
    # ── Pass count ───────────────────────────────────────────────────
    echo
    echo -e "  Overwrite passes:"
    echo -e "  ${CYAN}[1]${RESET} 1 pass  — fast, good enough for most SSDs / already-encrypted"
    echo -e "  ${CYAN}[2]${RESET} 3 passes — DoD 5220.22-M (default, recommended for HDDs)"
    echo -e "  ${CYAN}[3]${RESET} 7 passes — stricter"
    echo -e "  ${CYAN}[4]${RESET} 35 passes — Gutmann (very slow)"
    echo
    read -rp "Select pass count (1-4, default: 2): " pass_choice
 
    local passes
    case "$pass_choice" in
        1) passes=1  ;;
        3) passes=7  ;;
        4) passes=35 ;;
        *) passes=3  ;;   # default: DoD 3-pass
    esac
 
    # ── Count files before starting ──────────────────────────────────
    local total_files
    total_files=$(find "$abs_target" -type f | wc -l)
 
    echo
    echo -e "${CYAN}  Directory : $abs_target${RESET}"
    echo -e "${CYAN}  Files     : $total_files${RESET}"
    echo -e "${CYAN}  Passes    : $passes${RESET}"
    echo
 
    if [[ $total_files -eq 0 ]]; then
        echo -e "${YELLOW}[i] Directory is empty — nothing to shred.${RESET}"
        read -rp "Remove the empty directory structure? (y/n): " rm_empty
        if [[ "$rm_empty" == "y" ]]; then
            rm -rf "$abs_target"
            echo -e "${GREEN}[+] Empty directory removed.${RESET}"
        fi
        echo "───────────────────────────────────────────────────────────────"
        return 0
    fi
 
    # ── Confirmation ─────────────────────────────────────────────────
    echo -e "${RED}[!] This will permanently destroy $total_files file(s) in:${RESET}"
    echo -e "    ${BOLD}$abs_target${RESET}"
    echo
    read -rp "Type the directory name to confirm: " confirm_name
 
    if [[ "$confirm_name" != "$(basename "$abs_target")" ]]; then
        echo -e "${YELLOW}[!] Name did not match — operation aborted.${RESET}"
        return 0
    fi
 
    # ── Shred ────────────────────────────────────────────────────────
    echo
    echo -e "${GREEN}[➜] Shredding $total_files file(s) with $passes pass(es)...${RESET}"
    echo
 
    local current=0
    local errors=0
 
    while IFS= read -r -d '' file; do
        (( current++ ))
        local pct=$(( current * 100 / total_files ))
        printf "\r  ${GREEN}[%3d%%]${RESET} (%d/%d) Shredding: %-60s" \
            "$pct" "$current" "$total_files" "$(basename "$file")"
 
        if ! shred -u -z -n "$passes" "$file" 2>/dev/null; then
            echo
            echo -e "  ${RED}[!]${RESET} Failed to shred: $file"
            (( errors++ ))
        fi
    done < <(find "$abs_target" -type f -print0)
 
    echo   # newline after progress line
    echo
 
    # ── Remove remaining empty dirs and symlinks ──────────────────────
    echo -e "${GREEN}[➜] Removing directory structure...${RESET}"
    find "$abs_target" -type l -delete 2>/dev/null   # remove any symlinks
    rm -rf "$abs_target"
 
    # ── Verify ───────────────────────────────────────────────────────
    echo
    echo -e "${CYAN}── Summary ──────────────────────────────────────────────────${RESET}"
    echo -e "  Files processed : $current"
 
    if [[ $errors -gt 0 ]]; then
        echo -e "  Errors          : ${RED}$errors${RESET}"
    fi
 
    if [[ -e "$abs_target" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Directory still exists — some files may not have been removed.${RESET}"
        echo -e "${YELLOW}    Check manually: $abs_target${RESET}"
        echo "───────────────────────────────────────────────────────────────"
        return 1
    fi
 
    echo -e "  ${GREEN}Directory verified gone.${RESET}"
    echo
    echo -e "${GREEN}[+] Secure directory shred completed.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
secure_empty_trash() {
    echo "───────────────────────────────────────────────────────────────"

    local TRASH_FILES="$HOME/.local/share/Trash/files"
    local TRASH_INFO="$HOME/.local/share/Trash/info"

    if ! command -v srm &>/dev/null; then
        echo -e "\a"
        echo
        echo -e "${RED}[!] srm is not installed.${RESET}"
        echo -e "${YELLOW}[i] Install with: sudo apt install secure-delete${RESET}"
        return 1
    fi

    # Count items using find to avoid glob expansion issues on empty dirs
    local file_count
    file_count=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l)

    if [[ $file_count -eq 0 ]]; then
        echo
        echo -e "${GREEN}[i] Trash is already empty.${RESET}"
        echo "---------------------------------------------------------------"
        return 0
    fi

    echo -e "${CYAN}[i] Found $file_count item(s) in Trash.${RESET}"
    echo
    read -rp "Securely delete all trash? (y/n): " confirm
    if [[ "$confirm" != "y" ]]; then
        echo -e "${YELLOW}[!] Deletion aborted.${RESET}"
        return 0
    fi

    echo
    echo -e "${GREEN}[➜] Securely deleting trash files...${RESET}"
    find "$TRASH_FILES" -mindepth 1 -exec srm -v -r {} + 2>/dev/null

    echo
    echo -e "${GREEN}[➜] Removing trash metadata...${RESET}"
    find "$TRASH_INFO" -mindepth 1 -name "*.trashinfo" -exec srm -v {} + 2>/dev/null

    # Verify
    local remaining
    remaining=$(find "$TRASH_FILES" -mindepth 1 2>/dev/null | wc -l)
    if [[ $remaining -eq 0 ]]; then
        echo -e "${GREEN}[+] Trash securely emptied.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] $remaining item(s) may not have been deleted — check manually.${RESET}"
        return 1
    fi

    echo "───────────────────────────────────────────────────────────────"
}
secure_overwrite_free_space() {
