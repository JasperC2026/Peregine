# File integrity commands
_fic_create() {
    read -rp "Enter file or directory to hash: " target
 
    if [[ -z "$target" ]]; then
        echo -e "${YELLOW}[!] No target entered.${RESET}"
        return 1
    fi
 
    if [[ ! -e "$target" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Target does not exist: '$target'${RESET}"
        return 1
    fi
 
    # Default manifest path next to the target
    local default_manifest
    default_manifest="$(basename "$target").sha256manifest"
    read -rp "Save manifest to (default: $default_manifest): " manifest
    manifest="${manifest:-$default_manifest}"
 
    # Warn if manifest already exists
    if [[ -f "$manifest" ]]; then
        echo -e "${YELLOW}[!] '$manifest' already exists — it will be overwritten.${RESET}"
        read -rp "Continue? (y/n): " confirm
        [[ "$confirm" != "y" ]] && return 0
    fi
 
    echo
    echo -e "${GREEN}[➜] Hashing files in '$target'...${RESET}"
    sleep 0.5
 
    local count=0
    local errors=0
 
    {
        echo "# jas file integrity manifest"
        echo "# Target  : $target"
        echo "# Created : $(date)"
        echo "# Format  : sha256  path"
        echo
    } > "$manifest"
 
    if [[ -f "$target" ]]; then
        # Single file
        local hash
        hash=$(sha256sum "$target" 2>/dev/null | awk '{print $1}')
        if [[ -n "$hash" ]]; then
            echo "$hash  $target" >> "$manifest"
            echo -e "  ${GREEN}[+]${RESET} $target"
            (( count++ ))
        else
            echo -e "  ${RED}[!]${RESET} Failed to hash: $target"
            (( errors++ ))
        fi
    elif [[ -d "$target" ]]; then
        # Walk directory, skip symlinks
        while IFS= read -r -d '' file; do
            local hash
            hash=$(sha256sum "$file" 2>/dev/null | awk '{print $1}')
            if [[ -n "$hash" ]]; then
                echo "$hash  $file" >> "$manifest"
                echo -e "  ${GREEN}[+]${RESET} $file"
                (( count++ ))
            else
                echo -e "  ${RED}[!]${RESET} Failed to hash: $file"
                (( errors++ ))
            fi
        done < <(find "$target" -type f -print0 | sort -z)
    fi
 
    echo
    echo -e "${CYAN}── Summary ──────────────────────────────────────────────────${RESET}"
    echo -e "  Files hashed : ${GREEN}${count}${RESET}"
    if [[ $errors -gt 0 ]]; then
        echo -e "  Errors       : ${RED}${errors}${RESET}"
    fi
    echo -e "  Manifest     : ${CYAN}${manifest}${RESET}"
 
    if [[ $count -eq 0 ]]; then
        echo -e "\a"
        echo -e "${RED}[!] No files were hashed.${RESET}"
        rm -f "$manifest"
        return 1
    fi
 
    echo -e "${GREEN}[+] Manifest created successfully.${RESET}"
    echo "───────────────────────────────────────────────────────────────"
}
_fic_verify() {
    read -rp "Enter manifest file to verify against: " manifest
 
    if [[ -z "$manifest" ]]; then
        echo -e "${YELLOW}[!] No manifest entered.${RESET}"
        return 1
    fi
 
    if [[ ! -f "$manifest" ]]; then
        echo -e "\a"
        echo -e "${RED}[!] Manifest not found: '$manifest'${RESET}"
        return 1
    fi
 
    echo
    echo -e "${GREEN}[➜] Verifying files against '$manifest'...${RESET}"
    sleep 0.5
 
    local ok=0
    local changed=0
    local missing=0
 
    while IFS= read -r line; do
        # Skip comment/blank lines
        [[ "$line" =~ ^#  ]] && continue
        [[ -z "$line"     ]] && continue
 
        local stored_hash filepath
        stored_hash=$(echo "$line" | awk '{print $1}')
        filepath=$(echo "$line" | awk '{print $2}')
 
        if [[ ! -e "$filepath" ]]; then
            echo -e "  ${RED}[MISSING]${RESET}  $filepath"
            (( missing++ ))
            continue
        fi
 
        local current_hash
        current_hash=$(sha256sum "$filepath" 2>/dev/null | awk '{print $1}')
 
        if [[ "$current_hash" == "$stored_hash" ]]; then
            echo -e "  ${GREEN}[OK]${RESET}       $filepath"
            (( ok++ ))
        else
            echo -e "  ${RED}[CHANGED]${RESET}  $filepath"
            echo -e "             stored : ${YELLOW}${stored_hash}${RESET}"
            echo -e "             current: ${RED}${current_hash}${RESET}"
            (( changed++ ))
        fi
    done < "$manifest"
 
    echo
    echo -e "${CYAN}── Verification Summary ──────────────────────────────────────${RESET}"
    echo -e "  ${GREEN}OK      : $ok${RESET}"
    echo -e "  ${RED}Changed : $changed${RESET}"
    echo -e "  ${RED}Missing : $missing${RESET}"
    echo
 
    if [[ $changed -eq 0 && $missing -eq 0 ]]; then
        echo -e "${GREEN}[+] All files match the manifest — integrity verified.${RESET}"
    else
        echo -e "\a"
        echo -e "${RED}[!] Integrity check FAILED — $changed changed, $missing missing.${RESET}"
        echo "───────────────────────────────────────────────────────────────"
        return 1
    fi
    echo "───────────────────────────────────────────────────────────────"
}
