# ─── Install functions ────────────────────────────────────────────────────────

_install_version() {
    local tag="$1"
    echo "Installing $tag..."

    curl -L "https://codeberg.org/JasperC/Peregine/archive/${tag}.tar.gz" -o /tmp/peregine.tar.gz

    mkdir -p ~/Peregine
    tar -xzf /tmp/peregine.tar.gz -C ~/Peregine --strip-components=1

    chmod +x ~/Peregine/peregine
    chmod +x ~/Peregine/peregine_loading.sh
    sudo ln -sf ~/Peregine/peregine /usr/local/bin/peregine
    sudo ln -sf ~/Peregine/peregine_loading.sh /usr/local/bin/peregine_loading.sh

    echo "Done! Peregine $tag installed."
}

install_stable_40()  { _install_version "stable_4.0"; }
install_stable_391() { _install_version "stable_3.9.1"; }
install_stable_38()  { _install_version "stable_3.8"; }
install_beta_37()    { _install_version "beta_3.7"; }

